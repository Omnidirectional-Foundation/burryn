// vm.bur — bytecode interpreter, mirroring vm.go + gc.go + builtins.go.
//
// Interpreted values are Val. Scalars and strings live inline (strings are
// immutable and content-equal, so host strings serve directly); every
// mutable or identity-bearing object (list, map, closure, upvalue, enum
// instance, channel, native, enum type, variant ctor) lives in a tagged
// arena of parallel mut lists reached through an int handle, because mut
// does not penetrate enum fields. The interpreted heap has its own
// mark-sweep collector ported from gc.go: handles are plain ints the host
// GC cannot trace, so slot liveness is the VM's own job. Freed slots drop
// their payloads (letting the host GC reclaim the memory) and go on a free
// list for reuse.
//
// Fibers are plain data in parallel mut lists — the scheduler is the same
// FIFO ready-queue loop as vm.go, running on one host thread. Runtime traps
// print to stderr and exit(4) directly: a trap always ends the program, so
// nothing needs to unwind.

// interpreted runtime value
enum Val {
    VUnit,
    VBool(bool),
    VInt(int),
    VFloat(float),
    VStr(str),
    VObj(int), // arena handle
}

// chan_try_recv result (the language has no tuples)
enum RecvRes {
    RecvGot(Val),
    RecvNone,
}

// arena object tags
let ot_free = 0
let ot_list = 1
let ot_map = 2
let ot_closure = 3
let ot_upval = 4
let ot_enuminst = 5
let ot_channel = 6
let ot_native = 7
let ot_enumtype = 8
let ot_ctor = 9
let ot_record = 10

// fiber status (vm.go FiberStatus)
let fs_ready = 0
let fs_blocked_send = 1
let fs_blocked_recv = 2
let fs_blocked_select = 3
let fs_done = 4
let fs_blocked_timer = 5
let fs_blocked_io = 6
let fs_blocked_net = 7
let fs_blocked_stdin = 8

let wait_timer = 1
let wait_exec = 2
let wait_net = 3

// instructions per fiber before a forced yield (vm.go timeSlice)
let vm_time_slice = 10000

// run_program interprets a Compiled(...) payload: the function arena
// (name/file/arity/upvals/code/spans/consts, entry = handle 0), the enum
// arena (qualified name, variant names, variant arities) and the
// interpreted program's argv.
pub fn run_program(f_name, f_file, f_arity, f_nupvals, f_code, f_spans, f_consts, en_qual, en_vnames, en_varities, vm_args, ls_files, ls_names, ls_tables) {
    let max_int = 9223372036854775807
    let min_int = -9223372036854775807 - 1

    // ---- interpreted heap arena (parallel lists, one slot per handle) ----
    let mut o_tag = []
    let mut o_mark = []
    let mut o_vals = [] // list elems / enum inst fields / channel buffer
    let mut o_keys = [] // map keys, parallel to o_vals entries
    let mut o_idxi = [] // map: int key -> entry position
    let mut o_idxs = [] // map: str key -> entry position
    let mut o_i1 = [] // closure:fn / upval:fiber / inst:enum / chan:cap / native:id / enumtype:enum / ctor:enum
    let mut o_i2 = [] // upval:slot / inst:variant / ctor:variant
    let mut o_b1 = [] // upval:open / chan:closed
    let mut o_v1 = [] // upval: closed-over value
    let mut o_h1 = [] // closure: upvalue handles / chan: sendq fiber ids
    let mut o_h2 = [] // chan: recvq fiber ids
    let mut o_h3 = [] // chan: select waiter fiber ids
    let mut free_slots = []
    let mut pinned = [] // permanent roots: enum types, ctors, singletons, natives
    let mut obj_count = 0
    let mut gc_threshold = 256
    let mut gc_total_alloc = 0
    let mut gc_cycles_n = 0
    let mut vm_on = false // collections only run once the fibers exist
    let mut gray = [] // collect()'s worklist

    // ---- globals and fibers ----
    let mut globals = map() // name -> Val
    let mut fb_stack = [] // [[Val]]; list length is the live stack top
    let mut fb_status = []
    let mut fb_sendval = [] // pending value while blocked on send
    let mut fb_selectch = [] // channels this fiber waits on in a select
    let mut fb_openuv = [] // open upvalue handles
    let mut fb_fr_cl = [] // call frames: closure handle
    let mut fb_fr_ip = [] // call frames: instruction pointer
    let mut fb_fr_base = [] // call frames: stack base
    let mut fb_fr_callip = [] // call frames: caller's call-site ip (traces)
    let mut fb_fr_defers = [] // call frames: registered defer closures (run LIFO)
    let mut fb_fr_dstash = [] // call frames: stashed exit value while defers run
    let mut fb_fr_dact = [] // call frames: a defer exit sequence is in progress
    let mut fb_wakeat = [] // absolute clock() deadline while fs_blocked_timer
    let mut fb_ioproc = [] // host exec handle awaited while fs_blocked_io
    let mut fb_iohas = [] // scheduler delivered an exec result
    let mut fb_iores = [] // the delivered guest Result value
    let mut fb_netop = [] // net_nb op while fs_blocked_net (-1 = not net)
    let mut fb_nethandle = [] // socket handle for the parked net operation
    let mut fb_netdata = [] // remaining write data while parked
    let mut fb_netmax = [] // read max while parked
    let mut fb_stdinmax = [] // read_stdin max while fs_blocked_stdin
    let mut ready = [] // FIFO of ready fiber ids
    let mut main_fiber = 0
    let mut park_recv = -1 // set by the recv() native to ask OpCall to park
    let mut park_sleep = -1.0 // wake deadline set by the sleep() native, or -1
    let mut park_io = -1 // host exec handle set by the exec() native
    let mut park_netop = -1 // net_nb op set by a net native on EAGAIN
    let mut park_nethandle = -1
    let mut park_netdata = ""
    let mut park_netmax = 0
    let mut park_stdinmax = -1 // read_stdin max on EAGAIN
    let mut ntimers = 0 // fibers currently parked on a timer
    let mut nio = 0 // fibers currently parked on child-process IO
    let mut nio_net = 0 // fibers currently parked on net IO
    let mut nio_stdin = 0 // fibers currently parked on stdin
    let mut wait_fiber = []
    let mut wait_kind = []
    let mut wait_deadline = []
    let mut wait_handle = []
    let mut yield_flag = false
    let mut opt_enum = -1
    let mut res_enum = -1
    let mut out_enum = -1
    let mut k_vals = [] // converted constant tables, parallel to f_consts

    let mut cur_f = -1 // fiber whose instruction is executing (traces)
    let mut cur_ip = 0 // start ip of that instruction (traces)

    // a trap always ends the program: report the message, then the frame
    // trace of the trapping fiber (same shape as the native runtime's)
    fn trap(msg) {
        eprintln("runtime error: " + msg)
        if cur_f >= 0 {
            let mut d = len(fb_fr_cl[cur_f]) - 1
            while d >= 0 {
                let fnh = o_i1[fb_fr_cl[cur_f][d]]
                let ip = if d == len(fb_fr_cl[cur_f]) - 1 {
                    cur_ip
                } else {
                    fb_fr_callip[cur_f][d + 1]
                }
                let name = if f_name[fnh] != "" {
                    f_name[fnh]
                } else {
                    "<fn>"
                }
                let mut li = -1
                let mut i = 0
                while i < len(ls_files) {
                    if ls_files[i] == f_file[fnh] {
                        li = i
                        i = len(ls_files)
                    } else {
                        i = i + 1
                    }
                }
                let file = if li >= 0 {
                    ls_names[li]
                } else {
                    f_file[fnh]
                }
                if file != "" {
                    // synthetic glue (module entry) has no source to point at
                    let ln = if li >= 0 && ip < len(f_spans[fnh]) {
                        match f_spans[fnh][ip] {
                            Sp(s0, _) => line_of(ls_tables[li], s0),
                        }
                    } else {
                        0
                    }
                    eprintln("  at " + name + " (" + file + ":" + str(ln) + ")")
                }
                d = d - 1
            }
        }
        exit(4)
    }

    fn rd_u16(code, ip) {
        code[ip] * 256 + code[ip + 1]
    }

    // ---- Val inspectors ----
    fn is_str(v) {
        match v {
            VStr(_) => true,
            _ => false,
        }
    }
    fn str_of(v) {
        match v {
            VStr(s) => s,
            _ => "",
        }
    }
    fn is_int(v) {
        match v {
            VInt(_) => true,
            _ => false,
        }
    }
    fn int_of(v) {
        match v {
            VInt(n) => n,
            _ => 0,
        }
    }
    fn is_bool(v) {
        match v {
            VBool(_) => true,
            _ => false,
        }
    }
    fn bool_of(v) {
        match v {
            VBool(b) => b,
            _ => false,
        }
    }
    fn is_num(v) {
        match v {
            VInt(_) => true,
            VFloat(_) => true,
            _ => false,
        }
    }
    fn num_f(v) {
        match v {
            VInt(n) => to_float(n),
            VFloat(x) => x,
            _ => 0.0,
        }
    }
    fn obj_h(v) {
        match v {
            VObj(h) => h,
            _ => -1,
        }
    }
    fn tagged_h(v, t) {
        match v {
            VObj(h) => if o_tag[h] == t {
                h
            } else {
                -1
            },
            _ => -1,
        }
    }

    fn type_name(v) {
        match v {
            VUnit => "unit",
            VBool(_) => "bool",
            VInt(_) => "int",
            VFloat(_) => "float",
            VStr(_) => "string",
            VObj(h) => {
                let t = o_tag[h]
                if t == ot_list {
                    "list"
                } else if t == ot_map {
                    "map"
                } else if t == ot_closure {
                    "function"
                } else if t == ot_upval {
                    "upvalue"
                } else if t == ot_enuminst {
                    en_qual[o_i1[h]]
                } else if t == ot_channel {
                    "channel"
                } else if t == ot_native {
                    "native function"
                } else if t == ot_enumtype {
                    "enum"
                } else if t == ot_record {
                    "record"
                } else {
                    "variant constructor"
                }
            },
        }
    }

    // format mirrors value.go format(): quote=false is display (print),
    // quote=true is repr (inside containers)
    fn format_val(v, quote) {
        match v {
            VUnit => "()",
            VBool(b) => str(b),
            VInt(n) => str(n),
            VFloat(x) => str(x),
            VStr(s) => if quote {
                go_quote(s)
            } else {
                s
            },
            VObj(h) => {
                let t = o_tag[h]
                if t == ot_list {
                    let mut parts = []
                    for e in o_vals[h] {
                        push(parts, format_val(e, true))
                    }
                    "[" + join(parts, ", ") + "]"
                } else if t == ot_map {
                    let mut parts = []
                    let mut i = 0
                    while i < len(o_keys[h]) {
                        push(parts, format_val(o_keys[h][i], true) + ": " + format_val(o_vals[h][i], true))
                        i = i + 1
                    }
                    "" + chr(123) + "" + join(parts, ", ") + "}"
                } else if t == ot_closure {
                    let name = f_name[o_i1[h]]
                    if name == "" {
                        "<fn anonymous>"
                    } else {
                        "<fn " + name + ">"
                    }
                } else if t == ot_native {
                    "<native " + native_names[o_i1[h]] + ">"
                } else if t == ot_enumtype {
                    "<enum " + en_qual[o_i1[h]] + ">"
                } else if t == ot_ctor {
                    "<variant " + en_qual[o_i1[h]] + "." + en_vnames[o_i1[h]][o_i2[h]] + ">"
                } else if t == ot_enuminst {
                    let name = en_vnames[o_i1[h]][o_i2[h]]
                    if len(o_vals[h]) == 0 {
                        name
                    } else {
                        let mut parts = []
                        for e in o_vals[h] {
                            push(parts, format_val(e, true))
                        }
                        name + "(" + join(parts, ", ") + ")"
                    }
                } else if t == ot_channel {
                    "<chan cap=" + str(o_i1[h]) + " len=" + str(len(o_vals[h])) + ">"
                } else if t == ot_record {
                    let mut parts = []
                    let mut i = 0
                    while i < len(o_keys[h]) {
                        let kname = match o_keys[h][i] {
                            VStr(s) => s,
                            _ => "?",
                        }
                        push(parts, kname + ": " + format_val(o_vals[h][i], true))
                        i = i + 1
                    }
                    "record " + chr(123) + " " + join(parts, ", ") + " " + chr(125)
                } else {
                    "?"
                }
            },
        }
    }

    // eq_val mirrors valuesEqual: deep for lists, maps and enum instances,
    // int/float cross-compare, reference (handle) equality otherwise
    fn eq_val(a, b) {
        match a {
            VUnit => match b {
                VUnit => true,
                _ => false,
            },
            VBool(x) => match b {
                VBool(y) => x == y,
                _ => false,
            },
            VInt(x) => match b {
                VInt(y) => x == y,
                VFloat(y) => to_float(x) == y,
                _ => false,
            },
            VFloat(x) => match b {
                VFloat(y) => x == y,
                VInt(y) => x == to_float(y),
                _ => false,
            },
            VStr(x) => match b {
                VStr(y) => x == y,
                _ => false,
            },
            VObj(x) => match b {
                VObj(y) => {
                    let tx = o_tag[x]
                    let ty = o_tag[y]
                    if tx == ot_list && ty == ot_list {
                        if len(o_vals[x]) != len(o_vals[y]) {
                            false
                        } else {
                            let mut same = true
                            let mut i = 0
                            while i < len(o_vals[x]) {
                                if !eq_val(o_vals[x][i], o_vals[y][i]) {
                                    same = false
                                    break
                                }
                                i = i + 1
                            }
                            same
                        }
                    } else if tx == ot_map && ty == ot_map {
                        if len(o_keys[x]) != len(o_keys[y]) {
                            false
                        } else {
                            // order-insensitive, like objEqual
                            let mut same = true
                            let mut i = 0
                            while i < len(o_keys[x]) {
                                let pos = match o_keys[x][i] {
                                    VInt(n) => match get(o_idxi[y], n) {
                                        Some(p) => p,
                                        None => -1,
                                    },
                                    VStr(s) => match get(o_idxs[y], s) {
                                        Some(p) => p,
                                        None => -1,
                                    },
                                    _ => -1,
                                }
                                if pos < 0 {
                                    same = false
                                    break
                                }
                                if !eq_val(o_vals[x][i], o_vals[y][pos]) {
                                    same = false
                                    break
                                }
                                i = i + 1
                            }
                            same
                        }
                    } else if tx == ot_enuminst && ty == ot_enuminst {
                        if o_i1[x] != o_i1[y] || o_i2[x] != o_i2[y] {
                            false
                        } else {
                            let mut same = true
                            let mut i = 0
                            while i < len(o_vals[x]) {
                                if !eq_val(o_vals[x][i], o_vals[y][i]) {
                                    same = false
                                    break
                                }
                                i = i + 1
                            }
                            same
                        }
                    } else if tx == ot_record && ty == ot_record {
                        if len(o_keys[x]) != len(o_keys[y]) {
                            false
                        } else {
                            let mut same = true
                            let mut i = 0
                            while i < len(o_keys[x]) {
                                if o_keys[x][i] != o_keys[y][i] || !eq_val(o_vals[x][i], o_vals[y][i]) {
                                    same = false
                                    i = len(o_keys[x])
                                }
                                i = i + 1
                            }
                            same
                        }
                    } else {
                        x == y
                    }
                },
                _ => false,
            },
        }
    }

    // ---- mark-sweep collector (gc.go) ----
    fn mark_val(v) {
        match v {
            VObj(h) => {
                if !o_mark[h] {
                    o_mark[h] = true
                    push(gray, h)
                }
            },
            _ => {},
        }
    }
    fn mark_obj(h) {
        if !o_mark[h] {
            o_mark[h] = true
            push(gray, h)
        }
    }

    fn collect() {
        gc_cycles_n = gc_cycles_n + 1
        gray = []

        // roots: permanent objects, globals, every fiber's stack, frame
        // closures, open upvalues and pending send value
        for h in pinned {
            mark_obj(h)
        }
        for k in keys(globals) {
            match get(globals, k) {
                Some(v) => mark_val(v),
                None => {},
            }
        }
        let mut fi = 0
        while fi < len(fb_stack) {
            for v in fb_stack[fi] {
                mark_val(v)
            }
            for ch in fb_fr_cl[fi] {
                mark_obj(ch)
            }
            for dl in fb_fr_defers[fi] {
                for dh in dl {
                    mark_obj(dh)
                }
            }
            for dv in fb_fr_dstash[fi] {
                mark_val(dv)
            }
            for uh in fb_openuv[fi] {
                mark_obj(uh)
            }
            mark_val(fb_sendval[fi])
            fi = fi + 1
        }
        for pr in fb_iores {
            mark_val(pr)
        }

        // trace: enum types, ctors and natives carry no interpreted
        // references (variant metadata lives in the compiler's enum arena)
        while len(gray) > 0 {
            let h = pop(gray)
            let t = o_tag[h]
            if t == ot_list || t == ot_enuminst || t == ot_channel {
                for e in o_vals[h] {
                    mark_val(e)
                }
            } else if t == ot_record {
                for e in o_vals[h] {
                    mark_val(e)
                }
                for e in o_keys[h] {
                    mark_val(e)
                }
            } else if t == ot_map {
                for e in o_keys[h] {
                    mark_val(e)
                }
                for e in o_vals[h] {
                    mark_val(e)
                }
            } else if t == ot_closure {
                for uh in o_h1[h] {
                    mark_obj(uh)
                }
            } else if t == ot_upval {
                if !o_b1[h] {
                    mark_val(o_v1[h])
                }
            }
        }

        // sweep: drop payloads so the host GC reclaims them, reuse the slot
        let mut freed = 0
        let mut h = 0
        while h < len(o_tag) {
            if o_tag[h] != ot_free {
                if o_mark[h] {
                    o_mark[h] = false
                } else {
                    o_tag[h] = ot_free
                    o_vals[h] = []
                    o_keys[h] = []
                    o_idxi[h] = map()
                    o_idxs[h] = map()
                    o_i1[h] = 0
                    o_i2[h] = 0
                    o_b1[h] = false
                    o_v1[h] = VUnit
                    o_h1[h] = []
                    o_h2[h] = []
                    o_h3[h] = []
                    push(free_slots, h)
                    freed = freed + 1
                }
            }
            h = h + 1
        }
        obj_count = obj_count - freed
        freed
    }

    // alloc registers a slot, collecting first when the live count crosses
    // the threshold (gc.go alloc); freed slots come back payload-clean
    fn alloc_obj(tag) {
        if vm_on && obj_count + 1 > gc_threshold {
            let _ = collect()
            gc_threshold = obj_count * 2 + 64
        }
        obj_count = obj_count + 1
        gc_total_alloc = gc_total_alloc + 1
        if len(free_slots) > 0 {
            let h = pop(free_slots)
            o_tag[h] = tag
            h
        } else {
            push(o_tag, tag)
            push(o_mark, false)
            push(o_vals, [])
            push(o_keys, [])
            push(o_idxi, map())
            push(o_idxs, map())
            push(o_i1, 0)
            push(o_i2, 0)
            push(o_b1, false)
            push(o_v1, VUnit)
            push(o_h1, [])
            push(o_h2, [])
            push(o_h3, [])
            len(o_tag) - 1
        }
    }

    // ---- fiber stack ----
    fn fpush(f, v) {
        push(fb_stack[f], v)
    }
    fn fpop(f) {
        pop(fb_stack[f])
    }
    fn fpeek(f, n) {
        fb_stack[f][len(fb_stack[f]) - 1 - n]
    }
    fn ftop(f) {
        len(fb_stack[f])
    }
    fn fsettop(f, n) {
        while len(fb_stack[f]) > n {
            let _ = pop(fb_stack[f])
        }
    }

    fn make_inst(eh, variant, fields) {
        let h = alloc_obj(ot_enuminst)
        o_i1[h] = eh
        o_i2[h] = variant
        o_vals[h] = fields
        VObj(h)
    }
    // Option/Result constructors root their payload on the current fiber's
    // stack across the allocation, mirroring builtins.go
    fn make_some(f, v) {
        fpush(f, v)
        let r = make_inst(opt_enum, 0, [fpeek(f, 0)])
        let _ = fpop(f)
        r
    }
    fn make_none() {
        make_inst(opt_enum, 1, [])
    }
    fn make_ok(f, v) {
        fpush(f, v)
        let r = make_inst(res_enum, 0, [fpeek(f, 0)])
        let _ = fpop(f)
        r
    }
    fn make_err(f, v) {
        fpush(f, v)
        let r = make_inst(res_enum, 1, [fpeek(f, 0)])
        let _ = fpop(f)
        r
    }

    fn schedule(f) {
        fb_status[f] = fs_ready
        push(ready, f)
    }

    // convert a host exec Result<Output, str> into a guest value, rooting
    // fresh objects on fiber f's stack
    fn conv_exec_result(f, r) {
        match r {
            Ok(o) => match o {
                Output(code, so, se) => {
                    let oi = make_inst(out_enum, 0, [VInt(code), VStr(so), VStr(se)])
                    make_ok(f, oi)
                },
            },
            Err(m) => make_err(f, VStr(m)),
        }
    }

    fn wait_reset() {
        wait_fiber = []
        wait_kind = []
        wait_deadline = []
        wait_handle = []
    }

    fn wait_add_timer(f, deadline) {
        push(wait_fiber, f)
        push(wait_kind, wait_timer)
        push(wait_deadline, deadline)
        push(wait_handle, -1)
    }

    fn wait_add_exec(f, h) {
        push(wait_fiber, f)
        push(wait_kind, wait_exec)
        push(wait_deadline, -1.0)
        push(wait_handle, h)
    }

    // Register every blocked timer and IO source through one wait list.
    fn wait_register_all() {
        wait_reset()
        let mut i = 0
        while i < len(fb_status) {
            if fb_status[i] == fs_blocked_timer {
                wait_add_timer(i, fb_wakeat[i])
            } else if fb_status[i] == fs_blocked_io {
                wait_add_exec(i, fb_ioproc[i])
            } else if fb_status[i] == fs_blocked_net {
                push(wait_fiber, i)
                push(wait_kind, wait_net)
                push(wait_deadline, -1.0)
                push(wait_handle, -1)
            }
            i = i + 1
        }
    }

    // Poll registered IO sources and wake their fibers in fiber id order.
    fn wait_poll_io() {
        let mut i = 0
        while i < len(wait_fiber) {
            if wait_kind[i] == wait_exec {
                let f = wait_fiber[i]
                match exec_poll(wait_handle[i]) {
                    Some(r) => {
                        fb_iores[f] = conv_exec_result(f, r)
                        fb_iohas[f] = true
                        fb_ioproc[f] = -1
                        nio = nio - 1
                        schedule(f)
                    },
                    None => {},
                }
            }
            i = i + 1
        }
    }

    // Retry non-blocking net operations for net-blocked fibers.
    fn wait_poll_net() {
        let mut i = 0
        while i < len(fb_status) {
            if fb_status[i] != fs_blocked_net {
                i = i + 1
                continue
            }
            let f = i
            let op = fb_netop[f]
            let h = fb_nethandle[f]
            match net_nb(op, h, fb_netdata[f], fb_netmax[f]) {
                Ok(s) => {
                    if op == 2 {
                        let n = match parse_int(s) {
                            Some(x) => x,
                            None => 0,
                        }
                        let rem = str_len(fb_netdata[f]) - n
                        if rem > 0 {
                            fb_netdata[f] = substr(fb_netdata[f], n, rem)
                        } else {
                            fb_iores[f] = make_ok(f, VUnit)
                            fb_iohas[f] = true
                            fb_netop[f] = -1
                            nio_net = nio_net - 1
                            schedule(f)
                        }
                    } else if op == 0 {
                        let ch = match parse_int(s) {
                            Some(x) => x,
                            None => {
                                trap("net_nb accept returned bad handle")
                                0
                            },
                        }
                        fb_iores[f] = make_ok(f, VInt(ch))
                        fb_iohas[f] = true
                        fb_netop[f] = -1
                        nio_net = nio_net - 1
                        schedule(f)
                    } else {
                        fb_iores[f] = make_ok(f, VStr(s))
                        fb_iohas[f] = true
                        fb_netop[f] = -1
                        nio_net = nio_net - 1
                        schedule(f)
                    }
                },
                Err(m) => {
                    if m == "__eagain" {
                        // still not ready
                    } else {
                        fb_iores[f] = make_err(f, VStr(m))
                        fb_iohas[f] = true
                        fb_netop[f] = -1
                        nio_net = nio_net - 1
                        schedule(f)
                    }
                },
            }
            i = i + 1
        }
    }

    // Retry non-blocking stdin reads for stdin-blocked fibers.
    fn wait_poll_stdin() {
        let mut i = 0
        while i < len(fb_status) {
            if fb_status[i] != fs_blocked_stdin {
                i = i + 1
                continue
            }
            let f = i
            match stdin_nb(fb_stdinmax[f]) {
                Ok(s) => {
                    fb_iores[f] = VStr(s)
                    fb_iohas[f] = true
                    nio_stdin = nio_stdin - 1
                    schedule(f)
                },
                Err(m) => {
                    if m == "__eagain" {
                        // still not ready
                    } else {
                        trap("read_stdin: " + m)
                    }
                },
            }
            i = i + 1
        }
    }

    fn wait_nearest_timer() {
        let mut nearest = -1.0
        let mut i = 0
        while i < len(wait_fiber) {
            if wait_kind[i] == wait_timer {
                if nearest < 0.0 || wait_deadline[i] < nearest {
                    nearest = wait_deadline[i]
                }
            }
            i = i + 1
        }
        nearest
    }

    // wake every timer whose deadline has passed, in (deadline, fiber id)
    // order; fiber ids ascend during the scan, so strictly-less picks suffice
    fn wake_due_timers() {
        let now = clock()
        let mut going = true
        while going {
            going = false
            let mut best = -1
            let mut i = 0
            while i < len(fb_status) {
                if fb_status[i] == fs_blocked_timer && fb_wakeat[i] <= now {
                    if best < 0 || fb_wakeat[i] < fb_wakeat[best] {
                        best = i
                    }
                }
                i = i + 1
            }
            if best >= 0 {
                ntimers = ntimers - 1
                schedule(best)
                going = true
            }
        }
    }

    // Block the host only while the guest has no runnable fibers.
    fn wait_idle() {
        while len(ready) == 0 {
            wait_register_all()
            if nio > 0 || nio_net > 0 || nio_stdin > 0 {
                sleep(1)
            } else {
                let nearest = wait_nearest_timer()
                let waitms = trunc((nearest - clock()) * 1000.0) + 1
                if waitms > 0 {
                    sleep(waitms)
                }
            }
            wait_poll_io()
            if nio_net > 0 {
                wait_poll_net()
            }
            if nio_stdin > 0 {
                wait_poll_stdin()
            }
            if ntimers > 0 {
                wake_due_timers()
            }
        }
    }

    fn new_fiber(cl, args) {
        push(fb_stack, [VObj(cl)])
        push(fb_status, fs_ready)
        push(fb_sendval, VUnit)
        push(fb_selectch, [])
        push(fb_openuv, [])
        push(fb_fr_cl, [cl])
        push(fb_fr_ip, [0])
        push(fb_fr_base, [0])
        push(fb_fr_callip, [0])
        push(fb_fr_defers, [[]])
        push(fb_fr_dstash, [VUnit])
        push(fb_fr_dact, [false])
        push(fb_wakeat, -1.0)
        push(fb_ioproc, -1)
        push(fb_iohas, false)
        push(fb_iores, VUnit)
        push(fb_netop, -1)
        push(fb_nethandle, -1)
        push(fb_netdata, "")
        push(fb_netmax, 0)
        push(fb_stdinmax, 0)
        let f = len(fb_stack) - 1
        for a in args {
            push(fb_stack[f], a)
        }
        f
    }

    // ---- channels (vm.go) ----
    // wake every fiber parked in a select on ch; one woken elsewhere first
    // is skipped
    fn wake_waiters(ch) {
        if len(o_h3[ch]) > 0 {
            for w in o_h3[ch] {
                if fb_status[w] == fs_blocked_select {
                    schedule(w)
                }
            }
            o_h3[ch] = []
        }
    }
    fn remove_waiter(ch, f) {
        let mut kept = []
        for w in o_h3[ch] {
            if w != f {
                push(kept, w)
            }
        }
        o_h3[ch] = kept
    }
    fn chan_recv_ready(ch) {
        len(o_vals[ch]) > 0 || len(o_h1[ch]) > 0 || o_b1[ch]
    }
    fn chan_send_ready(ch) {
        o_b1[ch] || len(o_h2[ch]) > 0 || len(o_vals[ch]) < o_i1[ch]
    }
    // non-blocking receive, waking one blocked sender to refill the slot it
    // drains; RecvNone when nothing is available yet
    fn chan_try_recv(ch) {
        if len(o_vals[ch]) > 0 {
            let v = o_vals[ch][0]
            o_vals[ch] = slice(o_vals[ch], 1, len(o_vals[ch]))
            if len(o_h1[ch]) > 0 {
                let s = o_h1[ch][0]
                o_h1[ch] = slice(o_h1[ch], 1, len(o_h1[ch]))
                push(o_vals[ch], fb_sendval[s])
                fb_sendval[s] = VUnit
                schedule(s)
            }
            RecvGot(v)
        } else if len(o_h1[ch]) > 0 {
            // unbuffered rendezvous
            let s = o_h1[ch][0]
            o_h1[ch] = slice(o_h1[ch], 1, len(o_h1[ch]))
            let v = fb_sendval[s]
            fb_sendval[s] = VUnit
            schedule(s)
            RecvGot(v)
        } else {
            RecvNone
        }
    }

    // ---- upvalues ----
    fn uv_get(h) {
        if o_b1[h] {
            fb_stack[o_i1[h]][o_i2[h]]
        } else {
            o_v1[h]
        }
    }
    fn uv_set(h, v) {
        if o_b1[h] {
            fb_stack[o_i1[h]][o_i2[h]] = v
        } else {
            o_v1[h] = v
        }
    }
    fn capture_upvalue(f, slot) {
        let mut found = -1
        for uh in fb_openuv[f] {
            if o_i2[uh] == slot {
                found = uh
            }
        }
        if found >= 0 {
            found
        } else {
            let h = alloc_obj(ot_upval)
            o_i1[h] = f
            o_i2[h] = slot
            o_b1[h] = true
            o_v1[h] = VUnit
            push(fb_openuv[f], h)
            h
        }
    }
    fn close_upvalues(f, from) {
        let mut kept = []
        for uh in fb_openuv[f] {
            if o_i2[uh] >= from {
                o_v1[uh] = fb_stack[f][o_i2[uh]]
                o_b1[uh] = false
            } else {
                push(kept, uh)
            }
        }
        fb_openuv[f] = kept
    }

    // map entry position for key k: >=0 found, -1 absent, -2 bad key type
    fn map_find(mh, k) {
        match k {
            VInt(n) => match get(o_idxi[mh], n) {
                Some(p) => p,
                None => -1,
            },
            VStr(s) => match get(o_idxs[mh], s) {
                Some(p) => p,
                None => -1,
            },
            _ => -2,
        }
    }
    fn map_index_put(mh, k, pos) {
        match k {
            VInt(n) => put(o_idxi[mh], n, pos),
            VStr(s) => put(o_idxs[mh], s, pos),
            _ => {},
        }
    }

    // ---- natives (builtins.go); argc already checked by the typechecker,
    // arg i sits at fpeek(f, argc-1-i) and stays rooted until the caller
    // pops. Allocating natives root fresh handles before any further
    // allocation, mirroring the Go implementations.
    fn do_native(f, id, argc) {
        let nm = native_names[id]
        if nm == "print" || nm == "println" || nm == "eprintln" {
            let mut parts = []
            let mut i = 0
            while i < argc {
                push(parts, format_val(fpeek(f, argc - 1 - i), false))
                i = i + 1
            }
            let s = join(parts, " ")
            if nm == "print" {
                print(s)
            } else if nm == "println" {
                println(s)
            } else {
                eprintln(s)
            }
            VUnit
        } else if nm == "len" {
            let v = fpeek(f, 0)
            let lh = tagged_h(v, ot_list)
            if lh >= 0 {
                VInt(len(o_vals[lh]))
            } else if is_str(v) {
                VInt(str_len(str_of(v)))
            } else {
                trap("len() needs a list, string, or map, got " + type_name(v))
                VUnit
            }
        } else if nm == "map" {
            VObj(alloc_obj(ot_map))
        } else if nm == "get" {
            let mh = tagged_h(fpeek(f, 1), ot_map)
            if mh < 0 {
                trap("get() needs a map, got " + type_name(fpeek(f, 1)))
            }
            let pos = map_find(mh, fpeek(f, 0))
            if pos == -2 {
                trap("map keys must be int or str, got " + type_name(fpeek(f, 0)))
            }
            if pos >= 0 {
                make_some(f, o_vals[mh][pos])
            } else {
                make_none()
            }
        } else if nm == "put" {
            let mh = tagged_h(fpeek(f, 2), ot_map)
            if mh < 0 {
                trap("put() needs a map, got " + type_name(fpeek(f, 2)))
            }
            let k = fpeek(f, 1)
            let v = fpeek(f, 0)
            let pos = map_find(mh, k)
            if pos == -2 {
                trap("map keys must be int or str, got " + type_name(k))
            }
            if pos >= 0 {
                o_vals[mh][pos] = v
            } else {
                let p = len(o_keys[mh])
                push(o_keys[mh], k)
                push(o_vals[mh], v)
                map_index_put(mh, k, p)
            }
            VUnit
        } else if nm == "delete" {
            let mh = tagged_h(fpeek(f, 1), ot_map)
            if mh < 0 {
                trap("delete() needs a map, got " + type_name(fpeek(f, 1)))
            }
            let k = fpeek(f, 0)
            let pos = map_find(mh, k)
            if pos == -2 {
                trap("map keys must be int or str, got " + type_name(k))
            }
            if pos >= 0 {
                o_keys[mh] = concat(slice(o_keys[mh], 0, pos), slice(o_keys[mh], pos + 1, len(o_keys[mh])))
                o_vals[mh] = concat(slice(o_vals[mh], 0, pos), slice(o_vals[mh], pos + 1, len(o_vals[mh])))
                match k {
                    VInt(n) => delete(o_idxi[mh], n),
                    VStr(s) => delete(o_idxs[mh], s),
                    _ => {},
                }
                let mut i = pos
                while i < len(o_keys[mh]) {
                    map_index_put(mh, o_keys[mh][i], i)
                    i = i + 1
                }
            }
            VUnit
        } else if nm == "keys" {
            let mh = tagged_h(fpeek(f, 0), ot_map)
            if mh < 0 {
                trap("keys() needs a map, got " + type_name(fpeek(f, 0)))
            }
            // keys are int|str only, never arena handles: plain fill is safe
            let lh = alloc_obj(ot_list)
            o_vals[lh] = slice(o_keys[mh], 0, len(o_keys[mh]))
            VObj(lh)
        } else if nm == "push" {
            let lh = tagged_h(fpeek(f, 1), ot_list)
            if lh < 0 {
                trap("push() needs a list, got " + type_name(fpeek(f, 1)))
            }
            push(o_vals[lh], fpeek(f, 0))
            VUnit
        } else if nm == "pop" {
            let lh = tagged_h(fpeek(f, 0), ot_list)
            if lh < 0 {
                trap("pop() needs a list, got " + type_name(fpeek(f, 0)))
            }
            if len(o_vals[lh]) == 0 {
                trap("pop() on empty list")
            }
            pop(o_vals[lh])
        } else if nm == "str" {
            VStr(format_val(fpeek(f, 0), false))
        } else if nm == "trunc" {
            match fpeek(f, 0) {
                VFloat(x) => VInt(trunc(x)),
                _ => {
                    trap("trunc() needs a float, got " + type_name(fpeek(f, 0)))
                    VUnit
                },
            }
        } else if nm == "to_float" {
            match fpeek(f, 0) {
                VInt(n) => VFloat(to_float(n)),
                _ => {
                    trap("to_float() needs an int, got " + type_name(fpeek(f, 0)))
                    VUnit
                },
            }
        } else if nm == "float_bits" {
            match fpeek(f, 0) {
                VFloat(x) => VInt(float_bits(x)),
                _ => {
                    trap("float_bits() needs a float, got " + type_name(fpeek(f, 0)))
                    VUnit
                },
            }
        } else if nm == "parse_int" {
            if !is_str(fpeek(f, 0)) {
                trap("parse_int() needs a str, got " + type_name(fpeek(f, 0)))
            }
            match parse_int(str_of(fpeek(f, 0))) {
                Some(n) => make_some(f, VInt(n)),
                None => make_none(),
            }
        } else if nm == "parse_float" {
            if !is_str(fpeek(f, 0)) {
                trap("parse_float() needs a str, got " + type_name(fpeek(f, 0)))
            }
            match parse_float(str_of(fpeek(f, 0))) {
                Some(x) => make_some(f, VFloat(x)),
                None => make_none(),
            }
        } else if nm == "str_len" {
            if !is_str(fpeek(f, 0)) {
                trap("str_len() needs a str, got " + type_name(fpeek(f, 0)))
            }
            VInt(str_len(str_of(fpeek(f, 0))))
        } else if nm == "char_at" {
            if !is_str(fpeek(f, 1)) || !is_int(fpeek(f, 0)) {
                trap("char_at() needs (str, int)")
            }
            let s = str_of(fpeek(f, 1))
            let i = int_of(fpeek(f, 0))
            if i < 0 || i >= str_len(s) {
                trap("char_at index " + str(i) + " out of bounds (len " + str(str_len(s)) + ")")
            }
            VStr(char_at(s, i))
        } else if nm == "range" {
            if !is_int(fpeek(f, 1)) || !is_int(fpeek(f, 0)) {
                trap("range() needs two ints")
            }
            let a = int_of(fpeek(f, 1))
            let b = int_of(fpeek(f, 0))
            let lh = alloc_obj(ot_list)
            let mut i = a
            while i < b {
                push(o_vals[lh], VInt(i))
                i = i + 1
            }
            VObj(lh)
        } else if nm == "split" {
            if !is_str(fpeek(f, 1)) || !is_str(fpeek(f, 0)) {
                trap("split() needs (str, str)")
            }
            let parts = split(str_of(fpeek(f, 1)), str_of(fpeek(f, 0)))
            let lh = alloc_obj(ot_list)
            for p in parts {
                push(o_vals[lh], VStr(p))
            }
            VObj(lh)
        } else if nm == "join" {
            let lh = tagged_h(fpeek(f, 1), ot_list)
            if lh < 0 || !is_str(fpeek(f, 0)) {
                trap("join() needs ([str], str)")
            }
            let mut parts = []
            for e in o_vals[lh] {
                if !is_str(e) {
                    trap("join() needs a list of str, got " + type_name(e) + " element")
                }
                push(parts, str_of(e))
            }
            VStr(join(parts, str_of(fpeek(f, 0))))
        } else if nm == "substr" {
            if !is_str(fpeek(f, 2)) || !is_int(fpeek(f, 1)) || !is_int(fpeek(f, 0)) {
                trap("substr() needs (str, int, int)")
            }
            let s = str_of(fpeek(f, 2))
            let start = int_of(fpeek(f, 1))
            let n = int_of(fpeek(f, 0))
            if start < 0 || n < 0 || start + n > str_len(s) {
                trap("substr(" + str(start) + ", " + str(n) + ") out of bounds (len " + str(str_len(s)) + ")")
            }
            VStr(substr(s, start, n))
        } else if nm == "byte_at" {
            if !is_str(fpeek(f, 1)) || !is_int(fpeek(f, 0)) {
                trap("byte_at() needs (str, int)")
            }
            let s = str_of(fpeek(f, 1))
            let i = int_of(fpeek(f, 0))
            if i < 0 || i >= str_len(s) {
                trap("byte_at index " + str(i) + " out of bounds (len " + str(str_len(s)) + ")")
            }
            VInt(byte_at(s, i))
        } else if nm == "str_contains" {
            if !is_str(fpeek(f, 1)) || !is_str(fpeek(f, 0)) {
                trap("str_contains() needs (str, str)")
            }
            VBool(str_contains(str_of(fpeek(f, 1)), str_of(fpeek(f, 0))))
        } else if nm == "str_index_of" {
            if !is_str(fpeek(f, 1)) || !is_str(fpeek(f, 0)) {
                trap("str_index_of() needs (str, str)")
            }
            match str_index_of(str_of(fpeek(f, 1)), str_of(fpeek(f, 0))) {
                Some(i) => make_some(f, VInt(i)),
                None => make_none(),
            }
        } else if nm == "trim" {
            if !is_str(fpeek(f, 0)) {
                trap("trim() needs a str, got " + type_name(fpeek(f, 0)))
            }
            VStr(trim(str_of(fpeek(f, 0))))
        } else if nm == "slice" {
            let src = tagged_h(fpeek(f, 2), ot_list)
            if src < 0 || !is_int(fpeek(f, 1)) || !is_int(fpeek(f, 0)) {
                trap("slice() needs ([a], int, int)")
            }
            let start = int_of(fpeek(f, 1))
            let end = int_of(fpeek(f, 0))
            if start < 0 || end < start || end > len(o_vals[src]) {
                trap("slice(" + str(start) + ", " + str(end) + ") out of bounds (len " + str(len(o_vals[src])) + ")")
            }
            // the source stays rooted on the stack across the allocation
            let lh = alloc_obj(ot_list)
            o_vals[lh] = slice(o_vals[src], start, end)
            VObj(lh)
        } else if nm == "concat" {
            let xs = tagged_h(fpeek(f, 1), ot_list)
            let ys = tagged_h(fpeek(f, 0), ot_list)
            if xs < 0 || ys < 0 {
                trap("concat() needs ([a], [a])")
            }
            let lh = alloc_obj(ot_list)
            o_vals[lh] = concat(o_vals[xs], o_vals[ys])
            VObj(lh)
        } else if nm == "contains" {
            let lh = tagged_h(fpeek(f, 1), ot_list)
            if lh < 0 {
                trap("contains() needs a list, got " + type_name(fpeek(f, 1)))
            }
            let mut found = false
            for e in o_vals[lh] {
                if eq_val(e, fpeek(f, 0)) {
                    found = true
                    break
                }
            }
            VBool(found)
        } else if nm == "read_file" {
            if !is_str(fpeek(f, 0)) {
                trap("read_file() needs a str, got " + type_name(fpeek(f, 0)))
            }
            match read_file(str_of(fpeek(f, 0))) {
                Ok(s) => make_ok(f, VStr(s)),
                Err(m) => make_err(f, VStr(m)),
            }
        } else if nm == "write_file" {
            if !is_str(fpeek(f, 1)) || !is_str(fpeek(f, 0)) {
                trap("write_file() needs (str, str)")
            }
            match write_file(str_of(fpeek(f, 1)), str_of(fpeek(f, 0))) {
                Ok(_) => make_ok(f, VUnit),
                Err(m) => make_err(f, VStr(m)),
            }
        } else if nm == "file_exists" {
            if !is_str(fpeek(f, 0)) {
                trap("file_exists() needs a str, got " + type_name(fpeek(f, 0)))
            }
            VBool(file_exists(str_of(fpeek(f, 0))))
        } else if nm == "read_dir" {
            if !is_str(fpeek(f, 0)) {
                trap("read_dir() needs a str, got " + type_name(fpeek(f, 0)))
            }
            match read_dir(str_of(fpeek(f, 0))) {
                Ok(names) => {
                    let lh = alloc_obj(ot_list)
                    for n in names {
                        push(o_vals[lh], VStr(n))
                    }
                    make_ok(f, VObj(lh)) // make_ok roots the fresh list
                },
                Err(m) => make_err(f, VStr(m)),
            }
        } else if nm == "exec" {
            if fb_iohas[f] {
                // resuming: the scheduler already delivered
                fb_iohas[f] = false
                let r = fb_iores[f]
                fb_iores[f] = VUnit
                r
            } else {
                let ah = tagged_h(fpeek(f, 0), ot_list)
                if !is_str(fpeek(f, 1)) || ah < 0 {
                    trap("exec() needs (str, [str])")
                }
                let mut hargs = []
                for e in o_vals[ah] {
                    if !is_str(e) {
                        trap("exec() args must be str, got " + type_name(e))
                    }
                    push(hargs, str_of(e))
                }
                match exec_start(str_of(fpeek(f, 1)), hargs) {
                    Ok(h) => match exec_poll(h) {
                        Some(r) => conv_exec_result(f, r),
                        None => {
                            park_io = h // OpCall parks this fiber and retries
                            VUnit
                        },
                    },
                    Err(m) => make_err(f, VStr(m)),
                }
            }
        } else if nm == "exec_start" {
            let ah = tagged_h(fpeek(f, 0), ot_list)
            if !is_str(fpeek(f, 1)) || ah < 0 {
                trap("exec_start() needs (str, [str])")
            }
            let mut hargs = []
            for e in o_vals[ah] {
                if !is_str(e) {
                    trap("exec_start() args must be str, got " + type_name(e))
                }
                push(hargs, str_of(e))
            }
            match exec_start(str_of(fpeek(f, 1)), hargs) {
                Ok(h) => make_ok(f, VInt(h)),
                Err(m) => make_err(f, VStr(m)),
            }
        } else if nm == "exec_poll" {
            match exec_poll(int_of(fpeek(f, 0))) {
                Some(r) => make_some(f, conv_exec_result(f, r)),
                None => make_none(),
            }
        } else if nm == "args" {
            let lh = alloc_obj(ot_list)
            for a in vm_args {
                push(o_vals[lh], VStr(a))
            }
            VObj(lh)
        } else if nm == "exit" {
            match fpeek(f, 0) {
                VInt(n) => exit(n),
                _ => {
                    trap("exit() needs an int, got " + type_name(fpeek(f, 0)))
                    VUnit
                },
            }
        } else if nm == "chan" {
            if argc > 1 {
                trap("chan() takes at most one argument")
            }
            let mut capacity = 0
            if argc == 1 {
                if !is_int(fpeek(f, 0)) || int_of(fpeek(f, 0)) < 0 {
                    trap("chan() capacity must be a non-negative int")
                }
                capacity = int_of(fpeek(f, 0))
            }
            let h = alloc_obj(ot_channel)
            o_i1[h] = capacity
            VObj(h)
        } else if nm == "close" {
            let ch = tagged_h(fpeek(f, 0), ot_channel)
            if ch < 0 {
                trap("close() needs a channel, got " + type_name(fpeek(f, 0)))
            }
            if o_b1[ch] {
                trap("close of closed channel")
            }
            o_b1[ch] = true
            // wake every blocked receiver: each re-runs its receive, drains
            // any buffered values, then observes closure
            for r in o_h2[ch] {
                schedule(r)
            }
            o_h2[ch] = []
            wake_waiters(ch)
            VUnit
        } else if nm == "recv" {
            let ch = tagged_h(fpeek(f, 0), ot_channel)
            if ch < 0 {
                trap("recv() needs a channel, got " + type_name(fpeek(f, 0)))
            }
            match chan_try_recv(ch) {
                RecvGot(v) => {
                    let opt = make_some(f, v) // roots v across the Some allocation
                    wake_waiters(ch)
                    opt
                },
                RecvNone => {
                    if o_b1[ch] {
                        make_none()
                    } else {
                        park_recv = ch // OpCall parks this fiber and retries once woken
                        VUnit
                    }
                },
            }
        } else if nm == "chr" {
            if !is_int(fpeek(f, 0)) || int_of(fpeek(f, 0)) < 0 || int_of(fpeek(f, 0)) > 1114111 {
                trap("chr() needs an int code point")
            }
            VStr(chr(int_of(fpeek(f, 0))))
        } else if nm == "byte_chr" {
            if !is_int(fpeek(f, 0)) || int_of(fpeek(f, 0)) < 0 || int_of(fpeek(f, 0)) > 255 {
                trap("byte_chr() needs an int in 0..255")
            }
            VStr(byte_chr(int_of(fpeek(f, 0))))
        } else if nm == "ord" {
            if !is_str(fpeek(f, 0)) || str_len(str_of(fpeek(f, 0))) == 0 {
                trap("ord() needs a non-empty string")
            }
            VInt(ord(str_of(fpeek(f, 0))))
        } else if nm == "clock" {
            VFloat(clock())
        } else if nm == "type_of" {
            VStr(type_name(fpeek(f, 0)))
        } else if nm == "assert" {
            if !is_bool(fpeek(f, 1)) {
                trap("assert() needs a bool, got " + type_name(fpeek(f, 1)))
            }
            if !bool_of(fpeek(f, 1)) {
                trap("assertion failed: " + format_val(fpeek(f, 0), false))
            }
            VUnit
        } else if nm == "gc" {
            VInt(collect())
        } else if nm == "heap_objects" {
            VInt(obj_count)
        } else if nm == "gc_cycles" {
            VInt(gc_cycles_n)
        } else if nm == "yield" {
            yield_flag = true
            VUnit
        } else if nm == "sleep" {
            if int_of(fpeek(f, 0)) > 0 {
                park_sleep = clock() + to_float(int_of(fpeek(f, 0))) / 1000.0
            } else {
                yield_flag = true // sleep(0) is a plain yield
            }
            VUnit
        } else if nm == "tcp_listen" {
            if !is_str(fpeek(f, 1)) || !is_int(fpeek(f, 0)) {
                trap("tcp_listen() needs (str, int)")
            }
            match tcp_listen(str_of(fpeek(f, 1)), int_of(fpeek(f, 0))) {
                Ok(h) => make_ok(f, VInt(h)),
                Err(m) => make_err(f, VStr(m)),
            }
        } else if nm == "tcp_accept" {
            if fb_iohas[f] {
                fb_iohas[f] = false
                let r = fb_iores[f]
                fb_iores[f] = VUnit
                r
            } else {
                if !is_int(fpeek(f, 0)) {
                    trap("tcp_accept() needs an int")
                }
                let lh = int_of(fpeek(f, 0))
                match net_nb(0, lh, "", 0) {
                    Ok(s) => {
                        let ch = match parse_int(s) {
                            Some(x) => x,
                            None => {
                                trap("tcp_accept: bad handle from net_nb")
                                0
                            },
                        }
                        make_ok(f, VInt(ch))
                    },
                    Err(m) => {
                        if m == "__eagain" {
                            park_netop = 0
                            park_nethandle = lh
                            park_netdata = ""
                            park_netmax = 0
                            VUnit
                        } else {
                            make_err(f, VStr(m))
                        }
                    },
                }
            }
        } else if nm == "tcp_dial" {
            if !is_str(fpeek(f, 1)) || !is_int(fpeek(f, 0)) {
                trap("tcp_dial() needs (str, int)")
            }
            match tcp_dial(str_of(fpeek(f, 1)), int_of(fpeek(f, 0))) {
                Ok(h) => make_ok(f, VInt(h)),
                Err(m) => make_err(f, VStr(m)),
            }
        } else if nm == "net_read" {
            if fb_iohas[f] {
                fb_iohas[f] = false
                let r = fb_iores[f]
                fb_iores[f] = VUnit
                r
            } else {
                if !is_int(fpeek(f, 1)) || !is_int(fpeek(f, 0)) {
                    trap("net_read() needs (int, int)")
                }
                let h = int_of(fpeek(f, 1))
                let max = int_of(fpeek(f, 0))
                match net_nb(1, h, "", max) {
                    Ok(s) => make_ok(f, VStr(s)),
                    Err(m) => {
                        if m == "__eagain" {
                            park_netop = 1
                            park_nethandle = h
                            park_netdata = ""
                            park_netmax = max
                            VUnit
                        } else {
                            make_err(f, VStr(m))
                        }
                    },
                }
            }
        } else if nm == "net_write" {
            if fb_iohas[f] {
                fb_iohas[f] = false
                let r = fb_iores[f]
                fb_iores[f] = VUnit
                r
            } else {
                if !is_int(fpeek(f, 1)) || !is_str(fpeek(f, 0)) {
                    trap("net_write() needs (int, str)")
                }
                let h = int_of(fpeek(f, 1))
                let mut data = str_of(fpeek(f, 0))
                let mut going = true
                let mut had_err = false
                let mut err_val = VUnit
                while going && str_len(data) > 0 {
                    match net_nb(2, h, data, 0) {
                        Ok(s) => {
                            let n = match parse_int(s) {
                                Some(x) => x,
                                None => 0,
                            }
                            if n <= 0 {
                                going = false
                            } else {
                                data = substr(data, n, str_len(data) - n)
                            }
                        },
                        Err(m) => {
                            if m == "__eagain" {
                                park_netop = 2
                                park_nethandle = h
                                park_netdata = data
                                park_netmax = 0
                                going = false
                            } else {
                                had_err = true
                                err_val = make_err(f, VStr(m))
                                going = false
                            }
                        },
                    }
                }
                if park_netop >= 0 {
                    VUnit
                } else if had_err {
                    err_val
                } else {
                    make_ok(f, VUnit)
                }
            }
        } else if nm == "net_close" {
            if !is_int(fpeek(f, 0)) {
                trap("net_close() needs an int")
            }
            let _ = net_close(int_of(fpeek(f, 0)))
            VUnit
        } else if nm == "net_nb" {
            if !is_int(fpeek(f, 3)) || !is_int(fpeek(f, 2)) || !is_str(fpeek(f, 1)) || !is_int(fpeek(f, 0)) {
                trap("net_nb() needs (int, int, str, int)")
            }
            match net_nb(int_of(fpeek(f, 3)), int_of(fpeek(f, 2)), str_of(fpeek(f, 1)), int_of(fpeek(f, 0))) {
                Ok(s) => make_ok(f, VStr(s)),
                Err(m) => make_err(f, VStr(m)),
            }
        } else if nm == "read_stdin" {
            if fb_iohas[f] {
                fb_iohas[f] = false
                let r = fb_iores[f]
                fb_iores[f] = VUnit
                r
            } else {
                if !is_int(fpeek(f, 0)) {
                    trap("read_stdin() needs an int")
                }
                let max = int_of(fpeek(f, 0))
                match stdin_nb(max) {
                    Ok(s) => VStr(s),
                    Err(m) => {
                        if m == "__eagain" {
                            park_stdinmax = max
                            VUnit
                        } else {
                            trap("read_stdin: " + m)
                            VUnit
                        }
                    },
                }
            }
        } else if nm == "stdin_nb" {
            if !is_int(fpeek(f, 0)) {
                trap("stdin_nb() needs an int")
            }
            match stdin_nb(int_of(fpeek(f, 0))) {
                Ok(s) => make_ok(f, VStr(s)),
                Err(m) => make_err(f, VStr(m)),
            }
        } else {
            trap("unknown native " + nm + " (VM bug)")
            VUnit
        }
    }

    // ---- calls (vm.go callValue) ----
    fn call_value(f, argc) {
        let callee = fpeek(f, argc)
        let h = obj_h(callee)
        if h < 0 {
            trap("cannot call " + type_name(callee))
        }
        let t = o_tag[h]
        if t == ot_closure {
            let fnh = o_i1[h]
            if argc != f_arity[fnh] {
                trap(format_val(callee, false) + " expects " + str(f_arity[fnh]) + " argument(s), got " + str(argc))
            }
            if len(fb_fr_cl[f]) >= 2048 {
                trap("stack overflow (call depth > 2048)")
            }
            push(fb_fr_cl[f], h)
            push(fb_fr_ip[f], 0)
            push(fb_fr_base[f], ftop(f) - argc - 1)
            push(fb_fr_callip[f], cur_ip)
            push(fb_fr_defers[f], [])
            push(fb_fr_dstash[f], VUnit)
            push(fb_fr_dact[f], false)
        } else if t == ot_native {
            let res = do_native(f, o_i1[h], argc)
            if park_recv < 0 && park_io < 0 && park_netop < 0 && park_stdinmax < 0 {
                // otherwise leave callee+args: OpCall parks and retries
                let mut i = 0
                while i <= argc {
                    let _ = fpop(f)
                    i = i + 1
                }
                fpush(f, res)
            }
        } else if t == ot_ctor {
            let eh = o_i1[h]
            let vi = o_i2[h]
            if argc != en_varities[eh][vi] {
                trap(en_qual[eh] + "." + en_vnames[eh][vi] + " expects " + str(en_varities[eh][vi]) + " field(s), got " + str(argc))
            }
            // fields copied while still on the stack, so they stay rooted
            let mut fields = []
            let mut i = 0
            while i < argc {
                push(fields, fpeek(f, argc - 1 - i))
                i = i + 1
            }
            let inst = make_inst(eh, vi, fields)
            i = 0
            while i <= argc {
                let _ = fpop(f)
                i = i + 1
            }
            fpush(f, inst)
        } else {
            trap("cannot call " + type_name(callee))
        }
    }

    // ---- arithmetic and comparison (vm.go arith/compare) ----
    fn arith_name(op) {
        if op == op_add {
            "+"
        } else if op == op_sub {
            "-"
        } else if op == op_mul {
            "*"
        } else if op == op_div {
            "/"
        } else {
            "%"
        }
    }
    fn do_arith(f, op) {
        let b = fpeek(f, 0)
        let a = fpeek(f, 1)
        if is_str(a) && is_str(b) {
            if op != op_add {
                trap("cannot apply " + go_quote(arith_name(op)) + " to " + type_name(a) + " and " + type_name(b))
            }
            let s = str_of(a) + str_of(b)
            let _ = fpop(f)
            let _ = fpop(f)
            fpush(f, VStr(s))
        } else if is_int(a) && is_int(b) {
            let x = int_of(a)
            let y = int_of(b)
            let _ = fpop(f)
            let _ = fpop(f)
            // integer overflow always traps — never wraps silently (GOALS);
            // checks run before the host operation, which would trap itself
            if op == op_add {
                if y > 0 && x > max_int - y {
                    trap("integer overflow: " + str(x) + " + " + str(y))
                }
                if y < 0 && x < min_int - y {
                    trap("integer overflow: " + str(x) + " + " + str(y))
                }
                fpush(f, VInt(x + y))
            } else if op == op_sub {
                if y > 0 && x < min_int + y {
                    trap("integer overflow: " + str(x) + " - " + str(y))
                }
                if y < 0 && x > max_int + y {
                    trap("integer overflow: " + str(x) + " - " + str(y))
                }
                fpush(f, VInt(x - y))
            } else if op == op_mul {
                let mut over = false
                if x > 0 && y > 0 && x > max_int / y {
                    over = true
                }
                if x > 0 && y < 0 && y < min_int / x {
                    over = true
                }
                if x < 0 && y > 0 && x < min_int / y {
                    over = true
                }
                if x < 0 && y < 0 && x < max_int / y {
                    over = true
                }
                if over {
                    trap("integer overflow: " + str(x) + " * " + str(y))
                }
                fpush(f, VInt(x * y))
            } else if op == op_div {
                if y == 0 {
                    trap("integer division by zero")
                }
                if x == min_int && y == -1 {
                    trap("integer overflow: " + str(x) + " / " + str(y))
                }
                fpush(f, VInt(x / y))
            } else {
                if y == 0 {
                    trap("integer modulo by zero")
                }
                fpush(f, VInt(x % y))
            }
        } else if is_num(a) && is_num(b) && op != op_mod {
            let x = num_f(a)
            let y = num_f(b)
            let _ = fpop(f)
            let _ = fpop(f)
            if op == op_add {
                fpush(f, VFloat(x + y))
            } else if op == op_sub {
                fpush(f, VFloat(x - y))
            } else if op == op_mul {
                fpush(f, VFloat(x * y))
            } else {
                fpush(f, VFloat(x / y))
            }
        } else {
            trap("cannot apply " + go_quote(arith_name(op)) + " to " + type_name(a) + " and " + type_name(b))
        }
    }
    fn do_compare(f, op) {
        let b = fpop(f)
        let a = fpop(f)
        if is_str(a) && is_str(b) {
            let x = str_of(a)
            let y = str_of(b)
            let r = if op == op_gt {
                x > y
            } else if op == op_gt_eq {
                x >= y
            } else if op == op_lt {
                x < y
            } else {
                x <= y
            }
            fpush(f, VBool(r))
        } else if is_int(a) && is_int(b) {
            let x = int_of(a)
            let y = int_of(b)
            let r = if op == op_gt {
                x > y
            } else if op == op_gt_eq {
                x >= y
            } else if op == op_lt {
                x < y
            } else {
                x <= y
            }
            fpush(f, VBool(r))
        } else if is_num(a) && is_num(b) {
            let x = num_f(a)
            let y = num_f(b)
            let r = if op == op_gt {
                x > y
            } else if op == op_gt_eq {
                x >= y
            } else if op == op_lt {
                x < y
            } else {
                x <= y
            }
            fpush(f, VBool(r))
        } else {
            trap("cannot compare " + type_name(a) + " and " + type_name(b))
        }
    }

    // ---- one fiber until it finishes, blocks, or exhausts its slice ----
    fn exec_fiber(f) {
        let mut budget = vm_time_slice
        cur_f = f
        while true {
            if budget <= 0 {
                // preemption point
                schedule(f)
                return false
            }
            budget = budget - 1
            let fi = len(fb_fr_ip[f]) - 1
            let clh = fb_fr_cl[f][fi]
            let fnh = o_i1[clh]
            let code = f_code[fnh]
            let start_ip = fb_fr_ip[f][fi]
            cur_ip = start_ip
            let op = code[start_ip]
            fb_fr_ip[f][fi] = start_ip + 1

            if op == op_const {
                let idx = rd_u16(code, start_ip + 1)
                fb_fr_ip[f][fi] = start_ip + 3
                fpush(f, k_vals[fnh][idx])
            } else if op == op_unit {
                fpush(f, VUnit)
            } else if op == op_true {
                fpush(f, VBool(true))
            } else if op == op_false {
                fpush(f, VBool(false))
            } else if op == op_pop {
                let _ = fpop(f)
            } else if op == op_pop_n {
                let n = code[start_ip + 1]
                fb_fr_ip[f][fi] = start_ip + 2
                fsettop(f, ftop(f) - n)
            } else if op == op_close_upvalue {
                close_upvalues(f, ftop(f) - 1)
                let _ = fpop(f)
            } else if op == op_end_block {
                let n = code[start_ip + 1]
                fb_fr_ip[f][fi] = start_ip + 2
                let v = fpop(f)
                close_upvalues(f, ftop(f) - n)
                fsettop(f, ftop(f) - n)
                fpush(f, v)
            } else if op == op_get_local {
                let slot = rd_u16(code, start_ip + 1)
                fb_fr_ip[f][fi] = start_ip + 3
                fpush(f, fb_stack[f][fb_fr_base[f][fi] + slot])
            } else if op == op_set_local {
                let slot = rd_u16(code, start_ip + 1)
                fb_fr_ip[f][fi] = start_ip + 3
                fb_stack[f][fb_fr_base[f][fi] + slot] = fpeek(f, 0)
            } else if op == op_get_global {
                let idx = rd_u16(code, start_ip + 1)
                fb_fr_ip[f][fi] = start_ip + 3
                let name = match k_vals[fnh][idx] {
                    VStr(s) => s,
                    _ => {
                        trap("bad global name const (VM bug)")
                        ""
                    },
                }
                match get(globals, name) {
                    Some(v) => fpush(f, v),
                    None => trap("undefined variable " + go_quote(name)),
                }
            } else if op == op_def_global {
                let idx = rd_u16(code, start_ip + 1)
                fb_fr_ip[f][fi] = start_ip + 3
                let name = match k_vals[fnh][idx] {
                    VStr(s) => s,
                    _ => {
                        trap("bad global name const (VM bug)")
                        ""
                    },
                }
                put(globals, name, fpop(f))
            } else if op == op_set_global {
                let idx = rd_u16(code, start_ip + 1)
                fb_fr_ip[f][fi] = start_ip + 3
                let name = match k_vals[fnh][idx] {
                    VStr(s) => s,
                    _ => {
                        trap("bad global name const (VM bug)")
                        ""
                    },
                }
                match get(globals, name) {
                    Some(_) => put(globals, name, fpeek(f, 0)),
                    None => trap("undefined variable " + go_quote(name)),
                }
            } else if op == op_get_upval {
                let idx = rd_u16(code, start_ip + 1)
                fb_fr_ip[f][fi] = start_ip + 3
                fpush(f, uv_get(o_h1[clh][idx]))
            } else if op == op_set_upval {
                let idx = rd_u16(code, start_ip + 1)
                fb_fr_ip[f][fi] = start_ip + 3
                uv_set(o_h1[clh][idx], fpeek(f, 0))
            } else if op == op_eq {
                let b = fpop(f)
                let a = fpop(f)
                fpush(f, VBool(eq_val(a, b)))
            } else if op == op_neq {
                let b = fpop(f)
                let a = fpop(f)
                fpush(f, VBool(!eq_val(a, b)))
            } else if op == op_gt || op == op_gt_eq || op == op_lt || op == op_lt_eq {
                do_compare(f, op)
            } else if op == op_add || op == op_sub || op == op_mul || op == op_div || op == op_mod {
                do_arith(f, op)
            } else if op == op_neg {
                let v = fpop(f)
                match v {
                    VInt(n) => {
                        if n == min_int {
                            trap("integer overflow: -(" + str(n) + ")")
                        }
                        fpush(f, VInt(0 - n))
                    },
                    VFloat(x) => fpush(f, VFloat(0.0 - x)),
                    _ => trap("operand of '-' must be a number, got " + type_name(v)),
                }
            } else if op == op_not {
                let v = fpop(f)
                if !is_bool(v) {
                    trap("operand of '!' must be a bool, got " + type_name(v))
                }
                fpush(f, VBool(!bool_of(v)))
            } else if op == op_jump {
                fb_fr_ip[f][fi] = start_ip + 3 + rd_u16(code, start_ip + 1)
            } else if op == op_jump_if_false || op == op_jump_if_true || op == op_jump_if_false_pop {
                let cond = fpeek(f, 0)
                if !is_bool(cond) {
                    trap("condition must be a bool, got " + type_name(cond))
                }
                let dist = rd_u16(code, start_ip + 1)
                let mut nip = start_ip + 3
                if op == op_jump_if_false_pop {
                    let _ = fpop(f)
                }
                if op == op_jump_if_true {
                    if bool_of(cond) {
                        nip = nip + dist
                    }
                } else {
                    if !bool_of(cond) {
                        nip = nip + dist
                    }
                }
                fb_fr_ip[f][fi] = nip
            } else if op == op_loop {
                fb_fr_ip[f][fi] = start_ip + 3 - rd_u16(code, start_ip + 1)
            } else if op == op_call {
                let argc = code[start_ip + 1]
                fb_fr_ip[f][fi] = start_ip + 2
                call_value(f, argc)
                if park_recv >= 0 {
                    // the recv() native asked to block on a channel
                    let ch = park_recv
                    park_recv = -1
                    fb_status[f] = fs_blocked_recv
                    push(o_h2[ch], f)
                    wake_waiters(ch) // a select send arm can now proceed
                    fb_fr_ip[f][fi] = start_ip // re-run the call (and recv) once woken
                    return false
                }
                if park_sleep >= 0.0 {
                    // the sleep() native set a deadline
                    fb_status[f] = fs_blocked_timer
                    fb_wakeat[f] = park_sleep
                    park_sleep = -1.0
                    ntimers = ntimers + 1
                    return false // resumes after the call once the timer fires
                }
                if park_io >= 0 {
                    // the exec() native started a child
                    fb_status[f] = fs_blocked_io
                    fb_ioproc[f] = park_io
                    park_io = -1
                    nio = nio + 1
                    fb_fr_ip[f][fi] = start_ip // re-run exec once delivered
                    return false
                }
                if park_netop >= 0 {
                    fb_status[f] = fs_blocked_net
                    fb_netop[f] = park_netop
                    fb_nethandle[f] = park_nethandle
                    fb_netdata[f] = park_netdata
                    fb_netmax[f] = park_netmax
                    park_netop = -1
                    park_nethandle = -1
                    park_netdata = ""
                    park_netmax = 0
                    nio_net = nio_net + 1
                    fb_fr_ip[f][fi] = start_ip
                    return false
                }
                if park_stdinmax >= 0 {
                    fb_status[f] = fs_blocked_stdin
                    fb_stdinmax[f] = park_stdinmax
                    park_stdinmax = -1
                    nio_stdin = nio_stdin + 1
                    fb_fr_ip[f][fi] = start_ip
                    return false
                }
                if yield_flag {
                    // a native (yield) asked us to hand off
                    yield_flag = false
                    schedule(f)
                    return false
                }
            } else if op == op_closure {
                let idx = rd_u16(code, start_ip + 1)
                let mut ip = start_ip + 3
                let sub = match f_consts[fnh][idx] {
                    CFn(x) => x,
                    _ => {
                        trap("bad closure const (VM bug)")
                        0
                    },
                }
                let nclh = alloc_obj(ot_closure)
                o_i1[nclh] = sub
                fpush(f, VObj(nclh)) // root the closure while upvalues fill in
                let mut i = 0
                while i < f_nupvals[sub] {
                    let is_local = code[ip] == 1
                    let uidx = rd_u16(code, ip + 1)
                    ip = ip + 3
                    if is_local {
                        push(o_h1[nclh], capture_upvalue(f, fb_fr_base[f][fi] + uidx))
                    } else {
                        push(o_h1[nclh], o_h1[clh][uidx])
                    }
                    i = i + 1
                }
                fb_fr_ip[f][fi] = ip
            } else if op == op_return {
                if len(fb_fr_defers[f][fi]) > 0 || fb_fr_dact[f][fi] {
                    // registered defers: stash the exit value once, then run
                    // each deferred block by re-executing this return after
                    // its call (the re-entry pops the block's result)
                    let v = fpop(f)
                    if !fb_fr_dact[f][fi] {
                        fb_fr_dstash[f][fi] = v
                        fb_fr_dact[f][fi] = true
                    }
                    if len(fb_fr_defers[f][fi]) > 0 {
                        let dh = pop(fb_fr_defers[f][fi])
                        fb_fr_ip[f][fi] = start_ip
                        fpush(f, VObj(dh))
                        call_value(f, 0)
                    } else {
                        fpush(f, fb_fr_dstash[f][fi])
                        fb_fr_dact[f][fi] = false
                        fb_fr_ip[f][fi] = start_ip // plain return path below
                    }
                } else {
                    let result = fpop(f)
                    let base = fb_fr_base[f][fi]
                    close_upvalues(f, base)
                    let _ = pop(fb_fr_cl[f])
                    let _ = pop(fb_fr_ip[f])
                    let _ = pop(fb_fr_base[f])
                    let _ = pop(fb_fr_callip[f])
                    let _ = pop(fb_fr_defers[f])
                    let _ = pop(fb_fr_dstash[f])
                    let _ = pop(fb_fr_dact[f])
                    if len(fb_fr_cl[f]) == 0 {
                        fb_status[f] = fs_done
                        return true
                    }
                    fsettop(f, base)
                    fpush(f, result)
                }
            } else if op == op_list {
                let n = rd_u16(code, start_ip + 1)
                fb_fr_ip[f][fi] = start_ip + 3
                // alloc before popping: elements stay rooted on the stack
                let lh = alloc_obj(ot_list)
                let top = ftop(f)
                let mut i = top - n
                while i < top {
                    push(o_vals[lh], fb_stack[f][i])
                    i = i + 1
                }
                fsettop(f, top - n)
                fpush(f, VObj(lh))
            } else if op == op_index_get {
                let idx = fpop(f)
                let target = fpop(f)
                let lh = tagged_h(target, ot_list)
                if lh >= 0 {
                    if !is_int(idx) {
                        trap("list index must be an int, got " + type_name(idx))
                    }
                    let i = int_of(idx)
                    if i < 0 || i >= len(o_vals[lh]) {
                        trap("list index " + str(i) + " out of bounds (len " + str(len(o_vals[lh])) + ")")
                    }
                    fpush(f, o_vals[lh][i])
                } else if is_str(target) {
                    if !is_int(idx) {
                        trap("string index must be an int, got " + type_name(idx))
                    }
                    let s = str_of(target)
                    let i = int_of(idx)
                    if i < 0 || i >= str_len(s) {
                        trap("string index " + str(i) + " out of bounds (len " + str(str_len(s)) + ")")
                    }
                    fpush(f, VStr(char_at(s, i)))
                } else {
                    trap("cannot index " + type_name(target))
                }
            } else if op == op_index_set {
                let v = fpop(f)
                let idx = fpop(f)
                let target = fpop(f)
                let lh = tagged_h(target, ot_list)
                if lh < 0 {
                    trap("cannot index-assign into " + type_name(target))
                }
                if !is_int(idx) {
                    trap("list index must be an int, got " + type_name(idx))
                }
                let i = int_of(idx)
                if i < 0 || i >= len(o_vals[lh]) {
                    trap("list index " + str(i) + " out of bounds (len " + str(len(o_vals[lh])) + ")")
                }
                o_vals[lh][i] = v
            } else if op == op_len {
                let v = fpop(f)
                let lh = tagged_h(v, ot_list)
                if lh >= 0 {
                    fpush(f, VInt(len(o_vals[lh])))
                } else if is_str(v) {
                    fpush(f, VInt(str_len(str_of(v))))
                } else {
                    trap("len() needs a list or string, got " + type_name(v))
                }
            } else if op == op_test_variant {
                let vidx = code[start_ip + 1]
                fb_fr_ip[f][fi] = start_ip + 2
                let etv = fpop(f)
                let cand = fpop(f)
                let eth = obj_h(etv)
                if eth < 0 {
                    trap("bad TestVariant operand (VM bug)")
                }
                let m = match cand {
                    VObj(ih) => o_tag[ih] == ot_enuminst && o_i1[ih] == o_i1[eth] && o_i2[ih] == vidx,
                    _ => false,
                }
                fpush(f, VBool(m))
            } else if op == op_get_field {
                let fidx = code[start_ip + 1]
                fb_fr_ip[f][fi] = start_ip + 2
                let inst = fpop(f)
                let ih = obj_h(inst)
                if ih < 0 {
                    trap("bad GetField operand (VM bug)")
                }
                fpush(f, o_vals[ih][fidx])
            } else if op == op_no_match {
                trap("no pattern matched value " + format_val(fpeek(f, 0), true))
            } else if op == op_try {
                if fb_fr_dact[f][fi] {
                    // mid defer-exit re-entry: drop the deferred block's
                    // result and continue unwinding with the stashed None/Err
                    let _ = fpop(f)
                    if len(fb_fr_defers[f][fi]) > 0 {
                        let dh = pop(fb_fr_defers[f][fi])
                        fb_fr_ip[f][fi] = start_ip
                        fpush(f, VObj(dh))
                        call_value(f, 0)
                    } else {
                        let result = fb_fr_dstash[f][fi]
                        let base = fb_fr_base[f][fi]
                        close_upvalues(f, base)
                        let _ = pop(fb_fr_cl[f])
                        let _ = pop(fb_fr_ip[f])
                        let _ = pop(fb_fr_base[f])
                        let _ = pop(fb_fr_callip[f])
                        let _ = pop(fb_fr_defers[f])
                        let _ = pop(fb_fr_dstash[f])
                        let _ = pop(fb_fr_dact[f])
                        if len(fb_fr_cl[f]) == 0 {
                            fb_status[f] = fs_done
                            return true
                        }
                        fsettop(f, base)
                        fpush(f, result)
                    }
                } else {
                    let v = fpeek(f, 0)
                    let ih = tagged_h(v, ot_enuminst)
                    let is_opt_res = if ih >= 0 {
                        o_i1[ih] == opt_enum || o_i1[ih] == res_enum
                    } else {
                        false
                    }
                    if !is_opt_res {
                        trap("'?' needs an Option or Result, got " + type_name(v))
                    }
                    if o_i2[ih] == 0 {
                        // Some/Ok
                        let _ = fpop(f)
                        fpush(f, o_vals[ih][0])
                    } else if len(fb_fr_defers[f][fi]) > 0 {
                        // early exit with registered defers: run them first
                        let _ = fpop(f)
                        fb_fr_dstash[f][fi] = v
                        fb_fr_dact[f][fi] = true
                        let dh = pop(fb_fr_defers[f][fi])
                        fb_fr_ip[f][fi] = start_ip
                        fpush(f, VObj(dh))
                        call_value(f, 0)
                    } else {
                        // early-return the None/Err itself
                        let _ = fpop(f)
                        let base = fb_fr_base[f][fi]
                        close_upvalues(f, base)
                        let _ = pop(fb_fr_cl[f])
                        let _ = pop(fb_fr_ip[f])
                        let _ = pop(fb_fr_base[f])
                        let _ = pop(fb_fr_callip[f])
                        let _ = pop(fb_fr_defers[f])
                        let _ = pop(fb_fr_dstash[f])
                        let _ = pop(fb_fr_dact[f])
                        if len(fb_fr_cl[f]) == 0 {
                            fb_status[f] = fs_done
                            return true
                        }
                        fsettop(f, base)
                        fpush(f, v)
                    }
                }
            } else if op == op_defer {
                let v = fpop(f)
                let dh = tagged_h(v, ot_closure)
                if dh < 0 {
                    trap("defer needs a function, got " + type_name(v) + " (VM bug)")
                }
                push(fb_fr_defers[f][fi], dh)
            } else if op == op_spawn {
                let argc = code[start_ip + 1]
                fb_fr_ip[f][fi] = start_ip + 2
                let callee = fpeek(f, argc)
                let ch2 = tagged_h(callee, ot_closure)
                if ch2 < 0 {
                    trap("spawn needs a function, got " + type_name(callee))
                }
                if f_arity[o_i1[ch2]] != argc {
                    trap(format_val(callee, false) + " expects " + str(f_arity[o_i1[ch2]]) + " argument(s), got " + str(argc))
                }
                let mut sargs = []
                let mut i = 0
                while i < argc {
                    push(sargs, fpeek(f, argc - 1 - i))
                    i = i + 1
                }
                let nf = new_fiber(ch2, sargs)
                schedule(nf)
                fsettop(f, ftop(f) - argc - 1)
            } else if op == op_send {
                let v = fpop(f)
                let chv = fpop(f)
                let ch = tagged_h(chv, ot_channel)
                if ch < 0 {
                    trap("cannot send to " + type_name(chv) + " (need a channel)")
                }
                if o_b1[ch] {
                    trap("send on closed channel")
                }
                if len(o_h2[ch]) > 0 {
                    // hand the value off through the buffer; the woken
                    // receiver re-runs its receive and finds it there
                    push(o_vals[ch], v)
                    let r = o_h2[ch][0]
                    o_h2[ch] = slice(o_h2[ch], 1, len(o_h2[ch]))
                    schedule(r)
                    wake_waiters(ch)
                } else if len(o_vals[ch]) < o_i1[ch] {
                    push(o_vals[ch], v)
                    wake_waiters(ch)
                } else {
                    fb_sendval[f] = v
                    fb_status[f] = fs_blocked_send
                    push(o_h1[ch], f)
                    wake_waiters(ch) // a select receive arm can now proceed
                    return false
                }
            } else if op == op_recv {
                let chv = fpeek(f, 0) // keep the channel on the stack in case we park
                let ch = tagged_h(chv, ot_channel)
                if ch < 0 {
                    let _ = fpop(f)
                    trap("cannot receive from " + type_name(chv) + " (need a channel)")
                }
                match chan_try_recv(ch) {
                    RecvGot(v) => {
                        let _ = fpop(f)
                        fpush(f, v)
                        wake_waiters(ch)
                    },
                    RecvNone => {
                        if o_b1[ch] {
                            let _ = fpop(f)
                            trap("receive on closed channel")
                        }
                        fb_status[f] = fs_blocked_recv
                        push(o_h2[ch], f)
                        wake_waiters(ch) // a select send arm can now proceed
                        fb_fr_ip[f][fi] = start_ip // re-run once woken
                        return false
                    },
                }
            } else if op == op_chan_next {
                let chv = fpeek(f, 0)
                let ch = tagged_h(chv, ot_channel)
                if ch < 0 {
                    let _ = fpop(f)
                    trap("cannot iterate " + type_name(chv) + " (need a channel)")
                }
                match chan_try_recv(ch) {
                    RecvGot(v) => {
                        let _ = fpop(f)
                        fpush(f, v)
                        wake_waiters(ch)
                        // skip the jump operand: fall through into the body
                        fb_fr_ip[f][fi] = start_ip + 3
                    },
                    RecvNone => {
                        if o_b1[ch] {
                            let _ = fpop(f)
                            // exit the loop
                            fb_fr_ip[f][fi] = start_ip + 3 + rd_u16(code, start_ip + 1)
                        } else {
                            fb_status[f] = fs_blocked_recv
                            push(o_h2[ch], f)
                            wake_waiters(ch)
                            fb_fr_ip[f][fi] = start_ip // re-run once woken
                            return false
                        }
                    },
                }
            } else if op == op_select {
                // on re-entry after a park, drop stale waiter registrations
                if len(fb_selectch[f]) > 0 {
                    for pch in fb_selectch[f] {
                        remove_waiter(pch, f)
                    }
                    fb_selectch[f] = []
                }
                let mut p = start_ip + 1
                let n_arms = code[p]
                let has_default = code[p + 1] != 0
                p = p + 2
                let mut arm_send = []
                let mut arm_target = []
                let mut slots = 0
                let mut i = 0
                while i < n_arms {
                    let kind = code[p]
                    let dist = rd_u16(code, p + 1)
                    p = p + 3
                    push(arm_send, kind == 1)
                    push(arm_target, p + dist)
                    slots = slots + (if kind == 1 {
                        2
                    } else {
                        1
                    })
                    i = i + 1
                }
                let mut default_target = -1
                if has_default {
                    let dist = rd_u16(code, p)
                    p = p + 2
                    default_target = p + dist
                }
                let base = ftop(f) - slots
                // resolve each arm's operand positions from the bottom up
                let mut chan_pos = []
                let mut val_pos = []
                let mut off = base
                i = 0
                while i < n_arms {
                    push(chan_pos, off)
                    if arm_send[i] {
                        push(val_pos, off + 1)
                        off = off + 2
                    } else {
                        push(val_pos, -1)
                        off = off + 1
                    }
                    i = i + 1
                }
                // pick the first ready arm in declaration order
                let mut chosen = -1
                i = 0
                while i < n_arms {
                    let ch = tagged_h(fb_stack[f][chan_pos[i]], ot_channel)
                    if ch < 0 {
                        trap("select arm needs a channel, got " + type_name(fb_stack[f][chan_pos[i]]))
                    }
                    if arm_send[i] {
                        if chan_send_ready(ch) {
                            chosen = i
                            break
                        }
                    } else if chan_recv_ready(ch) {
                        chosen = i
                        break
                    }
                    i = i + 1
                }
                if chosen >= 0 {
                    let ch = tagged_h(fb_stack[f][chan_pos[chosen]], ot_channel)
                    if arm_send[chosen] {
                        if o_b1[ch] {
                            trap("send on closed channel")
                        }
                        let v = fb_stack[f][val_pos[chosen]]
                        if len(o_h2[ch]) > 0 {
                            push(o_vals[ch], v)
                            let r = o_h2[ch][0]
                            o_h2[ch] = slice(o_h2[ch], 1, len(o_h2[ch]))
                            schedule(r)
                        } else {
                            push(o_vals[ch], v)
                        }
                        wake_waiters(ch)
                        fsettop(f, base)
                    } else {
                        match chan_try_recv(ch) {
                            RecvGot(v) => {
                                wake_waiters(ch)
                                fsettop(f, base)
                                fpush(f, v) // left on the stack for a binding arm
                            },
                            RecvNone => {
                                // implies closed here
                                fsettop(f, base)
                                trap("receive on closed channel")
                            },
                        }
                    }
                    fb_fr_ip[f][fi] = arm_target[chosen]
                } else if has_default {
                    fsettop(f, base)
                    fb_fr_ip[f][fi] = default_target
                } else {
                    // nothing ready: park on every arm's channel, retry when woken
                    i = 0
                    while i < n_arms {
                        let ch = tagged_h(fb_stack[f][chan_pos[i]], ot_channel)
                        push(o_h3[ch], f)
                        push(fb_selectch[f], ch)
                        i = i + 1
                    }
                    fb_status[f] = fs_blocked_select
                    fb_fr_ip[f][fi] = start_ip
                    return false
                }
            } else if op == op_record {
                let n = code[start_ip + 1]
                let cidx = rd_u16(code, start_ip + 2)
                fb_fr_ip[f][fi] = start_ip + 4
                let names_str = match k_vals[fnh][cidx] {
                    VStr(s) => s,
                    _ => "",
                }
                let fnames = split(names_str, "\n")
                let h = alloc_obj(ot_record)
                let mut vals = []
                let mut i = 0
                while i < n {
                    push(vals, fpeek(f, n - 1 - i))
                    i = i + 1
                }
                fsettop(f, ftop(f) - n)
                let mut keys = []
                let mut j = 0
                while j < len(fnames) {
                    if fnames[j] != "" {
                        push(keys, VStr(fnames[j]))
                    }
                    j = j + 1
                }
                o_vals[h] = vals
                o_keys[h] = keys
                fpush(f, VObj(h))
            } else if op == op_get_field_name {
                let cidx = rd_u16(code, start_ip + 1)
                fb_fr_ip[f][fi] = start_ip + 3
                let fname = match k_vals[fnh][cidx] {
                    VStr(s) => s,
                    _ => "",
                }
                let rv = fpop(f)
                let rh = tagged_h(rv, ot_record)
                if rh < 0 {
                    trap("field access needs a record, got " + type_name(rv))
                }
                let mut found = false
                let mut i = 0
                while i < len(o_keys[rh]) {
                    if o_keys[rh][i] == VStr(fname) {
                        fpush(f, o_vals[rh][i])
                        found = true
                        i = len(o_keys[rh])
                    }
                    i = i + 1
                }
                if !found {
                    trap("record has no field \"" + fname + "\"")
                }
            } else if op == op_record_update {
                let n = code[start_ip + 1]
                let cidx = rd_u16(code, start_ip + 2)
                fb_fr_ip[f][fi] = start_ip + 4
                let names_str = match k_vals[fnh][cidx] {
                    VStr(s) => s,
                    _ => "",
                }
                let fnames = split(names_str, "\n")
                let mut update_names = []
                let mut j = 0
                while j < len(fnames) {
                    if fnames[j] != "" {
                        push(update_names, fnames[j])
                    }
                    j = j + 1
                }
                let mut new_vals = []
                let mut i = 0
                while i < n {
                    push(new_vals, fpeek(f, n - 1 - i))
                    i = i + 1
                }
                fsettop(f, ftop(f) - n)
                let base_v = fpop(f)
                let bh = tagged_h(base_v, ot_record)
                if bh < 0 {
                    trap("record update needs a record, got " + type_name(base_v))
                }
                let h = alloc_obj(ot_record)
                let mut rkeys = []
                let mut rvals = []
                let mut k = 0
                while k < len(o_keys[bh]) {
                    push(rkeys, o_keys[bh][k])
                    let mut overwritten = false
                    let mut m = 0
                    while m < len(update_names) {
                        if VStr(update_names[m]) == o_keys[bh][k] {
                            push(rvals, new_vals[m])
                            overwritten = true
                            m = len(update_names)
                        }
                        m = m + 1
                    }
                    if !overwritten {
                        push(rvals, o_vals[bh][k])
                    }
                    k = k + 1
                }
                o_vals[h] = rvals
                o_keys[h] = rkeys
                fpush(f, VObj(h))
            } else {
                trap("bad opcode " + str(op) + " (VM bug)")
            }
        }
        false // unreachable: the loop only exits through return
    }

    // ---- load: enum type objects, converted constants, natives ----
    let mut et_obj = []
    let mut e = 0
    while e < len(en_qual) {
        let h = alloc_obj(ot_enumtype)
        o_i1[h] = e
        push(et_obj, h)
        push(pinned, h)
        if en_qual[e] == "Option" {
            opt_enum = e
        }
        if en_qual[e] == "Result" {
            res_enum = e
        }
        if en_qual[e] == "Output" {
            out_enum = e
        }
        e = e + 1
    }
    let mut fh = 0
    while fh < len(f_name) {
        let mut kv = []
        for cv in f_consts[fh] {
            push(kv, match cv {
                CInt(n) => VInt(n),
                CFloat(x) => VFloat(x),
                CStr(s) => VStr(s),
                CFn(_) => VUnit, // only reached through OpClosure, which reads the CVal
                CEnumType(eh) => VObj(et_obj[eh]),
                CSingleton(eh, vi) => {
                    let h = alloc_obj(ot_enuminst)
                    o_i1[h] = eh
                    o_i2[h] = vi
                    push(pinned, h)
                    VObj(h)
                },
                CCtor(eh, vi) => {
                    let h = alloc_obj(ot_ctor)
                    o_i1[h] = eh
                    o_i2[h] = vi
                    push(pinned, h)
                    VObj(h)
                },
            })
        }
        push(k_vals, kv)
        fh = fh + 1
    }
    let mut ni = 0
    while ni < len(native_names) {
        let h = alloc_obj(ot_native)
        o_i1[h] = ni
        push(pinned, h)
        put(globals, native_names[ni], VObj(h))
        ni = ni + 1
    }
    put(globals, "Option", VObj(et_obj[opt_enum]))
    put(globals, "Result", VObj(et_obj[res_enum]))
    put(globals, "Output", VObj(et_obj[out_enum]))

    // ---- main fiber and scheduler (vm.go run) ----
    let mcl = alloc_obj(ot_closure)
    o_i1[mcl] = 0 // entry function is handle 0
    main_fiber = new_fiber(mcl, [])
    push(ready, main_fiber)
    vm_on = true

    while true {
        if ntimers > 0 {
            wake_due_timers()
        }
        if nio > 0 {
            wait_register_all()
            wait_poll_io()
        }
        if nio_net > 0 {
            wait_poll_net()
        }
        if nio_stdin > 0 {
            wait_poll_stdin()
        }
        if len(ready) == 0 {
            if nio > 0 || nio_net > 0 || nio_stdin > 0 || ntimers > 0 {
                wait_idle()
            } else {
                // main finished => program over (checked below); otherwise deadlock
                let mut blocked = 0
                let mut bi = 0
                while bi < len(fb_status) {
                    let st = fb_status[bi]
                    if st == fs_blocked_send || st == fs_blocked_recv || st == fs_blocked_select {
                        blocked = blocked + 1
                    }
                    bi = bi + 1
                }
                if blocked > 0 {
                    eprintln("fatal: deadlock — all " + str(blocked) + " remaining fiber(s) are blocked on channels")
                    exit(4)
                }
                return
            }
        }
        let fx = ready[0]
        ready = slice(ready, 1, len(ready))
        if fb_status[fx] == fs_ready {
            let done = exec_fiber(fx)
            if done && fx == main_fiber {
                return // Go semantics: program exits when main returns
            }
        }
    }
}
