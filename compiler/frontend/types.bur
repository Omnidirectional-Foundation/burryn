// Hindley-Milner checker ported from types.go.
//
// Go's Ty is an interface over TCon/TFunc/TV with mutable TV links; here
// types live in an arena of parallel mut lists and a type is an int handle:
//   tk[h] kind: 0 = con, 1 = fn, 2 = var
//   tn[h] con name, or the var's overloading constraint ("" = none)
//   ta[h] con args / fn params (list of handles)
//   tr[h] fn ret handle / var link (-1 = unbound)
//   tl[h] var level (Rémy-style, for generalization)
// The pure type machinery lives at module level and threads the arena
// explicitly; the checker itself is one big function whose helpers close
// over the arena and the checker state (see typecheck_script below).

import "burryn.dev/compiler/lib"

// LSP hover side-channel: the last typecheck_program run snapshots the type
// arena plus a per-node span->handle table so the LSP can answer "what is
// the inferred type at offset N in file F". Reset at the start of each
// check; populated only while lsp_recording is true (LSP only, so `bur
// check`/`build` pay just one bool check per expression). Mirrors the
// chan_fors side-list pattern: nodes are immutable, so type info is emitted
// to a parallel table during inference.
let mut lsp_recording = false
let mut lsp_ty_starts = []
let mut lsp_ty_ends = []
let mut lsp_ty_handles = []
let mut lsp_ty_files = []
let mut lsp_arena_tk = []
let mut lsp_arena_tn = []
let mut lsp_arena_ta = []
let mut lsp_arena_tr = []

fn lsp_record_type(sp, h, file) {
    match sp {
        Sp(s, e) => {
            push(lsp_ty_starts, s)
            push(lsp_ty_ends, e)
            push(lsp_ty_handles, h)
            push(lsp_ty_files, file)
        },
    }
}

// lsp_type_at returns the rendered type of the innermost recorded node whose
// span contains (file, offset), or "" if none. Innermost wins so hovering
// `foo` inside `foo(x)` reports foo's type, not the call's.
pub fn lsp_type_at(file, offset) {
    let mut best = -1
    let mut best_len = -1
    let mut i = 0
    while i < len(lsp_ty_handles) {
        if lsp_ty_files[i] == file && offset >= lsp_ty_starts[i] && offset < lsp_ty_ends[i] {
            let span_len = lsp_ty_ends[i] - lsp_ty_starts[i]
            if best < 0 || span_len < best_len {
                best = i
                best_len = span_len
            }
        }
        i = i + 1
    }
    if best < 0 {
        ""
    } else {
        ty_pretty1(lsp_arena_tk, lsp_arena_tn, lsp_arena_ta, lsp_arena_tr, lsp_ty_handles[best])
    }
}

// lsp_set_recording lets out-of-package callers (the `bur dev hover` command)
// toggle the side-channel; the LSP sets lsp_recording directly (same package).
pub fn lsp_set_recording(b: bool) {
    lsp_recording = b
}

fn ty_new_con(mut tk, mut tn, mut ta, mut tr, mut tl, name, cargs) {
    push(tk, 0)
    push(tn, name)
    push(ta, cargs)
    push(tr, -1)
    push(tl, 0)
    len(tk) - 1
}

fn ty_new_fn(mut tk, mut tn, mut ta, mut tr, mut tl, params, ret) {
    push(tk, 1)
    push(tn, "")
    push(ta, params)
    push(tr, ret)
    push(tl, 0)
    len(tk) - 1
}

fn ty_new_var(mut tk, mut tn, mut ta, mut tr, mut tl, level, con) {
    push(tk, 2)
    push(tn, con)
    push(ta, [])
    push(tr, -1)
    push(tl, level)
    len(tk) - 1
}

fn ty_resolve(tk, tr, h) {
    let mut cur = h
    while tk[cur] == 2 && tr[cur] != -1 {
        cur = tr[cur]
    }
    cur
}

fn ty_adjust_level(tk, tn, ta, tr, mut tl, h, level) {
    let x = ty_resolve(tk, tr, h)
    if tk[x] == 2 {
        if tl[x] > level {
            tl[x] = level
        }
    } else if tk[x] == 0 {
        for a in ta[x] {
            ty_adjust_level(tk, tn, ta, tr, tl, a, level)
        }
    } else {
        for p in ta[x] {
            ty_adjust_level(tk, tn, ta, tr, tl, p, level)
        }
        ty_adjust_level(tk, tn, ta, tr, tl, tr[x], level)
    }
}

fn ty_occurs(tk, ta, tr, v, h) {
    let x = ty_resolve(tk, tr, h)
    if tk[x] == 2 {
        x == v
    } else if tk[x] == 0 {
        let mut found = false
        for a in ta[x] {
            if ty_occurs(tk, ta, tr, v, a) {
                found = true
            }
        }
        found
    } else {
        let mut found = false
        for p in ta[x] {
            if ty_occurs(tk, ta, tr, v, p) {
                found = true
            }
        }
        found || ty_occurs(tk, ta, tr, v, tr[x])
    }
}

// dm_heap_walk: does a type recursively contain a heap source (list/map)?
// Skips chan subtrees (chan is exempt per GOALS §2 — CSP alias is semantic).
fn dm_heap_walk(tk, tn, ta, tr, h) {
    let x = ty_resolve(tk, tr, h)
    if tk[x] != 0 {
        return false
    }
    if tn[x] == "list" || tn[x] == "map" {
        return true
    }
    if tn[x] == "chan" {
        return false
    }
    let mut found = false
    for a in ta[x] {
        if dm_heap_walk(tk, tn, ta, tr, a) {
            found = true
        }
    }
    found
}

// is_fresh_source: syntactic freshness classification per GOALS §2.
// Fresh = literals / list+map literals / enum constructors / call returns
// / FnLit / if+match (recursively each arm tail) / block (tail expr or
// trailing return). Pattern names are threaded from each match arm so this
// classifier retains lexical scope after the checker has popped that arm.
fn fresh_name_copy(src) {
    let mut out = map()
    for name in keys(src) {
        put(out, name, true)
    }
    out
}

fn fresh_pattern_names(p, mut names) {
    match p {
        PatBinding(name, _) => put(names, name, true),
        PatVariant(_, _, _, binds, _) => {
            for bind in binds {
                fresh_pattern_names(bind, names)
            }
        },
        _ => {},
    }
}

// Ident: a binding from the current match pattern is fresh; a mutable
// binding is an allowed source; a non-mut binding aliases its value.
fn is_fresh_source(e, lookup, b_mut, b_kind, fresh_names) {
    match e {
        IntLit(_, _) => true,
        FloatLit(_, _) => true,
        StrLit(_, _) => true,
        BoolLit(_, _) => true,
        ListLit(_, _) => true,
        FnLit(_, _, _, _, _, _, _, _) => true,
        VariantAccess(_, _, _) => true,
        QualVariantAccess(_, _, _, _) => true,
        Call(_, _, _) => true,
        Ident(name, _) => {
            match get(fresh_names, name) {
                Some(_) => true,
                None => {
                    let b = lookup(name)
                    b >= 0 && b_mut[b]
                },
            }
        },
        IfExpr(_, then_b, else_b, _) => is_fresh_source(then_b, lookup, b_mut, b_kind, fresh_names) && is_fresh_source(else_b, lookup, b_mut, b_kind, fresh_names),
        MatchExpr(_, arms, _) => {
            let mut all_fresh = true
            for arm in arms {
                match arm {
                    MatchArm(pat, _, body, _) => {
                        let mut arm_names = fresh_name_copy(fresh_names)
                        fresh_pattern_names(pat, arm_names)
                        if !is_fresh_source(body, lookup, b_mut, b_kind, arm_names) {
                            all_fresh = false
                        }
                    },
                    _ => {},
                }
            }
            all_fresh
        },
        Block(stmts, _) => {
            if len(stmts) == 0 {
                false
            } else {
                match stmts[len(stmts) - 1] {
                    ExprStmt(inner, _) => is_fresh_source(inner, lookup, b_mut, b_kind, fresh_names),
                    ReturnStmt(_, _) => true,
                    _ => false,
                }
            }
        },
        _ => false,
    }
}

// con_set lists the members of an overloading constraint set
fn con_set(con) {
    match con {
        "num" => ["int", "float"],
        "addord" => ["int", "float", "str"],
        "key" => ["int", "str"],
        "int" => ["int"],
        "float" => ["float"],
        "str" => ["str"],
        _ => [],
    }
}

fn con_allows(con, name) {
    if con == "" {
        true
    } else {
        contains(con_set(con), name)
    }
}

fn con_join(con, sep) {
    join(con_set(con), sep)
}

// con_merge intersects two overloading constraints; "!" means the
// intersection is empty (Go returns ok=false).
fn con_merge(a, b) {
    if a == "" {
        b
    } else if b == "" || a == b {
        a
    } else {
        let mut inter = []
        for x in con_set(a) {
            if contains(con_set(b), x) {
                push(inter, x)
            }
        }
        if len(inter) == 0 {
            "!"
        } else {
            let mut best = "!"
            for name in ["num", "addord", "key", "int", "float", "str"] {
                let set = con_set(name)
                if len(set) == len(inter) {
                    let mut same = true
                    for x in inter {
                        if !contains(set, x) {
                            same = false
                        }
                    }
                    if same && best == "!" {
                        best = name
                    }
                }
            }
            best
        }
    }
}

// ty_pretty renders a type for messages and the bind dump; names is a
// var-handle -> display-name map filled in first-encounter order, cnt its
// one-slot size counter (mirrors pretty/prettyWith in types.go).
fn ty_pretty(tk, tn, ta, tr, h, mut names, mut cnt) {
    let x = ty_resolve(tk, tr, h)
    if tk[x] == 2 {
        let n = match get(names, x) {
            Some(nm) => nm,
            None => {
                let nm = "'" + chr(97 + cnt[0] % 26)
                put(names, x, nm)
                cnt[0] = cnt[0] + 1
                nm
            },
        }
        if tn[x] != "" {
            n + ":" + tn[x]
        } else {
            n
        }
    } else if tk[x] == 0 {
        if tn[x] == "list" {
            "[" + ty_pretty(tk, tn, ta, tr, ta[x][0], names, cnt) + "]"
        } else if tn[x] == "chan" {
            "chan(" + ty_pretty(tk, tn, ta, tr, ta[x][0], names, cnt) + ")"
        } else if str_len(tn[x]) > 4 && substr(tn[x], 0, 4) == "@rec" {
            let fnames = rec_parse_names(tn[x])
            let mut fields = []
            let mut i = 0
            while i < len(fnames) {
                push(fields, fnames[i] + ": " + ty_pretty(tk, tn, ta, tr, ta[x][i], names, cnt))
                i = i + 1
            }
            "record " + chr(123) + " " + join(fields, ", ") + " " + chr(125)
        } else if len(ta[x]) == 0 {
            tn[x]
        } else {
            let mut parts = []
            for a in ta[x] {
                push(parts, ty_pretty(tk, tn, ta, tr, a, names, cnt))
            }
            tn[x] + "(" + join(parts, ", ") + ")"
        }
    } else {
        let mut parts = []
        for p in ta[x] {
            push(parts, ty_pretty(tk, tn, ta, tr, p, names, cnt))
        }
        "fn(" + join(parts, ", ") + ") -> " + ty_pretty(tk, tn, ta, tr, tr[x], names, cnt)
    }
}

fn ty_pretty1(tk, tn, ta, tr, h) {
    let mut names = map()
    let mut cnt = [0]
    ty_pretty(tk, tn, ta, tr, h, names, cnt)
}

// ty_unify unifies two types in place; "" on success, else the error text
// (Go returns error). Mirrors unify in types.go.
fn ty_unify(tk, mut tn, ta, mut tr, mut tl, ah, bh) {
    let a = ty_resolve(tk, tr, ah)
    let b = ty_resolve(tk, tr, bh)
    if a == b {
        return ""
    }
    if tk[a] == 2 {
        if ty_occurs(tk, ta, tr, a, b) {
            return "recursive type detected"
        }
        if tk[b] == 0 && len(ta[b]) == 0 {
            if !con_allows(tn[a], tn[b]) {
                return "`" + tn[b] + "` is not valid here: this operator needs " + con_join(tn[a], " or ")
            }
        }
        if tk[b] == 0 && len(ta[b]) > 0 && tn[a] != "" {
            return "`" + ty_pretty1(tk, tn, ta, tr, b) + "` is not valid here: this operator needs " + con_join(tn[a], " or ")
        }
        if tk[b] == 1 && tn[a] != "" {
            return "a function is not valid here: this operator needs " + con_join(tn[a], " or ")
        }
        if tk[b] == 2 {
            let merged = con_merge(tn[a], tn[b])
            if merged == "!" {
                return "no type satisfies both " + con_join(tn[a], "|") + " and " + con_join(tn[b], "|")
            }
            tn[b] = merged
        }
        ty_adjust_level(tk, tn, ta, tr, tl, b, tl[a])
        tr[a] = b
        return ""
    }
    if tk[b] == 2 {
        return ty_unify(tk, tn, ta, tr, tl, b, a)
    }
    if tk[a] == 0 && tk[b] == 0 {
        if tn[a] != tn[b] || len(ta[a]) != len(ta[b]) {
            return "expected `" + ty_pretty1(tk, tn, ta, tr, a) + "`, found `" + ty_pretty1(tk, tn, ta, tr, b) + "`"
        }
        let mut i = 0
        while i < len(ta[a]) {
            let e = ty_unify(tk, tn, ta, tr, tl, ta[a][i], ta[b][i])
            if e != "" {
                return e
            }
            i = i + 1
        }
        return ""
    }
    if tk[a] == 1 && tk[b] == 1 {
        if len(ta[a]) != len(ta[b]) {
            return "expected a function with " + str(len(ta[a])) + " parameter(s), found one with " + str(len(ta[b]))
        }
        let mut i = 0
        while i < len(ta[a]) {
            let e = ty_unify(tk, tn, ta, tr, tl, ta[a][i], ta[b][i])
            if e != "" {
                return e
            }
            i = i + 1
        }
        return ty_unify(tk, tn, ta, tr, tl, tr[a], tr[b])
    }
    "expected `" + ty_pretty1(tk, tn, ta, tr, a) + "`, found `" + ty_pretty1(tk, tn, ta, tr, b) + "`"
}

// ty_generalize collects unbound vars deeper than level into vars (the
// quantified set), first-encounter order, skipping duplicates via seen.
fn ty_generalize_walk(tk, tn, ta, tr, tl, h, level, mut vars, mut seen) {
    let x = ty_resolve(tk, tr, h)
    if tk[x] == 2 {
        let dup = match get(seen, x) {
            Some(_) => true,
            None => false,
        }
        if tl[x] > level && !dup {
            put(seen, x, true)
            push(vars, x)
        }
    } else if tk[x] == 0 {
        for a in ta[x] {
            ty_generalize_walk(tk, tn, ta, tr, tl, a, level, vars, seen)
        }
    } else {
        for p in ta[x] {
            ty_generalize_walk(tk, tn, ta, tr, tl, p, level, vars, seen)
        }
        ty_generalize_walk(tk, tn, ta, tr, tl, tr[x], level, vars, seen)
    }
}

// ty_instantiate_cp copies t replacing quantified vars per subst (a var
// handle -> fresh handle map); level is the checker level for fresh vars.
fn ty_instantiate_cp(mut tk, mut tn, mut ta, mut tr, mut tl, h, subst) {
    let x = ty_resolve(tk, tr, h)
    if tk[x] == 2 {
        match get(subst, x) {
            Some(n) => n,
            None => x,
        }
    } else if tk[x] == 0 {
        let mut cargs = []
        for a in ta[x] {
            push(cargs, ty_instantiate_cp(tk, tn, ta, tr, tl, a, subst))
        }
        ty_new_con(tk, tn, ta, tr, tl, tn[x], cargs)
    } else {
        let mut ps = []
        for p in ta[x] {
            push(ps, ty_instantiate_cp(tk, tn, ta, tr, tl, p, subst))
        }
        let ret = ty_instantiate_cp(tk, tn, ta, tr, tl, tr[x], subst)
        ty_new_fn(tk, tn, ta, tr, tl, ps, ret)
    }
}

// scc_groups computes the strongly connected components of the directed
// graph adj (node index -> successor node indices) with Tarjan's algorithm.
// Components come out in completion order, so every component appears after
// the components it points to (callees first); the order is deterministic
// for a given adj.
fn scc_groups(adj) {
    let n = len(adj)
    let mut sidx = []
    let mut slow = []
    let mut onstk = []
    let mut i = 0
    while i < n {
        push(sidx, -1)
        push(slow, 0)
        push(onstk, false)
        i = i + 1
    }
    let mut stk = []
    let mut counter = 0
    let mut comps = []
    fn connect(v) {
        sidx[v] = counter
        slow[v] = counter
        counter = counter + 1
        push(stk, v)
        onstk[v] = true
        for w in adj[v] {
            if sidx[w] < 0 {
                connect(w)
                if slow[w] < slow[v] {
                    slow[v] = slow[w]
                }
            } else if onstk[w] {
                if sidx[w] < slow[v] {
                    slow[v] = sidx[w]
                }
            }
        }
        if slow[v] == sidx[v] {
            let mut comp = []
            let mut more = true
            while more {
                let w = pop(stk)
                onstk[w] = false
                push(comp, w)
                if w == v {
                    more = false
                }
            }
            push(comps, comp)
        }
    }
    i = 0
    while i < n {
        if sidx[i] < 0 {
            connect(i)
        }
        i = i + 1
    }
    comps
}

// typecheck_script checks a script (the non-package form), mirroring
// typecheck() in types.go. All checker state lives in the mut locals below;
// helpers are nested fns closing over it. Mutual-recursion knots
// (infer_expr <-> infer_stmt) go through mut fn cells assigned after both
// sides are defined.
//
fn rec_type_name(names) {
    let mut s = "@rec"
    for n in names {
        s = s + "|" + n
    }
    s
}

fn rec_parse_names(tname) {
    let mut out = []
    let mut i = 5
    let mut cur = ""
    while i < str_len(tname) {
        let c = substr(tname, i, 1)
        if c == "|" {
            push(out, cur)
            cur = ""
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if cur != "" {
        push(out, cur)
    }
    out
}

// Returns Checked(diags, bind_lines, chan_fors):
//   diags       sorted by span start (stable)
//   bind_lines  "bind <name> :: <type>" for every top-level global, sorted
//               by name (only meaningful when there are no errors)
//   chan_fors   span starts of `for` statements that iterate a channel
//               (Go sets ForStmt.IterIsChan on the AST; nodes here are
//               immutable, so the compiler reads this side channel)
pub fn typecheck_script(stmts) {
    typecheck_program([[stmts]], [[""]], false, [""], [[[]]])
}

// typecheck_program checks either a script (is_pkg false: one pseudo
// package with one file "") or a whole module (mirrors typecheckModule +
// checkPackage): packages arrive in dependency order, entry last, each as
// statements per file, display paths per file, and ImportDecls per file.
pub fn typecheck_program(pkgs_stmts, pkgs_fpaths, is_pkg, pkg_paths, pkgs_imports) {
    // ---- state ----
    let mut tk = []
    let mut tn = []
    let mut ta = []
    let mut tr = []
    let mut tl = []
    let mut diags = []
    let mut b_scheme = []
    let mut b_mut = []
    let mut b_used = []
    let mut b_isfn = []
    let mut b_special = []
    let mut b_kind = []
    let mut b_span = []
    let mut b_muts = map()
    let mut b_params = []
    let mut s_vars = []
    let mut s_t = []
    let mut e_qual = []
    let mut e_params = []
    let mut e_variants = []
    let mut enum_by_name = map()
    let mut v_name = []
    let mut v_fields = []
    let mut scopes = []
    let mut level = 0
    let mut ret_tys = []
    // deferred `?` decisions (operand type unknown at the use site, e.g. a
    // call into the current recursion group), flushed per inference group
    // and per top-level statement; parallel lists
    let mut pt_inner = [] // operand type
    let mut pt_ret = [] // enclosing fn's return type
    let mut pt_sp = [] // span of the `?`
    let mut pt_res = [] // placeholder handed back to the caller
    let mut pt_file = []
    let mut try_level = 0 // level deferred vars are pinned to (flush scope)
    // Deferred deep-mut checks, flushed beside deferred `?` decisions. A
    // source with an unresolved type cannot be safely classified as scalar
    // vs heap, so unresolved residuals are E0597 by GOALS §2.
    let mut dm_type = []
    let mut dm_fresh = []
    let mut dm_sp = []
    let mut dm_help = []
    let mut dm_msg = []
    let mut dm_file = []
    let mut chan_fors = []
    let mut cur_file = ""
    let mut diag_files = []
    let mut e_prefix = []
    let mut e_pub = []
    let mut b_pub = []
    let mut b_file = []
    let mut b_ready = [] // false while a top-level fn awaits its inference group
    let mut cur_pkg = "" // import path of the package being checked
    let mut cur_aliases = map() // current file's import aliases (alias -> path)
    let mut pkg_vals = map() // "path.name" -> binding handle, for importers
    let mut pkg_seen = map() // import path -> checked

    // reset the LSP hover side-channel for this check run
    lsp_ty_starts = []
    lsp_ty_ends = []
    lsp_ty_handles = []
    lsp_ty_files = []

    // ---- type helpers ----
    fn fresh(con) {
        ty_new_var(tk, tn, ta, tr, tl, level, con)
    }
    fn con0(name) {
        ty_new_con(tk, tn, ta, tr, tl, name, [])
    }
    fn con1(name, a) {
        ty_new_con(tk, tn, ta, tr, tl, name, [a])
    }
    fn con2(name, a, b) {
        ty_new_con(tk, tn, ta, tr, tl, name, [a, b])
    }
    fn tfn(params, ret) {
        ty_new_fn(tk, tn, ta, tr, tl, params, ret)
    }
    let h_int = con0("int")
    let h_float = con0("float")
    let h_bool = con0("bool")
    let h_str = con0("str")
    let h_unit = con0("unit")

    fn new_scheme(vars, t) {
        push(s_vars, vars)
        push(s_t, t)
        len(s_t) - 1
    }
    fn mono(t) {
        new_scheme([], t)
    }
    fn instantiate(sh) {
        if len(s_vars[sh]) == 0 {
            s_t[sh]
        } else {
            let mut subst = map()
            for v in s_vars[sh] {
                put(subst, v, fresh(tn[v]))
            }
            ty_instantiate_cp(tk, tn, ta, tr, tl, s_t[sh], subst)
        }
    }
    fn generalize(t) {
        let mut vars = []
        let mut seen = map()
        ty_generalize_walk(tk, tn, ta, tr, tl, t, level, vars, seen)
        new_scheme(vars, t)
    }

    // qual_name maps a bare enum name to its globally unique constructor name
    fn qual_name(name) {
        if cur_pkg == "" {
            name
        } else {
            cur_pkg + "." + name
        }
    }

    // ---- diagnostics (each diag records the file it was raised in) ----
    fn cerr(sp, code, help, msg) {
        match sp {
            Sp(s, e) => {
                push(diags, lib.DiagT.Diag(true, code, msg, help, s, e))
                push(diag_files, cur_file)
            },
        }
    }
    fn cwarn(sp, code, help, msg) {
        match sp {
            Sp(s, e) => {
                push(diags, lib.DiagT.Diag(false, code, msg, help, s, e))
                push(diag_files, cur_file)
            },
        }
    }
    // cwarn_fix warns with one structured fix replacing the span itself
    fn cwarn_fix(sp, code, msg, desc, rep) {
        match sp {
            Sp(s, e) => {
                push(diags, lib.DiagT.DiagX(false, code, msg, "", s, e, [], [lib.FixT.Fix(s, e, rep, desc)]))
                push(diag_files, cur_file)
            },
        }
    }
    fn err_pub_script(sp) {
        cerr(sp, "E0449", "`pub` exports items from a package (a directory with bur.mod); remove it here", "`pub` is not allowed here")
    }
    fn unify_at(a, b, sp, context) {
        let e = ty_unify(tk, tn, ta, tr, tl, a, b)
        if e != "" {
            cerr(sp, "E0308", "", "mismatched types " + context + ": " + e)
        }
    }
    fn pretty_of(h) {
        ty_pretty1(tk, tn, ta, tr, h)
    }
    fn check_deep_mut(t, fresh, sp, help, msg) {
        let r = ty_resolve(tk, tr, t)
        if tk[r] == 0 {
            if dm_heap_walk(tk, tn, ta, tr, r) && !fresh {
                cerr(sp, "E0597", help, msg)
            }
        } else if tk[r] == 2 {
            ty_adjust_level(tk, tn, ta, tr, tl, t, try_level)
            push(dm_type, t)
            push(dm_fresh, fresh)
            push(dm_sp, sp)
            push(dm_help, help)
            push(dm_msg, msg)
            push(dm_file, cur_file)
        }
    }

    // ---- scopes and bindings ----
    fn new_binding(sch, is_mut, kind, sp) {
        push(b_scheme, sch)
        push(b_mut, is_mut)
        push(b_used, false)
        push(b_isfn, false)
        push(b_special, "")
        push(b_kind, kind)
        push(b_span, sp)
        push(b_params, [])
        push(b_pub, false)
        push(b_file, cur_file)
        push(b_ready, true)
        put(b_muts, len(b_scheme), [])
        len(b_scheme) - 1
    }
    fn declare(name, sch, is_mut, kind, sp) {
        let bh = new_binding(sch, is_mut, kind, sp)
        put(scopes[len(scopes) - 1], name, bh)
        bh
    }
    fn lookup(name) {
        let mut i = len(scopes) - 1
        while i >= 0 {
            match get(scopes[i], name) {
                Some(bh) => {
                    return bh
                },
                None => {},
            }
            i = i - 1
        }
        -1
    }
    fn push_scope() {
        push(scopes, map())
    }
    fn starts_underscore(name) {
        str_len(name) > 0 && char_at(name, 0) == "_"
    }
    fn pop_scope() {
        let top = scopes[len(scopes) - 1]
        for name in keys(top) {
            match get(top, name) {
                Some(b) => {
                    if !b_used[b] && !starts_underscore(name) && (b_kind[b] == "local" || b_kind[b] == "param" || b_kind[b] == "pattern") {
                        let what = if b_kind[b] == "param" {
                            "parameter"
                        } else {
                            "variable"
                        }
                        cwarn_fix(b_span[b], "unused_variable", "unused " + what + ": `" + name + "`", "if this is intentional, prefix it with an underscore", "_" + name)
                    }
                },
                None => {},
            }
        }
        let _ = pop(scopes)
    }

    // ---- enums ----
    // enum_sig resolves a bare enum name: the current package's enums shadow
    // the builtins (mirrors Checker.enumSig)
    fn enum_sig(name) {
        match get(enum_by_name, qual_name(name)) {
            Some(eh) => eh,
            None => {
                match get(enum_by_name, name) {
                    Some(eh) => if e_prefix[eh] == "" {
                        eh
                    } else {
                        -1
                    },
                    None => -1,
                }
            },
        }
    }

    // alias_path resolves an import alias of the current file; "" = no alias
    fn alias_path(name) {
        match get(cur_aliases, name) {
            Some(p) => p,
            None => "",
        }
    }

    // lookup_pkg_enum resolves an already-alias-resolved pkg path plus enum
    // name to an enum handle, reporting resolution and visibility errors;
    // -1 means an error was already emitted (mirrors Checker.lookupPkgEnum)
    fn lookup_pkg_enum(pkg, name, sp) {
        let known = match get(pkg_seen, pkg) {
            Some(_) => true,
            None => false,
        }
        if !known {
            cerr(sp, "E0433", "", "cannot find package `" + pkg + "`")
            -1
        } else {
            match get(enum_by_name, pkg + "." + name) {
                Some(eh) => {
                    if !e_pub[eh] {
                        cerr(sp, "E0603", "mark it `pub enum " + name + "` to export it", "enum `" + name + "` is private to package `" + pkg + "`")
                        -1
                    } else {
                        eh
                    }
                },
                None => {
                    cerr(sp, "E0412", "", "cannot find enum `" + name + "` in package `" + pkg + "`")
                    -1
                },
            }
        }
    }

    // infer_pkg_access types pkg.name where pkg is an import path (mirrors
    // the Checker's PkgAccess case)
    fn infer_pkg_access(pkg, name, sp) {
        let known = match get(pkg_seen, pkg) {
            Some(_) => true,
            None => false,
        }
        if !known {
            cerr(sp, "E0433", "", "cannot find package `" + pkg + "`")
            fresh("")
        } else {
            match get(pkg_vals, pkg + "." + name) {
                Some(b) => {
                    if !b_pub[b] {
                        cerr(sp, "E0603", "mark it `pub` in package `" + pkg + "` to export it", "`" + name + "` is private to package `" + pkg + "`")
                    }
                    b_used[b] = true
                    instantiate(b_scheme[b])
                },
                None => {
                    let is_enum = match get(enum_by_name, pkg + "." + name) {
                        Some(_) => true,
                        None => false,
                    }
                    if is_enum {
                        cerr(sp, "E0423", "name a variant: `" + pkg + "." + name + ".SomeVariant`", "enum `" + name + "` cannot be used as a value")
                    } else {
                        cerr(sp, "E0425", "", "cannot find `" + name + "` in package `" + pkg + "`")
                    }
                    fresh("")
                },
            }
        }
    }

    fn validate_type_expr(te, pm) {
        match te {
            TEName(pkg, name, constraint, targs, sp) => {
                if constraint != "" {
                    cerr(sp, "E0109", "", "type constraints are only allowed on lowercase type parameters in function signatures")
                }
                if pkg != "" {
                    // the loader already rewrote pkg from alias to import path
                    let eh = lookup_pkg_enum(pkg, name, sp)
                    if eh >= 0 {
                        if len(targs) != len(e_params[eh]) {
                            cerr(sp, "E0107", "", "enum `" + name + "` takes " + str(len(e_params[eh])) + " type argument(s), " + str(len(targs)) + " given")
                        }
                    }
                } else if name == "int" || name == "float" || name == "bool" || name == "str" || name == "unit" {
                    if len(targs) > 0 {
                        cerr(sp, "E0109", "", "`" + name + "` takes no type arguments")
                    }
                } else if name == "chan" {
                    if len(targs) != 1 {
                        cerr(sp, "E0107", "", "`chan` takes exactly one type argument, e.g. chan(int)")
                    }
                } else if name == "map" {
                    if len(targs) != 2 {
                        cerr(sp, "E0107", "", "`map` takes two type arguments, e.g. map(str, int)")
                    }
                } else {
                    let is_param = match get(pm, name) {
                        Some(_) => true,
                        None => false,
                    }
                    if is_param {
                        if len(targs) > 0 {
                            cerr(sp, "E0109", "", "type parameter `" + name + "` takes no arguments")
                        }
                    } else {
                        let sh = enum_sig(name)
                        match if sh >= 0 {
                            Some(sh)
                        } else {
                            None
                        } {
                            Some(eh) => {
                                if len(targs) != len(e_params[eh]) {
                                    cerr(sp, "E0107", "", "enum `" + name + "` takes " + str(len(e_params[eh])) + " type argument(s), " + str(len(targs)) + " given")
                                }
                            },
                            None => cerr(sp, "E0412", "", "cannot find type `" + name + "`"),
                        }
                    }
                }
                for a in targs {
                    validate_type_expr(a, pm)
                }
            },
            TEList(elem, _) => validate_type_expr(elem, pm),
            TEFn(ps, ret, _) => {
                for p in ps {
                    validate_type_expr(p, pm)
                }
                validate_type_expr(ret, pm)
            },
            TERecord(_, ftypes, row, _) => {
                for ft in ftypes {
                    validate_type_expr(ft, pm)
                }
                match row {
                    NoNode => {},
                    _ => validate_type_expr(row, pm),
                }
            },
            _ => {},
        }
    }

    // register_enum records the enum's name and variants; "" on a duplicate
    // (the caller skips field validation then). Field types are validated
    // separately by validate_enum_fields once every enum in the package is
    // registered, so fields may reference enums from any file in any order.
    fn register_enum(n) {
        match n {
            EnumDecl(name, params, variants, is_pub, sp) => {
                let qual = qual_name(name)
                let dup = match get(enum_by_name, qual) {
                    Some(_) => true,
                    None => false,
                }
                if dup {
                    cerr(sp, "E0428", "", "enum `" + name + "` is declared more than once")
                    false
                } else {
                    let mut vhs = []
                    for vd in variants {
                        match vd {
                            EnumVariantDecl(vn, _, vtypes, _) => {
                                push(v_name, vn)
                                push(v_fields, vtypes)
                                push(vhs, len(v_name) - 1)
                            },
                            _ => {},
                        }
                    }
                    push(e_qual, qual)
                    push(e_params, params)
                    push(e_variants, vhs)
                    push(e_prefix, cur_pkg)
                    push(e_pub, is_pub)
                    put(enum_by_name, qual, len(e_qual) - 1)
                    true
                }
            },
            _ => false,
        }
    }

    fn validate_enum_fields(n) {
        match n {
            EnumDecl(_, params, variants, _, _) => {
                let mut pm = map()
                for p in params {
                    put(pm, p, true)
                }
                for vd in variants {
                    match vd {
                        EnumVariantDecl(_, _, vtypes, _) => {
                            for te in vtypes {
                                validate_type_expr(te, pm)
                            }
                        },
                        _ => {},
                    }
                }
            },
            _ => {},
        }
    }

    // convert_type_expr lowers a written type to a handle; subst maps type
    // parameter names to handles. prefix is the defining package of the enum
    // whose fields are being converted: bare enum names resolve against it.
    // Function annotations collect lowercase names into subst before calling
    // this helper, so a written `a` remains the same type variable throughout
    // one signature.
    fn convert_type_expr(te, subst, prefix) {
        match te {
            TEName(pkg, name, _, targs, _) => {
                let hit = if pkg == "" {
                    match get(subst, name) {
                        Some(t) => t,
                        None => -1,
                    }
                } else {
                    -1
                }
                if hit >= 0 {
                    hit
                } else {
                    let mut cargs = []
                    for a in targs {
                        push(cargs, convert_type_expr(a, subst, prefix))
                    }
                    let full = if pkg != "" {
                        let actual_pkg = match get(cur_aliases, pkg) {
                            Some(path) => path,
                            None => pkg,
                        }
                        actual_pkg + "." + name
                    } else if name == "int" || name == "float" || name == "bool" || name == "str" || name == "unit" || name == "chan" || name == "map" {
                        name
                    } else {
                        let local = match get(enum_by_name, prefix + "." + name) {
                            Some(_) => prefix != "",
                            None => false,
                        }
                        if local {
                            prefix + "." + name
                        } else {
                            name
                        }
                    }
                    ty_new_con(tk, tn, ta, tr, tl, full, cargs)
                }
            },
            TEList(elem, _) => con1("list", convert_type_expr(elem, subst, prefix)),
            TEFn(ps, ret, _) => {
                let mut phs = []
                for p in ps {
                    push(phs, convert_type_expr(p, subst, prefix))
                }
                tfn(phs, convert_type_expr(ret, subst, prefix))
            },
            TERecord(fnames, ftypes, _, _) => {
                let mut fhs = []
                for ft in ftypes {
                    push(fhs, convert_type_expr(ft, subst, prefix))
                }
                ty_new_con(tk, tn, ta, tr, tl, rec_type_name(fnames), fhs)
            },
            _ => h_unit,
        }
    }

    fn collect_annotation_vars(te, mut subst) {
        match te {
            TEName(pkg, name, constraint, targs, sp) => {
                let is_builtin = name == "int" || name == "float" || name == "bool" || name == "str" || name == "unit" || name == "chan" || name == "map"
                let is_var = pkg == "" && !is_builtin && str_len(name) > 0 && byte_at(name, 0) >= 97 && byte_at(name, 0) <= 122
                if constraint != "" && !is_var {
                    cerr(sp, "E0109", "", "type constraints are only allowed on lowercase type parameters")
                }
                if is_var {
                    if len(targs) > 0 {
                        cerr(sp, "E0109", "", "type parameter `" + name + "` takes no arguments")
                    }
                    let valid_constraint = constraint == "" || len(con_set(constraint)) > 0
                    if !valid_constraint {
                        cerr(sp, "E0412", "", "cannot find type constraint `" + constraint + "`")
                    }
                    let actual_constraint = if valid_constraint {
                        constraint
                    } else {
                        ""
                    }
                    match get(subst, name) {
                        Some(existing) => {
                            if actual_constraint != "" {
                                unify_at(existing, fresh(actual_constraint), sp, "between constraints on type parameter `" + name + "`")
                            }
                        },
                        None => put(subst, name, fresh(actual_constraint)),
                    }
                }
                for arg in targs {
                    collect_annotation_vars(arg, subst)
                }
            },
            TEList(elem, _) => collect_annotation_vars(elem, subst),
            TEFn(params, ret, _) => {
                for param in params {
                    collect_annotation_vars(param, subst)
                }
                collect_annotation_vars(ret, subst)
            },
            TERecord(_, ftypes, row, _) => {
                for ft in ftypes {
                    collect_annotation_vars(ft, subst)
                }
                match row {
                    NoNode => {},
                    _ => collect_annotation_vars(row, subst),
                }
            },
            _ => {},
        }
    }

    fn is_type_expr_node(n) {
        match n {
            TEName(_, _, _, _, _) => true,
            TEList(_, _) => true,
            TEFn(_, _, _) => true,
            TERecord(_, _, _, _) => true,
            _ => false,
        }
    }

    fn iface_var_name(i) {
        if i < 26 {
            chr(97 + i)
        } else {
            "t" + str(i)
        }
    }

    fn iface_enum_name(eh) {
        let prefix = e_prefix[eh]
        if prefix == "" {
            e_qual[eh]
        } else {
            substr(e_qual[eh], str_len(prefix) + 1, str_len(e_qual[eh]) - str_len(prefix) - 1)
        }
    }

    fn iface_collect_type(h, mut local_enums, mut external_pkgs) {
        let x = ty_resolve(tk, tr, h)
        if tk[x] == 0 {
            match get(enum_by_name, tn[x]) {
                Some(eh) => {
                    if e_prefix[eh] == cur_pkg {
                        put(local_enums, eh, true)
                    } else if e_prefix[eh] != "" {
                        put(external_pkgs, e_prefix[eh], true)
                    }
                },
                None => {},
            }
            for a in ta[x] {
                iface_collect_type(a, local_enums, external_pkgs)
            }
        } else if tk[x] == 1 {
            for p in ta[x] {
                iface_collect_type(p, local_enums, external_pkgs)
            }
            iface_collect_type(tr[x], local_enums, external_pkgs)
        }
    }

    fn iface_collect_te(te, mut local_enums, mut external_pkgs) {
        match te {
            TEName(pkg, name, _, targs, _) => {
                if pkg == "" {
                    match get(enum_by_name, cur_pkg + "." + name) {
                        Some(eh) => put(local_enums, eh, true),
                        None => {},
                    }
                } else if pkg == cur_pkg {
                    match get(enum_by_name, pkg + "." + name) {
                        Some(eh) => put(local_enums, eh, true),
                        None => {},
                    }
                } else {
                    put(external_pkgs, pkg, true)
                }
                for a in targs {
                    iface_collect_te(a, local_enums, external_pkgs)
                }
            },
            TEList(elem, _) => iface_collect_te(elem, local_enums, external_pkgs),
            TEFn(params, ret, _) => {
                for p in params {
                    iface_collect_te(p, local_enums, external_pkgs)
                }
                iface_collect_te(ret, local_enums, external_pkgs)
            },
            TERecord(_, ftypes, row, _) => {
                for ft in ftypes {
                    iface_collect_te(ft, local_enums, external_pkgs)
                }
                match row {
                    NoNode => {},
                    _ => iface_collect_te(row, local_enums, external_pkgs),
                }
            },
            _ => {},
        }
    }

    fn iface_render_te(te, aliases) {
        match te {
            TEName(pkg, name, constraint, targs, _) => {
                let mut out = if pkg == "" || pkg == cur_pkg {
                    name
                } else {
                    match get(aliases, pkg) {
                        Some(alias) => alias + "." + name,
                        None => name,
                    }
                }
                if constraint != "" {
                    out = out + ":" + constraint
                }
                if len(targs) > 0 {
                    let mut args = []
                    for a in targs {
                        push(args, iface_render_te(a, aliases))
                    }
                    out = out + "(" + join(args, ", ") + ")"
                }
                out
            },
            TEList(elem, _) => "[" + iface_render_te(elem, aliases) + "]",
            TEFn(params, ret, _) => {
                let mut ps = []
                for p in params {
                    push(ps, iface_render_te(p, aliases))
                }
                "fn(" + join(ps, ", ") + ") -> " + iface_render_te(ret, aliases)
            },
            TERecord(fnames, ftypes, row, _) => {
                let mut fields = []
                let mut i = 0
                while i < len(fnames) {
                    push(fields, fnames[i] + ": " + iface_render_te(ftypes[i], aliases))
                    i = i + 1
                }
                match row {
                    NoNode => "record " + chr(123) + " " + join(fields, ", ") + " " + chr(125),
                    _ => "record " + chr(123) + " " + join(fields, ", ") + " | " + iface_render_te(row, aliases) + " " + chr(125),
                }
            },
            _ => "unit",
        }
    }

    fn iface_render_type(h, aliases, mut var_names, mut shown, mut next_var) {
        let x = ty_resolve(tk, tr, h)
        if tk[x] == 2 {
            let name = match get(var_names, x) {
                Some(n) => n,
                None => {
                    let n = iface_var_name(next_var[0])
                    next_var[0] = next_var[0] + 1
                    put(var_names, x, n)
                    n
                },
            }
            let was_shown = match get(shown, x) {
                Some(_) => true,
                None => false,
            }
            if !was_shown {
                put(shown, x, true)
            }
            if !was_shown && tn[x] != "" {
                name + ":" + tn[x]
            } else {
                name
            }
        } else if tk[x] == 1 {
            let mut ps = []
            for p in ta[x] {
                push(ps, iface_render_type(p, aliases, var_names, shown, next_var))
            }
            "fn(" + join(ps, ", ") + ") -> " + iface_render_type(tr[x], aliases, var_names, shown, next_var)
        } else if tn[x] == "list" && len(ta[x]) == 1 {
            "[" + iface_render_type(ta[x][0], aliases, var_names, shown, next_var) + "]"
        } else {
            let mut name = tn[x]
            match get(enum_by_name, tn[x]) {
                Some(eh) => {
                    if e_prefix[eh] == cur_pkg || e_prefix[eh] == "" {
                        name = iface_enum_name(eh)
                    } else {
                        name = match get(aliases, e_prefix[eh]) {
                            Some(alias) => alias + "." + iface_enum_name(eh),
                            None => iface_enum_name(eh),
                        }
                    }
                },
                None => {},
            }
            if len(ta[x]) == 0 {
                name
            } else {
                let mut args = []
                for a in ta[x] {
                    push(args, iface_render_type(a, aliases, var_names, shown, next_var))
                }
                name + "(" + join(args, ", ") + ")"
            }
        }
    }

    fn iface_type_context(sh) {
        let mut names = map()
        let mut i = 0
        while i < len(s_vars[sh]) {
            put(names, s_vars[sh][i], iface_var_name(i))
            i = i + 1
        }
        names
    }

    fn iface_render_enum(eh, aliases) {
        let mut out = if e_pub[eh] {
            "pub enum "
        } else {
            "enum "
        }
        out = out + iface_enum_name(eh)
        if len(e_params[eh]) > 0 {
            out = out + "(" + join(e_params[eh], ", ") + ")"
        }
        out = out + " " + chr(123) + "\n"
        for vh in e_variants[eh] {
            out = out + "    " + v_name[vh]
            if len(v_fields[vh]) > 0 {
                let mut fields = []
                for field in v_fields[vh] {
                    push(fields, iface_render_te(field, aliases))
                }
                out = out + "(" + join(fields, ", ") + ")"
            }
            out = out + ",\n"
        }
        out + "}"
    }

    fn iface_render_binding(name, b, aliases) {
        let sh = b_scheme[b]
        let mut vars = iface_type_context(sh)
        let mut shown = map()
        let mut next_var = [len(s_vars[sh])]
        let root = ty_resolve(tk, tr, s_t[sh])
        if b_isfn[b] && tk[root] == 1 {
            let mut params = []
            let masks = match get(b_muts, b) {
                Some(ms) => ms,
                None => [],
            }
            let mut i = 0
            while i < len(ta[root]) {
                let pname = if i < len(b_params[b]) {
                    b_params[b][i]
                } else {
                    "p" + str(i)
                }
                let mut prefix = ""
                if i < len(masks) && masks[i] {
                    prefix = "mut "
                }
                push(params, prefix + pname + ": " + iface_render_type(ta[root][i], aliases, vars, shown, next_var))
                i = i + 1
            }
            "pub fn " + name + "(" + join(params, ", ") + ") -> " + iface_render_type(tr[root], aliases, vars, shown, next_var)
        } else {
            "pub let " + name + ": " + iface_render_type(root, aliases, vars, shown, next_var)
        }
    }

    fn render_package_interface(top) {
        let mut local_enums = map()
        let mut external_pkgs = map()
        let mut eh = 0
        while eh < len(e_qual) {
            if e_prefix[eh] == cur_pkg && e_pub[eh] {
                put(local_enums, eh, true)
            }
            eh = eh + 1
        }
        let mut export_names = []
        for name in keys(top) {
            match get(top, name) {
                Some(b) => {
                    if b_pub[b] {
                        push(export_names, name)
                        iface_collect_type(s_t[b_scheme[b]], local_enums, external_pkgs)
                    }
                },
                None => {},
            }
        }
        let mut growing = true
        while growing {
            let before = len(keys(local_enums))
            for idx in keys(local_enums) {
                for vh in e_variants[idx] {
                    for field in v_fields[vh] {
                        iface_collect_te(field, local_enums, external_pkgs)
                    }
                }
            }
            growing = len(keys(local_enums)) > before
        }
        let paths = sort_strs(keys(external_pkgs))
        let mut aliases = map()
        let mut imports = []
        let mut i = 0
        while i < len(paths) {
            let alias = "i" + str(i)
            put(aliases, paths[i], alias)
            push(imports, "import " + alias + " \"" + paths[i] + "\"")
            i = i + 1
        }
        let mut enum_names = []
        let mut enum_by_short = map()
        for idx in keys(local_enums) {
            let name = iface_enum_name(idx)
            push(enum_names, name)
            put(enum_by_short, name, idx)
        }
        let mut decls = []
        for name in sort_strs(enum_names) {
            match get(enum_by_short, name) {
                Some(idx) => push(decls, iface_render_enum(idx, aliases)),
                None => {},
            }
        }
        for name in sort_strs(export_names) {
            match get(top, name) {
                Some(b) => push(decls, iface_render_binding(name, b, aliases)),
                None => {},
            }
        }
        let mut out = ""
        if len(imports) > 0 {
            out = join(imports, "\n") + "\n"
            if len(decls) > 0 {
                out = out + "\n"
            }
        }
        if len(decls) > 0 {
            out = out + join(decls, "\n\n") + "\n"
        }
        out
    }

    // instantiate_enum fills subst with fresh vars for the enum's parameters
    // and returns the enum type handle
    fn instantiate_enum(eh, mut subst) {
        let mut cargs = []
        for p in e_params[eh] {
            let v = fresh("")
            put(subst, p, v)
            push(cargs, v)
        }
        ty_new_con(tk, tn, ta, tr, tl, e_qual[eh], cargs)
    }

    fn variant_type(eh, idx) {
        let mut subst = map()
        let enum_ty = instantiate_enum(eh, subst)
        let vh = e_variants[eh][idx]
        if len(v_fields[vh]) == 0 {
            enum_ty
        } else {
            let mut fields = []
            for f in v_fields[vh] {
                push(fields, convert_type_expr(f, subst, e_prefix[eh]))
            }
            tfn(fields, enum_ty)
        }
    }

    // find_variant_sig resolves a bare variant name; returns [eh, idx]:
    // eh = -1 not found, eh = -2 ambiguous
    fn find_variant_sig(name) {
        let mut found = -1
        let mut idx = -1
        let mut amb = false
        for q in keys(enum_by_name) {
            match get(enum_by_name, q) {
                Some(eh) => {
                    if e_prefix[eh] == cur_pkg || e_prefix[eh] == "" {
                        let mut i = 0
                        while i < len(e_variants[eh]) {
                            if v_name[e_variants[eh][i]] == name {
                                if found >= 0 {
                                    amb = true
                                }
                                found = eh
                                idx = i
                            }
                            i = i + 1
                        }
                    }
                },
                None => {},
            }
        }
        if amb {
            [-2, -1]
        } else {
            [found, idx]
        }
    }

    // ---- free-name scan (dependency edges for SCC inference order) ----
    fn scan_bound(sc, name) {
        let mut i = len(sc) - 1
        let mut hit = false
        while i >= 0 {
            match get(sc[i], name) {
                Some(_) => {
                    hit = true
                    i = -1
                },
                None => {
                    i = i - 1
                },
            }
        }
        hit
    }
    fn scan_bind(mut sc, name) {
        put(sc[len(sc) - 1], name, true)
    }
    // scan_free collects the names decl body n references without binding
    // them locally, in first-occurrence order; the caller keeps the ones
    // that resolve to top-level fns of the package. sc is the local scope
    // stack (innermost last). Binding forms mirror infer_expr/infer_stmt,
    // including the bare-name pattern that only binds when it is not a
    // known variant (the checker's catch-all case).
    fn scan_free(n, mut sc, mut seen, mut out) {
        match n {
            Ident(name, _) => {
                if !scan_bound(sc, name) {
                    let dup = match get(seen, name) {
                        Some(_) => true,
                        None => false,
                    }
                    if !dup {
                        put(seen, name, true)
                        push(out, name)
                    }
                }
            },
            Unary(_, e, _) => scan_free(e, sc, seen, out),
            TryExpr(e, _) => scan_free(e, sc, seen, out),
            RecvExpr(e, _) => scan_free(e, sc, seen, out),
            RecordLit(_, vals, _) => {
                for v in vals {
                    scan_free(v, sc, seen, out)
                }
            },
            RecordUpdate(base, _, vals, _) => {
                scan_free(base, sc, seen, out)
                for v in vals {
                    scan_free(v, sc, seen, out)
                }
            },
            FieldAccess(base, _, _) => scan_free(base, sc, seen, out),
            TypeAliasDecl(_, _, _, _) => {},
            ExprStmt(e, _) => scan_free(e, sc, seen, out),
            SpawnStmt(e, _) => scan_free(e, sc, seen, out),
            DeferStmt(e, _) => scan_free(e, sc, seen, out),
            ReturnStmt(e, _) => scan_free(e, sc, seen, out),
            Binary(_, l, r, _) => {
                scan_free(l, sc, seen, out)
                scan_free(r, sc, seen, out)
            },
            Logical(_, l, r, _) => {
                scan_free(l, sc, seen, out)
                scan_free(r, sc, seen, out)
            },
            Index(l, r, _) => {
                scan_free(l, sc, seen, out)
                scan_free(r, sc, seen, out)
            },
            SendStmt(l, r, _) => {
                scan_free(l, sc, seen, out)
                scan_free(r, sc, seen, out)
            },
            AssignStmt(l, r, _) => {
                scan_free(l, sc, seen, out)
                scan_free(r, sc, seen, out)
            },
            WhileStmt(l, r, _) => {
                scan_free(l, sc, seen, out)
                scan_free(r, sc, seen, out)
            },
            Call(callee, cargs, _) => {
                scan_free(callee, sc, seen, out)
                for a in cargs {
                    scan_free(a, sc, seen, out)
                }
            },
            ListLit(elems, _) => {
                for a in elems {
                    scan_free(a, sc, seen, out)
                }
            },
            IfExpr(c, t, e, _) => {
                scan_free(c, sc, seen, out)
                scan_free(t, sc, seen, out)
                scan_free(e, sc, seen, out)
            },
            FnLit(params, _, _, _, _, body, _, _) => {
                push(sc, map())
                for p in params {
                    scan_bind(sc, p)
                }
                scan_free(body, sc, seen, out)
                let _ = pop(sc)
            },
            Block(stmts, _) => {
                push(sc, map())
                for s in stmts {
                    scan_free(s, sc, seen, out)
                }
                let _ = pop(sc)
            },
            LetStmt(name, _, _, _, init, _) => {
                scan_free(init, sc, seen, out)
                scan_bind(sc, name)
            },
            FnDecl(name, _, _, lit, _) => {
                scan_bind(sc, name)
                scan_free(lit, sc, seen, out)
            },
            ForStmt(v, _, iter, _, body, _) => {
                scan_free(iter, sc, seen, out)
                push(sc, map())
                scan_bind(sc, v)
                scan_free(body, sc, seen, out)
                let _ = pop(sc)
            },
            MatchExpr(scrut, arms, _) => {
                scan_free(scrut, sc, seen, out)
                for arm in arms {
                    scan_free(arm, sc, seen, out)
                }
            },
            MatchArm(pat, guard, body, _) => {
                push(sc, map())
                scan_free(pat, sc, seen, out)
                scan_free(guard, sc, seen, out)
                scan_free(body, sc, seen, out)
                let _ = pop(sc)
            },
            PatBinding(name, _) => {
                let fv = find_variant_sig(name)
                if fv[0] == -1 {
                    scan_bind(sc, name)
                }
            },
            PatVariant(_, _, _, binds, _) => {
                for pb in binds {
                    match pb {
                        PatBinding(bn, _) => scan_bind(sc, bn),
                        _ => {},
                    }
                }
            },
            SelectStmt(arms, _, dflt, _, _) => {
                for arm in arms {
                    scan_free(arm, sc, seen, out)
                }
                scan_free(dflt, sc, seen, out)
            },
            SelectArm(is_send, bind, _, ch, val, body, _) => {
                scan_free(ch, sc, seen, out)
                scan_free(val, sc, seen, out)
                push(sc, map())
                if !is_send && bind != "" && bind != "_" {
                    scan_bind(sc, bind)
                }
                scan_free(body, sc, seen, out)
                let _ = pop(sc)
            },
            _ => {},
        }
    }

    // require_mut_root walks an index chain back to its root binding and
    // enforces deep mut
    fn require_mut_root(e0, what) {
        let mut root = e0
        let mut walking = true
        while walking {
            match root {
                Index(t, _, _) => {
                    root = t
                },
                _ => {
                    walking = false
                },
            }
        }
        // an alias-headed access is a package binding (Go sees PkgAccess here)
        let name = match root {
            Ident(n, _) => n,
            VariantAccess(en, vn, _) => if alias_path(en) != "" {
                vn
            } else {
                ""
            },
            PkgAccess(_, pn, _) => pn,
            _ => "",
        }
        let b = match root {
            Ident(n, _) => lookup(n),
            VariantAccess(en, vn, _) => {
                let ap = alias_path(en)
                if ap != "" {
                    match get(pkg_vals, ap + "." + vn) {
                        Some(bh) => bh,
                        None => -1,
                    }
                } else {
                    -1
                }
            },
            PkgAccess(pp, pn, _) => {
                match get(pkg_vals, pp + "." + pn) {
                    Some(bh) => bh,
                    None => -1,
                }
            },
            _ => -1,
        }
        if name != "" {
            if b >= 0 && !b_mut[b] {
                let help = if b_kind[b] == "param" {
                    "declare the parameter as mutable: `mut " + name + "`"
                } else {
                    "make this binding mutable: `let mut " + name + "`"
                }
                cerr(span_of(e0), "E0596", help, "cannot " + what + ", as `" + name + "` is not declared as mutable")
            }
        }
    }

    // ---- inference (the infer_expr <-> infer_stmt knot goes through cells) ----
    let mut infer_expr_ref = fn(_e) {
        0
    }
    let mut infer_stmt_ref = fn(_s) {}

    // statements of a while/for body: every statement is a statement (a
    // trailing expression is not a block value here)
    fn infer_block_stmts(blk) {
        match blk {
            Block(ss, _) => {
                for s in ss {
                    infer_stmt_ref(s)
                }
            },
            _ => {},
        }
    }

    fn infer_block_noscope(blk) {
        match blk {
            Block(ss, _) => {
                let n = len(ss)
                let mut i = 0
                let mut t = h_unit
                while i < n {
                    let s = ss[i]
                    let is_last_expr = if i == n - 1 {
                        match s {
                            ExprStmt(_, _) => true,
                            _ => false,
                        }
                    } else {
                        false
                    }
                    if is_last_expr {
                        match s {
                            ExprStmt(e, _) => {
                                t = infer_expr_ref(e)
                            },
                            _ => {},
                        }
                    } else {
                        infer_stmt_ref(s)
                    }
                    i = i + 1
                }
                t
            },
            _ => h_unit,
        }
    }

    fn infer_block_expr(blk) {
        push_scope()
        let t = infer_block_noscope(blk)
        pop_scope()
        t
    }

    fn infer_let_init(init) {
        let is_fnlit = match init {
            FnLit(_, _, _, _, _, _, _, _) => true,
            _ => false,
        }
        if is_fnlit {
            level = level + 1
            let t = infer_expr_ref(init)
            level = level - 1
            t
        } else {
            infer_expr_ref(init)
        }
    }

    fn infer_call(callee, cargs, csp) {
        let callee_name = match callee {
            Ident(n, _) => n,
            VariantAccess(pkg, n, _) => {
                let path = alias_path(pkg)
                if path == "" {
                    ""
                } else {
                    pkg + "." + n
                }
            },
            PkgAccess(path, n, _) => path + "." + n,
            _ => "",
        }
        let callee_b = match callee {
            Ident(n, _) => lookup(n),
            VariantAccess(pkg, n, _) => {
                let path = alias_path(pkg)
                if path == "" {
                    -1
                } else {
                    match get(pkg_vals, path + "." + n) {
                        Some(h) => h,
                        None => -1,
                    }
                }
            },
            PkgAccess(path, n, _) => {
                match get(pkg_vals, path + "." + n) {
                    Some(h) => h,
                    None => -1,
                }
            },
            _ => -1,
        }
        if (callee_name == "push" || callee_name == "pop" || callee_name == "put" || callee_name == "delete") && len(cargs) > 0 {
            let b = lookup(callee_name)
            if b >= 0 && b_kind[b] == "native" {
                require_mut_root(cargs[0], "mutate this list with `" + callee_name + "()`")
            }
        }
        // special-cased natives
        let mut special = ""
        let mut special_b = -1
        if callee_name != "" {
            let b = lookup(callee_name)
            if b >= 0 && b_special[b] != "" {
                special = b_special[b]
                special_b = b
            }
        }
        if special == "printf" {
            // print/println: variadic, any types
            b_used[special_b] = true
            for a in cargs {
                let _ = infer_expr_ref(a)
            }
            h_unit
        } else if special == "chan" {
            b_used[special_b] = true
            if len(cargs) > 1 {
                cerr(csp, "E0061", "", "chan() takes at most one argument (the capacity)")
            }
            for a in cargs {
                let at = infer_expr_ref(a)
                unify_at(at, h_int, span_of(a), "as the channel capacity")
            }
            con1("chan", fresh(""))
        } else {
            let ct = infer_expr_ref(callee)
            let mut ahs = []
            for a in cargs {
                push(ahs, infer_expr_ref(a))
            }
            // better arity errors when the callee type is already concrete
            let rf = ty_resolve(tk, tr, ct)
            if tk[rf] == 1 && len(ta[rf]) != len(ahs) {
                cerr(csp, "E0061", "", "this call takes " + str(len(ta[rf])) + " argument(s) but " + str(len(ahs)) + " were supplied")
                tr[rf]
            } else {
                let ret = fresh("")
                unify_at(ct, tfn(ahs, ret), csp, "in this call")
                let rf2 = ty_resolve(tk, tr, ct)
                if tk[rf2] == 1 && callee_name != "" {
                    let cmuts = if callee_b >= 0 {
                        match get(b_muts, callee_b) {
                            Some(m) => m,
                            None => [],
                        }
                    } else {
                        []
                    }
                    let mut ci = 0
                    while ci < len(ahs) && ci < len(cmuts) {
                        if cmuts[ci] {
                            let fresh = is_fresh_source(cargs[ci], lookup, b_mut, b_kind, map())
                            check_deep_mut(ta[rf2][ci], fresh, span_of(cargs[ci]), "pass a fresh heap source (literal, call return, or enum ctor); a non-mut binding aliases its value and mutations inside `" + callee_name + "` would be visible through the source", "cannot pass a non-fresh heap source as mutable argument to `" + callee_name + "`")
                        }
                        ci = ci + 1
                    }
                }
                ret
            }
        }
    }

    fn infer_try(inner, tsp) {
        let t = infer_expr_ref(inner)
        if len(ret_tys) == 0 {
            cerr(tsp, "E0277", "", "`?` can only be used inside a function")
            return fresh("")
        }
        let ret = ret_tys[len(ret_tys) - 1]
        let r = ty_resolve(tk, tr, t)
        if tk[r] == 0 && tn[r] == "Result" {
            let e = fresh("")
            let ok = fresh("")
            unify_at(t, con2("Result", ok, e), tsp, "with `?`")
            let b = fresh("")
            unify_at(ret, con2("Result", b, e), tsp, "with `?` (the enclosing function must return a Result with the same error type)")
            ok
        } else if tk[r] == 0 && tn[r] == "Option" {
            let v = fresh("")
            unify_at(t, con1("Option", v), tsp, "with `?`")
            let b = fresh("")
            unify_at(ret, con1("Option", b), tsp, "with `?` (the enclosing function must return an Option)")
            v
        } else if tk[r] == 2 {
            // operand type still unknown (e.g. a call into the current
            // recursion group): defer the Option/Result decision until the
            // group is fully inferred. Pin the involved vars to the flush
            // scope so no inner generalization quantifies them first
            let res = fresh("")
            ty_adjust_level(tk, tn, ta, tr, tl, t, try_level)
            ty_adjust_level(tk, tn, ta, tr, tl, ret, try_level)
            ty_adjust_level(tk, tn, ta, tr, tl, res, try_level)
            push(pt_inner, t)
            push(pt_ret, ret)
            push(pt_sp, tsp)
            push(pt_res, res)
            push(pt_file, cur_file)
            res
        } else {
            cerr(tsp, "E0277", "", "`?` needs an `Option` or `Result`, found `" + pretty_of(t) + "`")
            fresh("")
        }
    }

    // flush_tries settles the deferred `?` decisions collected since the
    // last flush, iterating because one settlement can resolve another's
    // operand; whatever stays unresolved is a genuine error
    fn flush_tries() {
        let mut done = []
        let mut i = 0
        while i < len(pt_inner) {
            push(done, false)
            i = i + 1
        }
        let mut progress = true
        while progress {
            progress = false
            i = 0
            while i < len(pt_inner) {
                if !done[i] {
                    let r = ty_resolve(tk, tr, pt_inner[i])
                    if tk[r] == 0 && tn[r] == "Result" {
                        cur_file = pt_file[i]
                        let e = fresh("")
                        unify_at(pt_inner[i], con2("Result", pt_res[i], e), pt_sp[i], "with `?`")
                        let b = fresh("")
                        unify_at(pt_ret[i], con2("Result", b, e), pt_sp[i], "with `?` (the enclosing function must return a Result with the same error type)")
                        done[i] = true
                        progress = true
                    } else if tk[r] == 0 && tn[r] == "Option" {
                        cur_file = pt_file[i]
                        unify_at(pt_inner[i], con1("Option", pt_res[i]), pt_sp[i], "with `?`")
                        let b = fresh("")
                        unify_at(pt_ret[i], con1("Option", b), pt_sp[i], "with `?` (the enclosing function must return an Option)")
                        done[i] = true
                        progress = true
                    } else if tk[r] != 2 {
                        cur_file = pt_file[i]
                        cerr(pt_sp[i], "E0277", "", "`?` needs an `Option` or `Result`, found `" + pretty_of(pt_inner[i]) + "`")
                        done[i] = true
                        progress = true
                    }
                }
                i = i + 1
            }
        }
        i = 0
        while i < len(pt_inner) {
            if !done[i] {
                cur_file = pt_file[i]
                cerr(pt_sp[i], "E0277", "make the operand's Option/Result type visible, e.g. via a match or an explicit Ok/Some in the callee", "cannot infer whether `?` operates on an `Option` or a `Result` here")
            }
            i = i + 1
        }
        pt_inner = []
        pt_ret = []
        pt_sp = []
        pt_res = []
        pt_file = []
    }

    fn flush_deep_mut() {
        let mut i = 0
        while i < len(dm_type) {
            cur_file = dm_file[i]
            let r = ty_resolve(tk, tr, dm_type[i])
            if tk[r] == 0 {
                if dm_heap_walk(tk, tn, ta, tr, r) && !dm_fresh[i] {
                    cerr(dm_sp[i], "E0597", dm_help[i], dm_msg[i])
                }
            } else if tk[r] == 2 {
                cerr(dm_sp[i], "E0597", "make the source type concrete before binding or passing it mutably", "cannot prove this mutable source is not an aliased heap value")
            }
            i = i + 1
        }
        dm_type = []
        dm_fresh = []
        dm_sp = []
        dm_help = []
        dm_msg = []
        dm_file = []
    }

    fn infer_match(scrut, arms, msp) {
        let scrut_t = infer_expr_ref(scrut)
        let res_t = fresh("")
        let mut covered = map() // variant names / "true"/"false"
        let mut has_catch_all = false

        for arm in arms {
            match arm {
                MatchArm(pat, guard, body, _) => {
                    push_scope()
                    let unguarded = match guard {
                        NoNode => true,
                        _ => false,
                    }
                    match pat {
                        PatWildcard(_) => {
                            if unguarded {
                                has_catch_all = true
                            }
                        },
                        PatLiteral(v, psp) => {
                            let lt = match v {
                                IntLit(_, _) => h_int,
                                FloatLit(_, _) => h_float,
                                StrLit(_, _) => h_str,
                                BoolLit(bv, _) => {
                                    if unguarded {
                                        put(covered, str(bv), true)
                                    }
                                    h_bool
                                },
                                _ => fresh(""),
                            }
                            unify_at(scrut_t, lt, psp, "between this pattern and the matched value")
                        },
                        PatBinding(name, psp) => {
                            let fv = find_variant_sig(name)
                            if fv[0] == -2 {
                                cerr(psp, "E0659", "qualify it, e.g. `SomeEnum." + name + "`", "`" + name + "` is a variant of several enums")
                            } else if fv[0] >= 0 && len(v_fields[e_variants[fv[0]][fv[1]]]) == 0 {
                                let mut subst = map()
                                let enum_ty = instantiate_enum(fv[0], subst)
                                unify_at(scrut_t, enum_ty, psp, "between this pattern and the matched value")
                                if unguarded {
                                    put(covered, name, true)
                                }
                            } else if fv[0] >= 0 {
                                cerr(psp, "E0532", "", "variant `" + name + "` has " + str(len(v_fields[e_variants[fv[0]][fv[1]]])) + " field(s); bind them: `" + name + "(...)`")
                            } else {
                                if unguarded {
                                    has_catch_all = true
                                }
                                let _ = declare(name, mono(scrut_t), false, "pattern", psp)
                            }
                        },
                        PatVariant(ppkg, penum, pvar, binds, psp) => {
                            let mut eh = -1
                            let mut idx = -1
                            if ppkg != "" {
                                let apath = alias_path(ppkg)
                                if apath == "" {
                                    cerr(psp, "E0433", "", "cannot find package `" + ppkg + "`")
                                } else {
                                    let h = lookup_pkg_enum(apath, penum, psp)
                                    if h >= 0 {
                                        let mut i = 0
                                        while i < len(e_variants[h]) {
                                            if v_name[e_variants[h][i]] == pvar {
                                                idx = i
                                            }
                                            i = i + 1
                                        }
                                        if idx < 0 {
                                            cerr(psp, "E0599", "", "enum `" + penum + "` has no variant `" + pvar + "`")
                                        } else {
                                            eh = h
                                        }
                                    }
                                }
                            } else if penum != "" {
                                let sh = enum_sig(penum)
                                match if sh >= 0 {
                                    Some(sh)
                                } else {
                                    None
                                } {
                                    Some(h) => {
                                        let mut i = 0
                                        while i < len(e_variants[h]) {
                                            if v_name[e_variants[h][i]] == pvar {
                                                idx = i
                                            }
                                            i = i + 1
                                        }
                                        if idx < 0 {
                                            cerr(psp, "E0599", "", "enum `" + penum + "` has no variant `" + pvar + "`")
                                        } else {
                                            eh = h
                                        }
                                    },
                                    None => cerr(psp, "E0412", "", "cannot find enum `" + penum + "`"),
                                }
                            } else {
                                let fv = find_variant_sig(pvar)
                                if fv[0] == -2 {
                                    cerr(psp, "E0659", "qualify it, e.g. `SomeEnum." + pvar + "`", "`" + pvar + "` is a variant of several enums")
                                } else if fv[0] < 0 {
                                    cerr(psp, "E0425", "", "cannot find variant `" + pvar + "`")
                                } else {
                                    eh = fv[0]
                                    idx = fv[1]
                                }
                            }
                            if eh >= 0 && idx >= 0 {
                                let mut subst = map()
                                let enum_ty = instantiate_enum(eh, subst)
                                unify_at(scrut_t, enum_ty, psp, "between this pattern and the matched value")
                                let fields = v_fields[e_variants[eh][idx]]
                                if len(binds) != len(fields) {
                                    cerr(psp, "E0023", "", "variant `" + pvar + "` has " + str(len(fields)) + " field(s), pattern binds " + str(len(binds)))
                                } else {
                                    let mut i = 0
                                    while i < len(binds) {
                                        let ft = convert_type_expr(fields[i], subst, e_prefix[eh])
                                        match binds[i] {
                                            PatBinding(bn, bsp) => {
                                                let _ = declare(bn, mono(ft), false, "pattern", bsp)
                                            },
                                            _ => {},
                                        }
                                        i = i + 1
                                    }
                                }
                                if unguarded {
                                    put(covered, pvar, true)
                                }
                            }
                        },
                        _ => {},
                    }
                    match guard {
                        NoNode => {},
                        _ => {
                            let gt = infer_expr_ref(guard)
                            unify_at(gt, h_bool, span_of(guard), "in this `match` guard (guards must be bool)")
                        },
                    }
                    let bt = infer_expr_ref(body)
                    unify_at(res_t, bt, span_of(body), "between the arms of this `match` (all arms must produce one type)")
                    pop_scope()
                },
                _ => {},
            }
        }

        // exhaustiveness
        if !has_catch_all {
            let s = ty_resolve(tk, tr, scrut_t)
            if tk[s] == 0 {
                let eh = match get(enum_by_name, tn[s]) {
                    Some(h) => h,
                    None => -1,
                }
                if eh >= 0 {
                    let mut missing = []
                    for vh in e_variants[eh] {
                        let hit = match get(covered, v_name[vh]) {
                            Some(_) => true,
                            None => false,
                        }
                        if !hit {
                            push(missing, "`" + v_name[vh] + "`")
                        }
                    }
                    if len(missing) > 0 {
                        cerr(msp, "E0004", "add the missing arms, or a `_ => ...` catch-all", "non-exhaustive `match`: variant(s) " + join(missing, ", ") + " not covered")
                    }
                } else if tn[s] == "bool" {
                    let t_hit = match get(covered, "true") {
                        Some(_) => true,
                        None => false,
                    }
                    let f_hit = match get(covered, "false") {
                        Some(_) => true,
                        None => false,
                    }
                    if !t_hit || !f_hit {
                        cerr(msp, "E0004", "cover both `true` and `false`, or add `_ => ...`", "non-exhaustive `match` on bool")
                    }
                } else {
                    cerr(msp, "E0004", "add a final binding or `_ => ...` arm", "non-exhaustive `match`: `" + pretty_of(scrut_t) + "` cannot be enumerated")
                }
            } else {
                cerr(msp, "E0004", "add a final binding or `_ => ...` arm", "non-exhaustive `match`")
            }
        }
        res_t
    }

    fn infer_expr(e) {
        let h = match e {
            IntLit(_, _) => h_int,
            FloatLit(_, _) => h_float,
            StrLit(_, _) => h_str,
            BoolLit(_, _) => h_bool,
            Ident(name, isp) => {
                let b = lookup(name)
                if b >= 0 {
                    // a not-ready hit means the dependency scan missed an
                    // edge: a compiler bug, not a user error
                    if b_kind[b] == "global" && b_isfn[b] {
                        assert(b_ready[b], "internal: `" + name + "` used before its inference group")
                    }
                    b_used[b] = true
                    instantiate(b_scheme[b])
                } else {
                    // bare enum variant
                    let fv = find_variant_sig(name)
                    if fv[0] == -2 {
                        cerr(isp, "E0659", "qualify it, e.g. `SomeEnum." + name + "`", "`" + name + "` is a variant of several enums")
                        fresh("")
                    } else if fv[1] >= 0 {
                        variant_type(fv[0], fv[1])
                    } else {
                        cerr(isp, "E0425", "", "cannot find `" + name + "` in this scope")
                        fresh("")
                    }
                }
            },
            VariantAccess(en, vr, vsp) => {
                // an import alias as the head makes this a package access
                // (module.go rewrites the AST; burc resolves on the fly)
                let apath = alias_path(en)
                if apath != "" {
                    infer_pkg_access(apath, vr, vsp)
                } else {
                    let seh = enum_sig(en)
                    match if seh >= 0 {
                        Some(seh)
                    } else {
                        None
                    } {
                        Some(eh) => {
                            let mut idx = -1
                            let mut i = 0
                            while i < len(e_variants[eh]) {
                                if v_name[e_variants[eh][i]] == vr {
                                    idx = i
                                }
                                i = i + 1
                            }
                            if idx >= 0 {
                                variant_type(eh, idx)
                            } else {
                                cerr(vsp, "E0599", "", "enum `" + en + "` has no variant `" + vr + "`")
                                fresh("")
                            }
                        },
                        None => {
                            let b = lookup(en)
                            if b >= 0 {
                                b_used[b] = true
                                let bt = instantiate(b_scheme[b])
                                let resolved = ty_resolve(tk, tr, bt)
                                if tk[resolved] == 0 && str_len(tn[resolved]) > 4 && substr(tn[resolved], 0, 4) == "@rec" {
                                    let fnames = rec_parse_names(tn[resolved])
                                    let mut result = -1
                                    let mut j = 0
                                    while j < len(fnames) {
                                        if fnames[j] == vr {
                                            result = j
                                        }
                                        j = j + 1
                                    }
                                    if result >= 0 {
                                        ta[resolved][result]
                                    } else {
                                        cerr(vsp, "E0609", "", "record has no field `" + vr + "`")
                                        fresh("")
                                    }
                                } else {
                                    cerr(vsp, "E0609", "only records support `.field` access", "cannot access field `" + vr + "` on a non-record type")
                                    fresh("")
                                }
                            } else {
                                cerr(vsp, "E0412", "", "cannot find enum `" + en + "`")
                                fresh("")
                            }
                        },
                    }
                }
            },
            PkgAccess(pkg, name, psp) => infer_pkg_access(pkg, name, psp),
            QualVariantAccess(pkg, en, vr, qsp) => {
                let apath = alias_path(pkg)
                if apath == "" {
                    cerr(qsp, "E0433", "", "cannot find package `" + pkg + "`")
                    fresh("")
                } else {
                    let eh = lookup_pkg_enum(apath, en, qsp)
                    if eh < 0 {
                        fresh("")
                    } else {
                        let mut idx = -1
                        let mut i = 0
                        while i < len(e_variants[eh]) {
                            if v_name[e_variants[eh][i]] == vr {
                                idx = i
                            }
                            i = i + 1
                        }
                        if idx >= 0 {
                            variant_type(eh, idx)
                        } else {
                            cerr(qsp, "E0599", "", "enum `" + en + "` has no variant `" + vr + "`")
                            fresh("")
                        }
                    }
                }
            },
            Unary(op, rhs, usp) => {
                let t = infer_expr(rhs)
                if op == t_minus {
                    unify_at(t, fresh("num"), usp, "with unary `-`")
                    t
                } else {
                    unify_at(t, h_bool, usp, "with `!`")
                    h_bool
                }
            },
            Binary(op, lhs, rhs, bsp) => {
                let lt = infer_expr(lhs)
                let rt = infer_expr(rhs)
                if op == t_plus {
                    unify_at(lt, rt, bsp, "with `+` (no implicit conversions: use str()/to_float()/trunc())")
                    unify_at(lt, fresh("addord"), bsp, "with `+`")
                    lt
                } else if op == t_minus || op == t_star || op == t_slash {
                    unify_at(lt, rt, bsp, "with this operator (no implicit conversions: use to_float()/trunc())")
                    unify_at(lt, fresh("num"), bsp, "with this arithmetic operator")
                    lt
                } else if op == t_percent {
                    unify_at(lt, h_int, bsp, "with `%` (int only)")
                    unify_at(rt, h_int, bsp, "with `%` (int only)")
                    h_int
                } else if op == t_lt || op == t_lt_eq || op == t_gt || op == t_gt_eq {
                    unify_at(lt, rt, bsp, "in this comparison (no implicit conversions)")
                    unify_at(lt, fresh("addord"), bsp, "in this comparison")
                    h_bool
                } else if op == t_eq_eq || op == t_bang_eq {
                    unify_at(lt, rt, bsp, "in this equality (both sides must be the same type)")
                    h_bool
                } else {
                    fresh("")
                }
            },
            Logical(_, lhs, rhs, _) => {
                let lt = infer_expr(lhs)
                let rt = infer_expr(rhs)
                unify_at(lt, h_bool, span_of(lhs), "with `&&`/`||`")
                unify_at(rt, h_bool, span_of(rhs), "with `&&`/`||`")
                h_bool
            },
            Call(callee, cargs, csp) => infer_call(callee, cargs, csp),
            Index(target, idx, _) => {
                let el = fresh("")
                let tt = infer_expr(target)
                unify_at(tt, con1("list", el), span_of(target), "when indexing (only lists; for strings use char_at(), for maps use get())")
                let it = infer_expr(idx)
                unify_at(it, h_int, span_of(idx), "in this index")
                el
            },
            ListLit(elems, _) => {
                let el = fresh("")
                for x in elems {
                    let t = infer_expr(x)
                    unify_at(el, t, span_of(x), "in this list (all elements must share one type)")
                }
                con1("list", el)
            },
            FnLit(params, muts, pspans, param_tys, ret_ty, body, _, _) => {
                push_scope()
                let mut annotation_vars = map()
                for te in param_tys {
                    collect_annotation_vars(te, annotation_vars)
                }
                collect_annotation_vars(ret_ty, annotation_vars)
                let mut phs = []
                let mut i = 0
                while i < len(params) {
                    let pv = fresh("")
                    push(phs, pv)
                    match param_tys[i] {
                        NoNode => {},
                        te => unify_at(pv, convert_type_expr(te, annotation_vars, cur_pkg), span_of(te), "with this parameter annotation"),
                    }
                    let _ = declare(params[i], mono(pv), muts[i], "param", pspans[i])
                    i = i + 1
                }
                let ret = fresh("")
                match ret_ty {
                    NoNode => {},
                    te => unify_at(ret, convert_type_expr(te, annotation_vars, cur_pkg), span_of(te), "with this return annotation"),
                }
                match body {
                    NoNode => {
                        // a bodyless signature (interface file) documents
                        // its parameter names; they are never "unused"
                        let top = scopes[len(scopes) - 1]
                        for name in keys(top) {
                            match get(top, name) {
                                Some(b) => {
                                    b_used[b] = true
                                },
                                None => {},
                            }
                        }
                    },
                    _ => {
                        push(ret_tys, ret)
                        let bt = infer_block_expr(body)
                        unify_at(ret, bt, span_of(body), "as this function's result")
                        let _ = pop(ret_tys)
                    },
                }
                pop_scope()
                tfn(phs, ret)
            },
            Block(_, _) => {
                push_scope()
                let t = infer_block_noscope(e)
                pop_scope()
                t
            },
            IfExpr(cond, then, els, _) => {
                let ct = infer_expr(cond)
                unify_at(ct, h_bool, span_of(cond), "in this `if` condition")
                let tt = infer_expr(then)
                let no_else = match els {
                    NoNode => true,
                    _ => false,
                }
                if no_else {
                    unify_at(tt, h_unit, span_of(then), "in this `if` (without an `else`, the branch must be unit)")
                    h_unit
                } else {
                    let et = infer_expr(els)
                    unify_at(tt, et, span_of(els), "between `if` and `else` branches")
                    tt
                }
            },
            MatchExpr(scrut, arms, msp) => infer_match(scrut, arms, msp),
            TryExpr(inner, tsp) => infer_try(inner, tsp),
            RecvExpr(ch, rsp) => {
                let el = fresh("")
                let ct = infer_expr(ch)
                unify_at(ct, con1("chan", el), rsp, "with `<-` (need a channel)")
                el
            },
            RecordLit(names, vals, _) => {
                let mut field_types = []
                let mut i = 0
                while i < len(names) {
                    let ft = infer_expr(vals[i])
                    push(field_types, ft)
                    i = i + 1
                }
                ty_new_con(tk, tn, ta, tr, tl, rec_type_name(names), field_types)
            },
            RecordUpdate(base, names, vals, _) => {
                let bt = infer_expr(base)
                let mut i = 0
                while i < len(names) {
                    let ft = infer_expr(vals[i])
                    let resolved = ty_resolve(tk, tr, bt)
                    if tk[resolved] == 0 && str_len(tn[resolved]) > 4 && substr(tn[resolved], 0, 4) == "@rec" {
                        let fnames = rec_parse_names(tn[resolved])
                        let mut found = false
                        let mut j = 0
                        while j < len(fnames) {
                            if fnames[j] == names[i] {
                                unify_at(ta[resolved][j], ft, span_of(vals[i]), "in record update field `" + names[i] + "`")
                                found = true
                            }
                            j = j + 1
                        }
                        if !found {
                            cerr(span_of(vals[i]), "E0609", "", "record has no field `" + names[i] + "`")
                        }
                    }
                    i = i + 1
                }
                bt
            },
            FieldAccess(base, field, fsp) => {
                let bt = infer_expr(base)
                let resolved = ty_resolve(tk, tr, bt)
                if tk[resolved] == 0 && str_len(tn[resolved]) > 4 && substr(tn[resolved], 0, 4) == "@rec" {
                    let fnames = rec_parse_names(tn[resolved])
                    let mut result = -1
                    let mut j = 0
                    while j < len(fnames) {
                        if fnames[j] == field {
                            result = j
                        }
                        j = j + 1
                    }
                    if result >= 0 {
                        ta[resolved][result]
                    } else {
                        cerr(fsp, "E0609", "", "record has no field `" + field + "`")
                        fresh("")
                    }
                } else {
                    let ft = fresh("")
                    unify_at(bt, ft, fsp, "field access requires a record")
                    cerr(fsp, "E0609", "only records support `.field` access", "cannot access field `" + field + "` on a non-record type")
                    fresh("")
                }
            },
            _ => fresh(""),
        }
        if lsp_recording {
            lsp_record_type(span_of(e), h, cur_file)
        }
        h
    }
    infer_expr_ref = infer_expr

    fn infer_stmt(s) {
        match s {
            LetStmt(name, nsp, is_mut, is_pub, init, ssp) => {
                if is_pub {
                    err_pub_script(ssp)
                }
                let t = infer_let_init(init)
                let is_fnlit = match init {
                    FnLit(_, _, _, _, _, _, _, _) => true,
                    _ => false,
                }
                let sch = if is_fnlit {
                    generalize(t)
                } else {
                    mono(t)
                }
                let bh = declare(name, sch, is_mut, "local", nsp)
                match init {
                    FnLit(_, muts, _, _, _, _, _, _) => {
                        put(b_muts, bh, muts)
                    },
                    _ => {},
                }
                if is_mut {
                    let fresh = is_fresh_source(init, lookup, b_mut, b_kind, map())
                    check_deep_mut(t, fresh, nsp, "initialize with a fresh heap source (literal, call return, or enum ctor); a non-mut binding aliases its value and mutations through `" + name + "` would be visible through the source", "cannot initialize mutable binding `" + name + "` with a non-fresh heap source")
                }
            },
            FnDecl(name, nsp, is_pub, lit, ssp) => {
                if is_pub {
                    err_pub_script(ssp)
                }
                let tv = fresh("")
                let b = declare(name, mono(tv), false, "local", nsp)
                b_isfn[b] = true
                b_used[b] = true // don't lint named helper fns
                match lit {
                    FnLit(_, muts, _, _, _, _, _, _) => {
                        put(b_muts, b, muts)
                    },
                    _ => {},
                }
                level = level + 1
                let ft = infer_expr(lit)
                level = level - 1
                b_scheme[b] = generalize(ft) // before unify: see top-level FnDecl note
                unify_at(tv, ft, nsp, "in this function")
            },
            EnumDecl(_, _, _, _, ssp) => {
                cerr(ssp, "E0637", "", "enum declarations are only allowed at top level")
            },
            ImportDecl(_, _, _, _, ssp) => {
                cerr(ssp, "E0432", "imports go at the top of a file in a module (a directory with bur.mod); single-file scripts cannot import", "`import` is not allowed here")
            },
            ExprStmt(e, ssp) => {
                let t = infer_expr(e)
                let r = ty_resolve(tk, tr, t)
                if tk[r] == 0 && (tn[r] == "Result" || tn[r] == "Option") {
                    cerr(ssp, "unused_must_use", "handle it with `match`/`?`, or discard explicitly with `let _ = ...`", "unused `" + tn[r] + "` value must be handled")
                }
            },
            AssignStmt(target, val, _) => {
                match target {
                    Ident(name, isp) => {
                        let b = lookup(name)
                        if b < 0 {
                            cerr(isp, "E0425", "declare it first: `let mut " + name + " = ...`", "cannot assign to undeclared variable `" + name + "`")
                            let _ = infer_expr(val)
                        } else {
                            if !b_mut[b] {
                                let help = if b_kind[b] == "param" {
                                    "declare the parameter as mutable: `mut " + name + "`"
                                } else {
                                    "make this binding mutable: `let mut " + name + "`"
                                }
                                cerr(isp, "E0384", help, "cannot assign twice to immutable variable `" + name + "`")
                            }
                            let vt = infer_expr(val)
                            unify_at(instantiate(b_scheme[b]), vt, span_of(val), "in this assignment")
                            if b_mut[b] {
                                let fresh = is_fresh_source(val, lookup, b_mut, b_kind, map())
                                check_deep_mut(vt, fresh, isp, "assign a fresh heap source (literal, call return, or enum ctor); a non-mut binding aliases its value and mutations through `" + name + "` would be visible through the source", "cannot assign a non-fresh heap source to mutable binding `" + name + "`")
                            }
                        }
                    },
                    Index(itarget, iidx, _) => {
                        require_mut_root(target, "assign to this element")
                        let el = fresh("")
                        let tt = infer_expr(itarget)
                        unify_at(tt, con1("list", el), span_of(itarget), "when indexing")
                        let it = infer_expr(iidx)
                        unify_at(it, h_int, span_of(iidx), "in this index")
                        let vt = infer_expr(val)
                        unify_at(el, vt, span_of(val), "in this assignment")
                    },
                    _ => {},
                }
            },
            WhileStmt(cond, body, _) => {
                let ct = infer_expr(cond)
                unify_at(ct, h_bool, span_of(cond), "in this `while` condition")
                push_scope()
                infer_block_stmts(body)
                pop_scope()
            },
            ForStmt(v, vsp, iter, _, body, fsp) => {
                let el = fresh("")
                let it = infer_expr(iter)
                // a channel iterable receives until closed; anything else must
                // be a list (the channel type must be statically evident here)
                let r = ty_resolve(tk, tr, it)
                if tk[r] == 0 && tn[r] == "chan" {
                    unify_at(el, ta[r][0], span_of(iter), "in this `for` loop (receive from a channel)")
                    match fsp {
                        Sp(fstart, _) => push(chan_fors, cur_file + ":" + str(fstart)),
                    }
                } else {
                    unify_at(it, con1("list", el), span_of(iter), "in this `for` loop (iterate over a list or channel)")
                }
                push_scope()
                let _ = declare(v, mono(el), false, "pattern", vsp)
                infer_block_stmts(body)
                pop_scope()
            },
            ReturnStmt(val, ssp) => {
                let has_val = match val {
                    NoNode => false,
                    _ => true,
                }
                let t = if has_val {
                    infer_expr(val)
                } else {
                    h_unit
                }
                if len(ret_tys) == 0 {
                    cerr(ssp, "E0572", "", "`return` outside of a function")
                } else {
                    unify_at(ret_tys[len(ret_tys) - 1], t, ssp, "in this `return`")
                }
            },
            SpawnStmt(call, _) => {
                let _ = infer_expr(call)
            },
            DeferStmt(body, ssp) => {
                // the block is a closure body: `return`/`?` inside exit the
                // block, and the runtime discards its result — so a dropped
                // Result/Option must be handled, same as an expression stmt
                let ret = fresh("")
                push(ret_tys, ret)
                let bt = infer_block_expr(body)
                unify_at(ret, bt, span_of(body), "as this `defer` block's result")
                let _ = pop(ret_tys)
                let r = ty_resolve(tk, tr, ret)
                if tk[r] == 0 && (tn[r] == "Result" || tn[r] == "Option") {
                    cerr(ssp, "unused_must_use", "handle it with `match`/`?`, or discard explicitly with `let _ = ...`", "unused `" + tn[r] + "` value must be handled")
                }
            },
            SelectStmt(arms, has_default, dflt, _, _) => {
                for arm in arms {
                    match arm {
                        SelectArm(is_send, bind, bind_sp, ch, val, body, _) => {
                            let el = fresh("")
                            let ct = infer_expr(ch)
                            unify_at(ct, con1("chan", el), span_of(ch), "in this `select` arm (need a channel)")
                            if is_send {
                                let vt = infer_expr(val)
                                unify_at(el, vt, span_of(val), "in this `select` send")
                                let _ = infer_expr(body)
                            } else {
                                push_scope()
                                if bind != "" && bind != "_" {
                                    let _ = declare(bind, mono(el), false, "pattern", bind_sp)
                                }
                                let _ = infer_expr(body)
                                pop_scope()
                            }
                        },
                        _ => {},
                    }
                }
                if has_default {
                    let _ = infer_expr(dflt)
                }
            },
            SendStmt(ch, val, _) => {
                let el = fresh("")
                let ct = infer_expr(ch)
                unify_at(ct, con1("chan", el), span_of(ch), "on the left of `<-` (need a channel)")
                let vt = infer_expr(val)
                unify_at(el, vt, span_of(val), "in this send")
            },
            _ => {}, // break/continue: loop nesting validated by the compiler
        }
    }
    infer_stmt_ref = infer_stmt

    // ---- builtins (mirrors declareBuiltins in types.go) ----
    push_scope() // scope 0

    fn te(name) {
        TEName("", name, "", [], Sp(0, 0))
    }
    fn builtin_enum(name, params, vnames, vfieldss) {
        let mut vhs = []
        let mut i = 0
        while i < len(vnames) {
            push(v_name, vnames[i])
            push(v_fields, vfieldss[i])
            push(vhs, len(v_name) - 1)
            i = i + 1
        }
        push(e_qual, name)
        push(e_params, params)
        push(e_variants, vhs)
        push(e_prefix, "")
        push(e_pub, true)
        put(enum_by_name, name, len(e_qual) - 1)
    }
    builtin_enum("Option", ["a"], ["Some", "None"], [[te("a")], []])
    builtin_enum("Result", ["a", "e"], ["Ok", "Err"], [[te("a")], [te("e")]])
    // Output(code, stdout, stderr): the single-variant result of exec()
    builtin_enum("Output", [], ["Output"], [[te("int"), te("str"), te("str")]])

    fn qvar(con) {
        ty_new_var(tk, tn, ta, tr, tl, 1, con)
    }
    fn decl_native(name, sch) {
        let _ = declare(name, sch, false, "native", Sp(0, 0))
    }

    let va1 = qvar("")
    decl_native("len", new_scheme([va1], tfn([con1("list", va1)], h_int)))
    let va2 = qvar("")
    decl_native("push", new_scheme([va2], tfn([con1("list", va2), va2], h_unit)))
    let va3 = qvar("")
    decl_native("pop", new_scheme([va3], tfn([con1("list", va3)], va3)))
    let mk1 = qvar("key")
    let mv1 = qvar("")
    decl_native("map", new_scheme([mk1, mv1], tfn([], con2("map", mk1, mv1))))
    let mk2 = qvar("key")
    let mv2 = qvar("")
    decl_native("get", new_scheme([mk2, mv2], tfn([con2("map", mk2, mv2), mk2], con1("Option", mv2))))
    let mk3 = qvar("key")
    let mv3 = qvar("")
    decl_native("put", new_scheme([mk3, mv3], tfn([con2("map", mk3, mv3), mk3, mv3], h_unit)))
    let mk4 = qvar("key")
    let mv4 = qvar("")
    decl_native("delete", new_scheme([mk4, mv4], tfn([con2("map", mk4, mv4), mk4], h_unit)))
    let mk5 = qvar("key")
    let mv5 = qvar("")
    decl_native("keys", new_scheme([mk5, mv5], tfn([con2("map", mk5, mv5)], con1("list", mk5))))
    let va4 = qvar("")
    decl_native("str", new_scheme([va4], tfn([va4], h_str)))
    let va5 = qvar("")
    decl_native("type_of", new_scheme([va5], tfn([va5], h_str)))
    decl_native("str_len", mono(tfn([h_str], h_int)))
    decl_native("char_at", mono(tfn([h_str, h_int], h_str)))
    decl_native("byte_at", mono(tfn([h_str, h_int], h_int)))
    decl_native("trunc", mono(tfn([h_float], h_int)))
    decl_native("to_float", mono(tfn([h_int], h_float)))
    decl_native("float_bits", mono(tfn([h_float], h_int)))
    decl_native("parse_int", mono(tfn([h_str], con1("Option", h_int))))
    decl_native("parse_float", mono(tfn([h_str], con1("Option", h_float))))
    decl_native("range", mono(tfn([h_int, h_int], con1("list", h_int))))
    decl_native("split", mono(tfn([h_str, h_str], con1("list", h_str))))
    decl_native("join", mono(tfn([con1("list", h_str), h_str], h_str)))
    decl_native("substr", mono(tfn([h_str, h_int, h_int], h_str)))
    decl_native("str_contains", mono(tfn([h_str, h_str], h_bool)))
    decl_native("str_index_of", mono(tfn([h_str, h_str], con1("Option", h_int))))
    decl_native("trim", mono(tfn([h_str], h_str)))
    let va6 = qvar("")
    decl_native("slice", new_scheme([va6], tfn([con1("list", va6), h_int, h_int], con1("list", va6))))
    let va7 = qvar("")
    decl_native("concat", new_scheme([va7], tfn([con1("list", va7), con1("list", va7)], con1("list", va7))))
    let va8 = qvar("")
    decl_native("contains", new_scheme([va8], tfn([con1("list", va8), va8], h_bool)))
    decl_native("read_file", mono(tfn([h_str], con2("Result", h_str, h_str))))
    decl_native("write_file", mono(tfn([h_str, h_str], con2("Result", h_unit, h_str))))
    decl_native("file_exists", mono(tfn([h_str], h_bool)))
    decl_native("read_dir", mono(tfn([h_str], con2("Result", con1("list", h_str), h_str))))
    decl_native("exec", mono(tfn([h_str, con1("list", h_str)], con2("Result", con0("Output"), h_str))))
    decl_native("args", mono(tfn([], con1("list", h_str))))
    // exit never returns, so it unifies with any expected type
    let va9 = qvar("")
    decl_native("exit", new_scheme([va9], tfn([h_int], va9)))
    decl_native("clock", mono(tfn([], h_float)))
    decl_native("assert", mono(tfn([h_bool, h_str], h_unit)))
    decl_native("gc", mono(tfn([], h_int)))
    decl_native("heap_objects", mono(tfn([], h_int)))
    decl_native("gc_cycles", mono(tfn([], h_int)))
    decl_native("chr", mono(tfn([h_int], h_str)))
    decl_native("byte_chr", mono(tfn([h_int], h_str)))
    decl_native("ord", mono(tfn([h_str], h_int)))
    decl_native("yield", mono(tfn([], h_unit)))
    decl_native("sleep", mono(tfn([h_int], h_unit)))
    decl_native("exec_start", mono(tfn([h_str, con1("list", h_str)], con2("Result", h_int, h_str))))
    decl_native("exec_poll", mono(tfn([h_int], con1("Option", con2("Result", con0("Output"), h_str)))))
    decl_native("tcp_listen", mono(tfn([h_str, h_int], con2("Result", h_int, h_str))))
    decl_native("tcp_accept", mono(tfn([h_int], con2("Result", h_int, h_str))))
    decl_native("tcp_dial", mono(tfn([h_str, h_int], con2("Result", h_int, h_str))))
    decl_native("net_read", mono(tfn([h_int, h_int], con2("Result", h_str, h_str))))
    decl_native("net_write", mono(tfn([h_int, h_str], con2("Result", h_unit, h_str))))
    decl_native("net_close", mono(tfn([h_int], h_unit)))
    decl_native("net_nb", mono(tfn([h_int, h_int, h_str, h_int], con2("Result", h_str, h_str))))
    decl_native("read_stdin", mono(tfn([h_int], h_str)))
    decl_native("stdin_nb", mono(tfn([h_int], con2("Result", h_str, h_str))))
    let va10 = qvar("")
    decl_native("close", new_scheme([va10], tfn([con1("chan", va10)], h_unit)))
    let va11 = qvar("")
    decl_native("recv", new_scheme([va11], tfn([con1("chan", va11)], con1("Option", va11))))

    let bp1 = declare("print", mono(tfn([], h_unit)), false, "native", Sp(0, 0))
    b_special[bp1] = "printf"
    let bp2 = declare("println", mono(tfn([], h_unit)), false, "native", Sp(0, 0))
    b_special[bp2] = "printf"
    let bp3 = declare("eprintln", mono(tfn([], h_unit)), false, "native", Sp(0, 0))
    b_special[bp3] = "printf"
    let bc1 = declare("chan", mono(tfn([], con1("chan", h_unit))), false, "native", Sp(0, 0))
    b_special[bc1] = "chan"

    // ---- passes: check each package in dependency order (entry last),
    // each in its own scope over the shared builtins (typecheckModule +
    // checkPackage; a script is one anonymous pseudo package) ----
    let n_pkgs = len(pkgs_stmts)
    // flat file order across all packages, for stable diagnostic sorting
    let mut flat_files = []
    let mut pi = 0
    while pi < n_pkgs {
        for f in pkgs_fpaths[pi] {
            push(flat_files, f)
        }
        pi = pi + 1
    }
    // entry-package globals for the bind dump, captured before the scope pop
    let mut bind_names = []
    let mut bind_by = map()
    let mut interface_sources = []

    pi = 0
    while pi < n_pkgs {
        cur_pkg = pkg_paths[pi]
        let files_stmts = pkgs_stmts[pi]
        let file_paths = pkgs_fpaths[pi]
        let file_imports = pkgs_imports[pi]
        let is_entry = pi == n_pkgs - 1
        let n_files = len(files_stmts)
        push_scope() // the package scope

        // pass 1: register enums from every file (names and variants only),
        // then validate field types in a second sweep so an enum may
        // reference enums registered later, in any file of the package
        let mut reg_decls = []
        let mut reg_files = []
        let mut fi = 0
        while fi < n_files {
            cur_file = file_paths[fi]
            cur_aliases = aliases_of(file_imports[fi])
            for s in files_stmts[fi] {
                match s {
                    EnumDecl(_, _, _, _, _) => {
                        if register_enum(s) {
                            push(reg_decls, s)
                            push(reg_files, fi)
                        }
                    },
                    _ => {},
                }
            }
            fi = fi + 1
        }
        let mut ri = 0
        while ri < len(reg_decls) {
            cur_file = file_paths[reg_files[ri]]
            cur_aliases = aliases_of(file_imports[reg_files[ri]])
            validate_enum_fields(reg_decls[ri])
            ri = ri + 1
        }
        // pass 1.5: pre-declare every top-level value name. Lets keep a
        // monomorphic level-0 placeholder (pre); fns are declared but stay
        // not-ready until pass 2a assigns their group placeholder
        let mut pre = map()
        let mut fnames = [] // distinct top-level fn names, declaration order
        let mut fname_idx = map()
        let mut fd_name = [] // per fn decl: index into fnames
        let mut fd_stmt = []
        let mut fd_file = []
        fi = 0
        while fi < n_files {
            cur_file = file_paths[fi]
            for s in files_stmts[fi] {
                match s {
                    FnDecl(name, nsp, is_pub, lit, _) => {
                        let b = declare(name, mono(fresh("")), false, "global", nsp)
                        b_isfn[b] = true
                        b_pub[b] = is_pub
                        b_ready[b] = false
                        match lit {
                            FnLit(params, _, _, _, _, _, _, _) => {
                                b_params[b] = params
                            },
                            _ => {},
                        }
                        let ni = match get(fname_idx, name) {
                            Some(x) => x,
                            None => {
                                put(fname_idx, name, len(fnames))
                                push(fnames, name)
                                len(fnames) - 1
                            },
                        }
                        push(fd_name, ni)
                        push(fd_stmt, s)
                        push(fd_file, fi)
                    },
                    LetStmt(name, nsp, is_mut, is_pub, _, _) => {
                        let tv = fresh("")
                        put(pre, name, tv)
                        let b = declare(name, mono(tv), is_mut, "global", nsp)
                        b_pub[b] = is_pub
                    },
                    _ => {},
                }
            }
            fi = fi + 1
        }

        // pass 1.7: fn dependency graph (free names resolved against the
        // package's fn names) and its SCC groups, callees first
        let mut adj = []
        let mut ni = 0
        while ni < len(fnames) {
            push(adj, [])
            ni = ni + 1
        }
        let mut di = 0
        while di < len(fd_stmt) {
            cur_file = file_paths[fd_file[di]]
            cur_aliases = aliases_of(file_imports[fd_file[di]])
            match fd_stmt[di] {
                FnDecl(_, _, _, lit, _) => {
                    let mut sc = [map()]
                    let mut seen = map()
                    let mut free = []
                    scan_free(lit, sc, seen, free)
                    for fname in free {
                        match get(fname_idx, fname) {
                            Some(ti) => {
                                if !contains(adj[fd_name[di]], ti) {
                                    push(adj[fd_name[di]], ti)
                                }
                            },
                            None => {},
                        }
                    }
                },
                _ => {},
            }
            di = di + 1
        }
        let groups = scc_groups(adj)
        let mut gdecls = [] // per group: its decl indices, declaration order
        let mut name_group = []
        ni = 0
        while ni < len(fnames) {
            push(name_group, -1)
            ni = ni + 1
        }
        let mut gi = 0
        while gi < len(groups) {
            push(gdecls, [])
            for gn in groups[gi] {
                name_group[gn] = gi
            }
            gi = gi + 1
        }
        di = 0
        while di < len(fd_stmt) {
            push(gdecls[name_group[fd_name[di]]], di)
            di = di + 1
        }

        // pass 2a: infer fns group by group in dependency order. Group
        // placeholders live at the raised level so mutual references stay
        // un-generalized inside the group; each member generalizes once the
        // whole group is inferred
        gi = 0
        while gi < len(groups) {
            level = level + 1
            try_level = level
            let mut gtv = map() // member name -> group placeholder
            for gn in groups[gi] {
                let name = fnames[gn]
                let tv = fresh("")
                let b = lookup(name)
                b_scheme[b] = mono(tv)
                b_ready[b] = true
                put(gtv, name, tv)
            }
            let mut gft = [] // inferred type per group decl
            for gd in gdecls[gi] {
                cur_file = file_paths[fd_file[gd]]
                cur_aliases = aliases_of(file_imports[fd_file[gd]])
                match fd_stmt[gd] {
                    FnDecl(name, nsp, is_pub, lit, _) => {
                        if is_pub && !is_pkg {
                            err_pub_script(span_of(fd_stmt[gd]))
                        }
                        let cb = lookup(name)
                        match lit {
                            FnLit(_, muts, _, _, _, _, _, _) => {
                                put(b_muts, cb, muts)
                            },
                            _ => {},
                        }
                        let ft = infer_expr(lit)
                        match get(gtv, name) {
                            Some(tv) => unify_at(tv, ft, nsp, "in this function"),
                            None => {},
                        }
                        push(gft, ft)
                    },
                    _ => push(gft, fresh("")),
                }
            }
            flush_tries()
            flush_deep_mut()
            level = level - 1
            let mut mi = 0
            while mi < len(gdecls[gi]) {
                match fd_stmt[gdecls[gi][mi]] {
                    FnDecl(name, _, _, _, _) => {
                        let b = lookup(name)
                        b_scheme[b] = generalize(gft[mi])
                    },
                    _ => {},
                }
                mi = mi + 1
            }
            gi = gi + 1
        }

        // pass 2b: infer the remaining top-level statements file by file,
        // in load order (matches the runtime initialization order of
        // package-level lets and script statements)
        try_level = 0
        fi = 0
        while fi < n_files {
            cur_file = file_paths[fi]
            cur_aliases = aliases_of(file_imports[fi])
            for s in files_stmts[fi] {
                match s {
                    FnDecl(_, _, _, _, _) => {
                        // inferred in pass 2a
                    },
                    LetStmt(name, nsp, _, is_pub, init, _) => {
                        if is_pub && !is_pkg {
                            err_pub_script(span_of(s))
                        }
                        let t = if is_type_expr_node(init) {
                            let mut annotation_vars = map()
                            collect_annotation_vars(init, annotation_vars)
                            convert_type_expr(init, annotation_vars, cur_pkg)
                        } else {
                            infer_let_init(init)
                        }
                        let pt = match get(pre, name) {
                            Some(x) => x,
                            None => t,
                        }
                        unify_at(pt, t, nsp, "in this binding")
                        let gmut = match get(scopes[len(scopes) - 1], name) {
                            Some(bh) => b_mut[bh],
                            None => false,
                        }
                        if gmut {
                            let fresh = is_fresh_source(init, lookup, b_mut, b_kind, map())
                            check_deep_mut(pt, fresh, nsp, "initialize with a fresh heap source (literal, call return, or enum ctor); a non-mut binding aliases its value and mutations through `" + name + "` would be visible through the source", "cannot initialize mutable binding `" + name + "` with a non-fresh heap source")
                        }
                    },
                    EnumDecl(_, _, _, is_pub, _) => {
                        if is_pub && !is_pkg {
                            err_pub_script(span_of(s))
                        }
                        // already registered
                    },
                    _ => infer_stmt(s),
                }
                flush_tries()
                flush_deep_mut()
            }
            fi = fi + 1
        }

        // entry package: validate main (mirrors checkPackage's isEntry block)
        if is_pkg && is_entry {
            let mb = match get(scopes[len(scopes) - 1], "main") {
                Some(b) => if b_isfn[b] {
                    b
                } else {
                    -1
                },
                None => -1,
            }
            if mb >= 0 {
                b_used[mb] = true
                let e = ty_unify(tk, tn, ta, tr, tl, instantiate(b_scheme[mb]), tfn([], fresh("")))
                if e != "" {
                    cur_file = b_file[mb]
                    cerr(b_span[mb], "E0580", "declare it as `fn main() " + chr(123) + " ... }`", "`main` must take no parameters")
                }
            } else {
                cur_file = file_paths[0]
                cerr(Sp(0, 0), "E0601", "declare `fn main() " + chr(123) + " ... }` in the package you run", "no `main` function in package \"" + cur_pkg + "\"")
            }
        }

        // lint unused non-pub globals (pub ones are the package's API), then
        // snapshot the scope for importers and pop it
        let top = scopes[len(scopes) - 1]
        for name in keys(top) {
            match get(top, name) {
                Some(b) => {
                    if b_kind[b] == "global" {
                        if (!is_pkg || !b_pub[b]) && !b_used[b] && !starts_underscore(name) {
                            let what = if b_isfn[b] {
                                "function"
                            } else {
                                "variable"
                            }
                            cur_file = b_file[b]
                            cwarn_fix(b_span[b], "unused_variable", "unused " + what + ": `" + name + "`", "if this is intentional, prefix it with an underscore", "_" + name)
                        }
                        put(pkg_vals, cur_pkg + "." + name, b)
                        if is_entry {
                            push(bind_names, name)
                            put(bind_by, name, b_scheme[b])
                        }
                    }
                },
                None => {},
            }
        }
        push(interface_sources, render_package_interface(top))
        put(pkg_seen, cur_pkg, true)
        let _ = pop(scopes)
        cur_aliases = map()
        pi = pi + 1
    }

    // ---- bind dump lines (only meaningful without errors) ----
    let mut has_err = false
    for d in diags {
        match d {
            lib.DiagT.Diag(ie, _, _, _, _, _) => {
                if ie {
                    has_err = true
                }
            },
            lib.DiagT.DiagX(ie, _, _, _, _, _, _, _) => {
                if ie {
                    has_err = true
                }
            },
        }
    }
    let mut bind_lines = []
    if !has_err {
        for name in sort_strs(bind_names) {
            match get(bind_by, name) {
                Some(sch) => push(bind_lines, "bind " + name + " :: " + pretty_of(s_t[sch])),
                None => {},
            }
        }
    }

    // ---- sort diags by (file order, span start), stable ----
    let mut ranks = []
    for f in diag_files {
        let mut r = 0
        let mut k = 0
        while k < len(flat_files) {
            if flat_files[k] == f {
                r = k + 1
            }
            k = k + 1
        }
        push(ranks, r)
    }
    let mut starts = []
    for d in diags {
        push(starts, diag_start(d))
    }
    let order = sort_order2(ranks, starts)
    let mut sorted_diags = []
    let mut sorted_files = []
    for oidx in order {
        push(sorted_diags, diags[oidx])
        push(sorted_files, diag_files[oidx])
    }

    if lsp_recording {
        lsp_arena_tk = tk
        lsp_arena_tn = tn
        lsp_arena_ta = ta
        lsp_arena_tr = tr
    }
    lib.CheckOut.Checked(sorted_diags, sorted_files, bind_lines, chan_fors, interface_sources)
}

// ---- small sorts (no stdlib sort yet; stable pick-first-minimum) ----

fn diag_start(d) {
    match d {
        lib.DiagT.Diag(_, _, _, _, s, _) => s,
        lib.DiagT.DiagX(_, _, _, _, s, _, _, _) => s,
    }
}

fn sort_order2(ranks, starts) {
    let n = len(ranks)
    let mut taken = []
    for _r in ranks {
        push(taken, false)
    }
    let mut out = []
    let mut c = 0
    while c < n {
        let mut best = -1
        let mut i = 0
        while i < n {
            if !taken[i] {
                if best < 0 {
                    best = i
                } else if ranks[i] < ranks[best] || ranks[i] == ranks[best] && starts[i] < starts[best] {
                    best = i
                }
            }
            i = i + 1
        }
        taken[best] = true
        push(out, best)
        c = c + 1
    }
    out
}

fn sort_strs(xs) {
    let n = len(xs)
    let mut taken = []
    for _x in xs {
        push(taken, false)
    }
    let mut out = []
    let mut c = 0
    while c < n {
        let mut best = -1
        let mut i = 0
        while i < n {
            if !taken[i] {
                if best < 0 {
                    best = i
                } else if xs[i] < xs[best] {
                    best = i
                }
            }
            i = i + 1
        }
        taken[best] = true
        push(out, xs[best])
        c = c + 1
    }
    out
}
