// std/testing: minimal assertion helpers for `bur test` (S6.6).

pub fn assert_eq(got, want) {
    assert(got == want, "assert_eq failed: got " + str(got) + ", want " + str(want))
}

pub fn assert_ok(result) {
    match result {
        Ok(_) => {},
        Err(err) => assert(false, "assert_ok failed: got Err(" + str(err) + ")"),
    }
}

pub fn assert_err(result) {
    match result {
        Err(_) => {},
        Ok(value) => assert(false, "assert_err failed: got Ok(" + str(value) + ")"),
    }
}
