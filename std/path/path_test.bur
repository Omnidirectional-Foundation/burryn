fn test_is_abs() {
    assert(is_abs("/foo"), "/foo is absolute")
    assert(is_abs("/"), "/ is absolute")
    assert(!is_abs("foo"), "foo is relative")
    assert(!is_abs(""), "empty is relative")
    assert(!is_abs("./foo"), "./foo is relative")
}

fn test_clean_basic() {
    assert(clean("") == ".", "empty becomes dot")
    assert(clean(".") == ".", "dot stays dot")
    assert(clean("/") == "/", "root stays root")
    assert(clean("/foo/bar") == "/foo/bar", "already clean absolute")
    assert(clean("foo/bar") == "foo/bar", "already clean relative")
}

fn test_clean_redundant_separators() {
    assert(clean("//foo///bar//") == "/foo/bar", "multiple slashes")
    assert(clean("foo//bar") == "foo/bar", "double slash relative")
}

fn test_clean_dot_segments() {
    assert(clean("/foo/./bar") == "/foo/bar", "dot in middle")
    assert(clean("./foo") == "foo", "leading dot")
    assert(clean("foo/.") == "foo", "trailing dot")
}

fn test_clean_dotdot_segments() {
    assert(clean("/foo/../bar") == "/bar", "dotdot absolute")
    assert(clean("foo/../bar") == "bar", "dotdot relative")
    assert(clean("../foo") == "../foo", "leading dotdot preserved")
    assert(clean("/../foo") == "/foo", "dotdot at root clamped")
    assert(clean("a/b/../../c") == "c", "multiple dotdot")
}

fn test_join_basic() {
    assert(join(["foo", "bar", "baz"]) == "foo/bar/baz", "simple join")
    assert(join(["/foo", "bar"]) == "/foo/bar", "absolute first segment")
    assert(join(["foo", "", "bar"]) == "foo/bar", "empty segments skipped")
    assert(join([]) == "", "empty list")
    assert(join([""]) == "", "single empty")
}

fn test_join_cleans_result() {
    assert(join(["foo/", "/bar"]) == "foo/bar", "trailing and leading slashes")
    assert(join(["a", "..", "b"]) == "b", "dotdot in join")
}

fn test_base_basic() {
    assert(base("/foo/bar.txt") == "bar.txt", "file base")
    assert(base("/foo/") == "foo", "trailing slash")
    assert(base("/") == "/", "root base")
    assert(base("") == ".", "empty base")
    assert(base("foo") == "foo", "single component")
}

fn test_dir_basic() {
    assert(dir("/foo/bar.txt") == "/foo", "file dir")
    assert(dir("/foo") == "/", "top-level dir")
    assert(dir("foo/bar") == "foo", "relative dir")
    assert(dir("foo") == ".", "single component dir")
    assert(dir("/") == "/", "root dir")
}

fn test_ext_basic() {
    assert(ext("/foo/bar.txt") == ".txt", "simple extension")
    assert(ext("file.tar.gz") == ".gz", "last extension")
    assert(ext("noext") == "", "no extension")
    assert(ext(".hidden") == "", "dotfile has no extension")
    assert(ext("/path/to/file.bur") == ".bur", "bur extension")
}
