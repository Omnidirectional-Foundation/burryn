fn must_decode(result) {
    match result {
        Ok(v) => v,
        Err(msg) => {
            assert(false, "decode failed: " + msg)
            ""
        },
    }
}

fn must_err(result) {
    match result {
        Err(_) => {},
        Ok(v) => assert(false, "expected Err, got Ok(" + str(str_len(v)) + " bytes)"),
    }
}

fn test_base64_encode_empty() {
    assert(base64_encode("") == "", "empty input must produce empty output")
}

fn test_base64_rfc4648_vectors() {
    assert(base64_encode("f") == "Zg==", "base64 of 'f'")
    assert(base64_encode("fo") == "Zm8=", "base64 of 'fo'")
    assert(base64_encode("foo") == "Zm9v", "base64 of 'foo'")
    assert(base64_encode("foob") == "Zm9vYg==", "base64 of 'foob'")
    assert(base64_encode("fooba") == "Zm9vYmE=", "base64 of 'fooba'")
    assert(base64_encode("foobar") == "Zm9vYmFy", "base64 of 'foobar'")
}

fn test_base64_decode_rfc4648_vectors() {
    assert(must_decode(base64_decode("Zg==")) == "f", "decode Zg==")
    assert(must_decode(base64_decode("Zm8=")) == "fo", "decode Zm8=")
    assert(must_decode(base64_decode("Zm9v")) == "foo", "decode Zm9v")
    assert(must_decode(base64_decode("Zm9vYg==")) == "foob", "decode Zm9vYg==")
    assert(must_decode(base64_decode("Zm9vYmE=")) == "fooba", "decode Zm9vYmE=")
    assert(must_decode(base64_decode("Zm9vYmFy")) == "foobar", "decode Zm9vYmFy")
}

fn test_base64_roundtrip_binary() {
    let mut data = ""
    let mut i = 0
    while i < 256 {
        data = data + byte_chr(i)
        i = i + 1
    }
    let encoded = base64_encode(data)
    assert(must_decode(base64_decode(encoded)) == data, "base64 roundtrip all bytes")
}

fn test_base64_decode_errors() {
    must_err(base64_decode("abc"))
    must_err(base64_decode("!!!!"))
    must_err(base64_decode("Zg=A"))
}

fn test_hex_encode_basic() {
    assert(hex_encode("") == "", "empty hex")
    assert(hex_encode("ABC") == "414243", "hex of ASCII")
    assert(hex_encode(byte_chr(0) + byte_chr(255)) == "00ff", "hex of binary bounds")
}

fn test_hex_decode_basic() {
    assert(must_decode(hex_decode("414243")) == "ABC", "hex decode ASCII")
    assert(must_decode(hex_decode("00ff")) == byte_chr(0) + byte_chr(255), "hex decode binary")
    assert(must_decode(hex_decode("4a4b")) == "JK", "hex decode lowercase")
}

fn test_hex_roundtrip_all_bytes() {
    let mut data = ""
    let mut i = 0
    while i < 256 {
        data = data + byte_chr(i)
        i = i + 1
    }
    assert(must_decode(hex_decode(hex_encode(data))) == data, "hex roundtrip all bytes")
}

fn test_hex_decode_errors() {
    must_err(hex_decode("abc"))
    must_err(hex_decode("zz"))
}

fn test_url_encode_basic() {
    assert(url_encode("hello") == "hello", "unreserved chars pass through")
    assert(url_encode("a b") == "a%20b", "space encoded")
    assert(url_encode("a+b=c&d") == "a%2bb%3dc%26d", "reserved chars encoded")
}

fn test_url_encode_unreserved_set() {
    let unreserved = "AZaz09-_.~"
    assert(url_encode(unreserved) == unreserved, "all unreserved chars pass through")
}

fn test_url_decode_basic() {
    assert(must_decode(url_decode("hello")) == "hello", "plain text")
    assert(must_decode(url_decode("a%20b")) == "a b", "space decode")
    assert(must_decode(url_decode("%41%42%43")) == "ABC", "uppercase hex decode")
}

fn test_url_roundtrip() {
    let input = "path/to/file?q=hello world&x=1+2"
    assert(must_decode(url_decode(url_encode(input))) == input, "url roundtrip")
}

fn test_url_decode_errors() {
    must_err(url_decode("%"))
    must_err(url_decode("%zz"))
}
