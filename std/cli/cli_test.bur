fn test_has_flag_present() {
    let argv = ["--verbose", "input.txt", "--output", "out.txt"]
    assert(has_flag(argv, "verbose"), "verbose flag present")
    assert(has_flag(argv, "output"), "output flag present")
    assert(!has_flag(argv, "debug"), "debug flag absent")
}

fn test_has_flag_equals_form() {
    let argv = ["--name=hello", "pos"]
    assert(has_flag(argv, "name"), "equals form detected")
    assert(!has_flag(argv, "nam"), "prefix match must not trigger")
}

fn test_get_flag_space_form() {
    let argv = ["--output", "result.txt", "--verbose"]
    match get_flag(argv, "output") {
        Some(v) => assert(v == "result.txt", "space form value"),
        None => assert(false, "output flag not found"),
    }
}

fn test_get_flag_equals_form() {
    let argv = ["--name=hello world"]
    match get_flag(argv, "name") {
        Some(v) => assert(v == "hello world", "equals form value"),
        None => assert(false, "name flag not found"),
    }
}

fn test_get_flag_absent() {
    let argv = ["--verbose"]
    match get_flag(argv, "missing") {
        None => {},
        Some(v) => assert(false, "unexpected value: " + v),
    }
}

fn test_get_flag_at_end_no_value() {
    let argv = ["--verbose", "--output"]
    match get_flag(argv, "output") {
        None => {},
        Some(v) => assert(false, "should not have value: " + v),
    }
}

fn test_positionals_basic() {
    let argv = ["--verbose", "input.txt", "--output", "out.txt", "extra"]
    let pos = positionals(argv)
    assert(len(pos) == 3, "three non-flag args")
    assert(pos[0] == "input.txt", "first positional")
    assert(pos[1] == "out.txt", "flag value appears as positional")
    assert(pos[2] == "extra", "third positional")
}

fn test_positionals_empty() {
    let argv = ["--verbose", "--debug"]
    let pos = positionals(argv)
    assert(len(pos) == 0, "no positionals")
}

fn test_positionals_all() {
    let argv = ["a", "b", "c"]
    let pos = positionals(argv)
    assert(len(pos) == 3, "all positionals")
}

fn test_positionals_equals_form_no_skip() {
    let argv = ["--name=val", "file.txt"]
    let pos = positionals(argv)
    assert(len(pos) == 1, "equals form does not consume next arg")
    assert(pos[0] == "file.txt", "positional after equals flag")
}
