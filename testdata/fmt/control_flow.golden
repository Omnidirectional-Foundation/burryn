fn main_loop() {
    let x = 10
    if x > 5 {
        println("big")
    } else {
        println("small")
    }
    if x > 100 {
        println("huge")
    } else if x > 50 {
        println("mid")
    } else {
        println("low")
    }
    let mut i = 0
    while i < 3 {
        println(i)
        i = i + 1
    }
    for v in range(0, 3) {
        println("v:", v)
    }
}

main_loop()
