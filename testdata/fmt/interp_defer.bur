fn greet(name){
println("hello, {name}!")
}
fn math_show(a,b){
println("{a} + {b} = {a + b}")
}
fn cleanup_demo(){
defer{
println("deferred: second")
}
defer{
println("deferred: first")
}
println("body")
}
fn main_loop(){
greet("world")
math_show(3,4)
cleanup_demo()
println("literal {{ braces }}")
}
main_loop()
