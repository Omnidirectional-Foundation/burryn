enum Animal {
    Cat(str),
    Dog(str, int),
    Fish,
}

fn describe(a) {
    match a {
        Animal.Cat(name) => println("cat:", name),
        Animal.Dog(name, age) => println("dog:", name, age),
        Animal.Fish => println("fish"),
    }
}

fn guarded(n) {
    match n {
        0 => println("zero"),
        x if x > 0 => println("positive"),
        _ => println("negative"),
    }
}

fn nested(opt) {
    match opt {
        Some(v) => {
            match v {
                Animal.Fish => println("some fish"),
                _ => println("some other"),
            }
        },
        None => println("none"),
    }
}

fn main_loop() {
    describe(Animal.Cat("whiskers"))
    describe(Animal.Dog("rex", 3))
    describe(Animal.Fish)
    guarded(5)
    guarded(0)
    guarded(-1)
    nested(Some(Animal.Fish))
    nested(None)
}

main_loop()
