fn test_add() {
    assert(add(2, 3) == 5, "add(2, 3) should be 5")
}

fn test_scale() {
    const factor = 5 * 2
    let ys = scale([1, 2, 3], factor)
    assert(len(ys) == 3, "length preserved")
    assert(ys[2] == 30, "3 * 10")
}

fn test_defer_runs_before_exit() {
    let mut log = []
    let run = fn() {
        defer {
            push(log, "first")
        }
        defer {
            push(log, "second")
        }
        push(log, "body")
    }
    run()
    assert(len(log) == 3, "three entries")
    assert(log[0] == "body", "body first")
    assert(log[1] == "second", "defers run LIFO")
    assert(log[2] == "first", "first registered runs last")
}
