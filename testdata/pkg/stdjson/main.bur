import json "std/json"
import testing "std/testing"

fn main() {
    match json.parse("{{\"items\":[1,2]}") {
        Ok(value) => {
            testing.assert_eq(json.render(value), "{{\"items\":[1,2]}")
            println(json.pretty(value, 2))
        },
        Err(msg) => assert(false, msg),
    }
}
