import ops "example.com/pipeline/ops"

fn add(value, a, b) {
    value + a + b
}

fn inc(value) {
    value + 1
}

fn parse_even(value) -> Result(int, str) {
    if value % 2 == 0 {
        Ok(value)
    } else {
        Err("odd")
    }
}

fn propagated(value) -> Result(int, str) {
    let parsed = (value |> parse_even)?
    Ok(parsed)
}

fn main() {
    println(str(3 |> inc))
    println(str(3 |> add(4, 5)))
    println(str(3 |> ops.double))
    println(str(3 |> ops.add(4, 5)))
    println(str(1 + 2 |> ops.double))
    println(str(3 |> inc |> ops.double))
    println(match propagated(4) {
        Ok(value) => str(value),
        Err(msg) => msg,
    })
}
