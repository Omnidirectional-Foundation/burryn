// package-level fns are inferred in SCC dependency order, so a fn defined
// in a later file (and a self- or mutually-recursive fn) stays polymorphic
// at every use site

fn main() {
    println(str(z_last([1, 2])))
    println(z_last(["a", "b"]))
    println(str(len(ping([1]))))
    println(str(len(ping(["x", "y"]))))
    match step_down(3) {
        Ok(v) => println(str(v)),
        Err(e) => println(e),
    }
}
