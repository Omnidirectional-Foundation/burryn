fn z_last(xs) {
    if len(xs) == 1 {
        xs[0]
    } else {
        z_last(slice(xs, 1, len(xs)))
    }
}

fn ping(xs) {
    if len(xs) == 0 {
        xs
    } else {
        pong(slice(xs, 1, len(xs)))
    }
}

fn pong(xs) {
    ping(xs)
}

// `?` inside a mutually-recursive group: the Option/Result decision is
// deferred until the whole group is inferred

fn step_down(n) {
    if n == 0 {
        Ok(0)
    } else {
        let v = bounce(n - 1)?
        Ok(v + 1)
    }
}

fn bounce(n) {
    step_down(n)
}
