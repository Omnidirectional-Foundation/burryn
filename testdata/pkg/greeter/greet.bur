// shared package scope: main.bur uses these without qualification

enum Mood {
    Happy,
    Grim(int),
}

pub fn greeting(mood, name) {
    match mood {
        Happy => "hello, " + name + "!",
        Grim(level) => "go away, " + name + " (level " + str(level) + ")",
    }
}

let base_excitement = 2

fn bangs(n) {
    let mut s = ""
    let mut i = 0
    while i < n + base_excitement {
        s = s + "!"
        i = i + 1
    }
    s
}
