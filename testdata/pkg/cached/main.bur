import streams "example.com/acme/streams"

fn main() {
    // arithmetic pins stream_sum's return to int, so a stale cached
    // interface with a swapped type cannot slip through unification
    let total = streams.stream_sum([1, 2, 3, 4])
    println(str(total + 1))
    println(streams.describe(streams.Reading.Reading("t", streams.scale)))
    println(streams.first_or(["x", "y"], "z"))
    println(str(streams.first_or([], 9)))
}
