// module form: defer inside package fns and fibers, LIFO across `?` exits
fn checked(s) {
    defer {
        println("checked(" + s + ") exit")
    }
    let v = parse_int(s)?
    println("checked value " + str(v))
    Some(v)
}

fn worker(ch) {
    defer {
        ch <- "worker cleanup"
    }
    ch <- "worker body"
}

fn main() {
    defer {
        println("main cleanup")
    }
    defer {
        println("main cleanup 2")
    }
    let _ = checked("7")
    let _ = checked("x")
    let ch = chan(0)
    spawn worker(ch)
    println(<-ch)
    println(<-ch)
    println("main end")
}
