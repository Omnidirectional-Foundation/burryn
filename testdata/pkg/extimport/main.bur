import lib "example.com/acme/lib"
import sub "example.com/acme/lib/sub"

fn identity(value: lib.Token) -> lib.Token {
    value
}

let echo_token = fn(value: lib.Token) -> lib.Token {
    value
}

fn main() {
    println(str(lib.answer()) + " " + sub.word())
    match echo_token(identity(lib.Token.Token(7))) {
        lib.Token.Token(value) => println(str(value)),
    }
}
