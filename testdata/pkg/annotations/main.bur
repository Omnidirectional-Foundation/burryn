import ops "burryn.dev/annotations/ops"

fn add(left: int, right: int) -> int {
    left + right
}

fn words(xs: [str]) -> [str] {
    xs
}

fn identity(value: a) -> a {
    value
}

fn main() {
    println(str(add(20, 22)))
    println(words(["typed"])[0])
    println(str(identity(7)))
    println(identity("generic"))
    println(str(ops.narrowed(20, 22)))
    println(ops.add_same("constrained ", "generic"))
    println(str(ops.only_num(1.5)))
    println(ops.only_key("key"))
    println(str(ops.only_int(7)))
    println(str(ops.only_float(2.5)))
    println(ops.only_str("string"))
}
