pub fn narrowed(left: a:num, right: a:key) -> a {
    left + right
}

pub fn add_same(left: a:addord, right: a) -> a {
    left + right
}

pub fn only_num(value: a:num) -> a {
    value
}

pub fn only_key(value: a:key) -> a {
    value
}

pub fn only_int(value: a:int) -> a {
    value
}

pub fn only_float(value: a:float) -> a {
    value
}

pub fn only_str(value: a:str) -> a {
    value
}

pub fn pop_mut(mut values: [a]) -> a {
    pop(values)
}
