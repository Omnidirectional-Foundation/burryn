let a = 3.14159
let b = 0.1
let c = 2.0
let d = 1000.0
let e = 0.5
let f = 123456789.125
let g = 0.000001
let h = 179769313486230000000000000000000.0
let i = -2.5
let j = -0.25

fn sign_word(n) {
    match n {
        -1 => "minus one",
        0 => "zero",
        -9223372036854775807 => "almost min",
        other => str(other),
    }
}

println(a, b, c, d, e, f, g, h, i, j)
println(sign_word(-1), sign_word(0), sign_word(7))
