// The `for v in ch` below is the load-bearing part of the interface-cache
// fixture: a warm build checks this package from its cached interface, so
// the channel-for metadata must come back from the `.meta` sidecar or the
// loop would be compiled as a list-for.

pub enum Reading {
    Reading(str, int),
}

pub let scale = 3

fn feed(ch, values) {
    for v in values {
        ch <- v
    }
    close(ch)
}

pub fn stream_sum(values: [int]) -> int {
    let ch = chan(2)
    spawn feed(ch, values)
    let mut total = 0
    for v in ch {
        total = total + v
    }
    total
}

pub fn describe(r: Reading) -> str {
    match r {
        Reading(label, value) => label + "=" + str(value),
    }
}

pub fn first_or(values: [a], fallback: a) -> a {
    if len(values) > 0 {
        values[0]
    } else {
        fallback
    }
}
