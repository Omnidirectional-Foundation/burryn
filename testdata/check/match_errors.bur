enum Shape {
    Circle(float),
    Rect(int, int),
    Point,
}

enum Coin {
    Heads,
    Tails,
}

enum Overlap {
    Heads,
    Extra,
}

let s = Circle(1.0)
let bad1 = match s {
    Circle(r) => r,
    Rect(w, h) => to_float(w + h),
}
let bad2 = match s {
    Circle(r, extra) => r,
    _ => 0.0,
}
let bad3 = match s {
    Circle => 1,
    _ => 0,
}
let bad4 = match s {
    Nope(x) => x,
    _ => 0,
}
let bad5 = match true {
    true => 1,
}
let bad6 = match 42 {
    1 => "one",
    2 => "two",
}
let amb = match s {
    Heads => 1,
    _ => 0,
}
let bad7 = match s {
    Shape.Wrong => 1,
    _ => 0,
}
let bad8 = match s {
    Missing.Circle(r) => r,
    _ => 0.0,
}
let arms = match s {
    Circle(_) => 1,
    _ => "no",
}
