fn wrong_param(value: int) -> int {
    value
}

fn wrong_return() -> str {
    42
}

fn only_num(value: a:num) -> a {
    value
}

fn only_key(value: a:key) -> a {
    value
}

fn incompatible(left: a:num, right: a:str) -> a {
    left
}

fn unknown_constraint(value: a:ordered) -> a {
    value
}

fn constrained_builtin(value: int:num) -> int {
    value
}

fn parameter_with_args(value: a:num(int)) -> a {
    value
}

enum ConstrainedField(a) {
    Constrained(a:num),
}

wrong_param("not an int")
only_num("not numeric")
only_key(1.5)
