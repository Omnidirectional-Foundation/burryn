{
  "name": "burryn",
  "displayName": "Burryn",
  "description": "Burryn language support: syntax highlighting and LSP diagnostics",
  "version": "0.1.0",
  "publisher": "burryn",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:burryn"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "burryn",
        "aliases": ["Burryn", "burryn"],
        "extensions": [".bur"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "burryn",
        "scopeName": "source.burryn",
        "path": "./syntaxes/burryn.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Burryn",
      "properties": {
        "burryn.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the bur binary. If empty, uses 'bur' from PATH."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.82.0",
    "typescript": "^5.5.0"
  }
}
