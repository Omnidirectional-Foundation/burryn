{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Burryn",
  "scopeName": "source.burryn",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#numbers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.burryn",
          "match": "//.*$"
        },
        {
          "name": "comment.block.burryn",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.burryn",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.burryn",
              "match": "\\\\[nt\"\\\\]"
            },
            {
              "name": "meta.interpolation.burryn",
              "begin": "\\{",
              "end": "\\}",
              "patterns": [
                { "include": "source.burryn" }
              ]
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.burryn",
          "match": "\\b(if|else|while|for|in|match|return|break|continue|spawn|select|defer)\\b"
        },
        {
          "name": "keyword.declaration.burryn",
          "match": "\\b(let|mut|const|fn|enum|pub|import)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.burryn",
          "match": "\\b(int|float|str|bool|unit)\\b"
        },
        {
          "name": "entity.name.type.burryn",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.burryn",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.option.burryn",
          "match": "\\b(Some|None|Ok|Err)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.burryn",
          "match": "\\b[a-z_][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.burryn",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.channel.burryn",
          "match": "<-|<-"
        },
        {
          "name": "keyword.operator.try.burryn",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.comparison.burryn",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.burryn",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.burryn",
          "match": "="
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.burryn",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.burryn",
          "match": "\\b[0-9]+\\b"
        }
      ]
    }
  }
}
