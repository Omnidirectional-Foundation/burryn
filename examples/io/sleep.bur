// sleep(ms) suspends the current fiber for at least the given duration.
// Golden output verifies ordering and continuation, not wall-clock time.

fn main_loop() {
    println("before sleep(0)")
    sleep(0)
    println("after sleep(0)")

    println("before sleep(1)")
    sleep(1)
    println("after sleep(1)")

    // sleep inside a function returns normally
    fn nap() {
        sleep(0)
        "napped"
    }
    println(nap())
}

main_loop()
