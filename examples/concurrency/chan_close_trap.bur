// Channel trap: closing an already-closed channel traps (exit 4).
// No .golden file — this script is expected to trap, producing no stdout.
// Run manually: bur run examples/concurrency/chan_close_trap.bur ; echo "exit: $?"

fn main_trap() {
    let ch = chan(1)
    close(ch)
    close(ch)
}

main_trap()
