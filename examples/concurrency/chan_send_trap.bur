// Channel trap: sending on a closed channel traps (exit 4).
// No .golden file — this script is expected to trap, producing no stdout.
// Run manually: bur run examples/concurrency/chan_send_trap.bur ; echo "exit: $?"
//
// Note: recv() on a closed-and-drained channel is safe — it returns None.
// Only send and double-close are traps.

fn main_trap() {
    let ch = chan(1)
    close(ch)
    ch <- 1
}

main_trap()
