const answer = 40 + 2
const greeting = "hello" + ", constants"
const max_int = 9223372036854775807
const ordered = max_int > max_int - 1
const short_circuit = false && 1 / 0 == 0

fn increment() {
    const next = answer + 1
    next
}

let previous = max_int - 1
println(greeting)
println(str(answer), str(increment()))
println(str(ordered), str(max_int > previous))
println(str(short_circuit))
