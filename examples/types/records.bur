// Records: literal construction, field access, functional update.

let p = record { x: 1, y: 2 }
println(p.x)
println(p.y)
println(p)

let p2 = record { p | x: 10 }
println(p2.x)
println(p2.y)

let person = record { name: "alice", age: 30 }
println(person.name)
println(person.age)

let empty = record {}
println(empty == empty)

println(p == record { x: 1, y: 2 })
println(p == p2)
