// the entry package of a module starts at fn main
import "example.com/examples/geometry/shapes"

fn main() {
    let all = [shapes.Shape.Circle(2.0), shapes.Shape.Rect(3, 4), shapes.Shape.Point]
    for s in all {
        println(shapes.describe(s), "-> area", shapes.area(s))
    }
    println("total:", total(all))
}

fn total(xs) {
    let mut sum = 0.0
    for s in xs {
        sum = sum + shapes.area(s)
    }
    sum
}
