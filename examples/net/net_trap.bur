// Net trap: net_close on an invalid handle traps (exit 4).
// No .golden file — this script is expected to trap, producing no stdout.
// Run manually: bur run examples/net/net_trap.bur ; echo "exit: $?"

fn main_trap() {
    // Handle 99999 was never opened; net_close traps.
    net_close(99999)
}

main_trap()
